---
export interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;

const GA4_ID = 'G-P7ZL8QPS87';
const GSC_CODE = 'L-ZMZr7109ivNV3YWlnWh7mgmSHN_kzAz2-Woa316AA';
const siteUrl = 'https://zowekine.com';
const ogImage = `${siteUrl}/og-image.png`;
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, viewport-fit=cover">
  <meta name="description" content={description}>
  <title>{title}</title>

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={siteUrl}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:locale" content="fr_BE">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>

  {GSC_CODE && <meta name="google-site-verification" content={GSC_CODE}>}

  <!-- Hreflang : même URL pour toutes les langues -->
  <link rel="alternate" hreflang="fr" href={siteUrl + "/"}>
  <link rel="alternate" hreflang="nl" href={siteUrl + "/"}>
  <link rel="alternate" hreflang="en" href={siteUrl + "/"}>
  <link rel="alternate" hreflang="x-default" href={siteUrl + "/"}>

  <!-- Favicon -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">

  <!-- PWA Manifest -->
  <link rel="manifest" href="/manifest.json">

  <!-- iOS Safari PWA -->
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Zowe">
  <link rel="apple-touch-icon" href="/icons/icon-192x192.png">
  <link rel="apple-touch-icon" sizes="152x152" href="/icons/icon-152x152.png">
  <link rel="apple-touch-startup-image" href="/icons/splash-640x1136.png" media="(device-width: 320px) and (-webkit-device-pixel-ratio: 2)">
  <link rel="apple-touch-startup-image" href="/icons/splash-750x1334.png" media="(device-width: 375px) and (-webkit-device-pixel-ratio: 2)">
  <link rel="apple-touch-startup-image" href="/icons/splash-1170x2532.png" media="(device-width: 390px) and (-webkit-device-pixel-ratio: 3)">
  <link rel="apple-touch-startup-image" href="/icons/splash-1179x2556.png" media="(device-width: 393px) and (-webkit-device-pixel-ratio: 3)">
  <link rel="apple-touch-startup-image" href="/icons/splash-1290x2796.png" media="(device-width: 430px) and (-webkit-device-pixel-ratio: 3)">

  <!-- Android Chrome -->
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="theme-color" content="#6B1F2A">

  <!-- Preconnect critiques -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://www.googletagmanager.com">

  <!-- DNS-prefetch APIs externes -->
  <link rel="dns-prefetch" href="https://maps.googleapis.com">
  <link rel="dns-prefetch" href="https://api.mapbox.com">
  <link rel="dns-prefetch" href="https://api.resend.com">
  <link rel="dns-prefetch" href="https://api.brevo.com">
  <link rel="dns-prefetch" href="https://formspree.io">
  <link rel="dns-prefetch" href="https://www.google-analytics.com">

  <!-- Préchargement image signature (visible sans scroll) -->
  <link rel="preload" href="/images/signature_zoe_premium.png" as="image">

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Inter:wght@300;400;500&family=Great+Vibes&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">

  <!-- Google Analytics 4 — Consent Mode -->
  <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
  <script is:inline define:vars={{ GA4_ID }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('consent', 'default', { analytics_storage: 'denied' });
    gtag('js', new Date());
    gtag('config', GA4_ID, { anonymize_ip: true });
    if (localStorage.getItem('zowe-cookies') === 'accepted') {
      gtag('consent', 'update', { analytics_storage: 'granted' });
    }
  </script>

  <!-- Netlify Identity -->
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <!-- Schema.org LocalBusiness + MedicalBusiness -->
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "MedicalBusiness"],
    "name": "Zowe — Zoé Grêde",
    "description": "Kinésithérapie de haute précision à Rhode-Saint-Genèse. Méthode BELTRA. Soins premium au cabinet et à domicile.",
    "url": "https://zowekine.com",
    "telephone": "+32471783746",
    "email": "zoegrede.kine@gmail.com",
    "image": "https://zowekine.com/images/zoe.jpg",
    "priceRange": "€€€",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Rue des Iris, Boîte 2",
      "addressLocality": "Rhode-Saint-Genèse",
      "postalCode": "1640",
      "addressCountry": "BE"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 50.74625,
      "longitude": 4.357579
    },
    "areaServed": [
      "Rhode-Saint-Genèse","Linkebeek","Beersel","Lot","Braine-l'Alleud"
    ],
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "08:00", "closes": "19:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "09:00", "closes": "14:00" }
    ],
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5.0",
      "reviewCount": "26",
      "bestRating": "5"
    },
    "sameAs": ["https://www.instagram.com/kine.zowe"]
  })}</script>
</head>
<body>
  <!-- Curseur custom desktop -->
  <div class="cursor-dot"    aria-hidden="true"></div>
  <div class="cursor-circle" aria-hidden="true"></div>

  <slot />

  <!-- Cookie banner -->
  <!-- Sélecteur de langue fixe (pages sans nav) -->
  <div id="langSelectorFixed" class="lang-selector-fixed" aria-label="Choisir la langue">
    <button class="lang-btn" data-lang="fr">FR</button>
    <span aria-hidden="true">·</span>
    <button class="lang-btn" data-lang="nl">NL</button>
    <span aria-hidden="true">·</span>
    <button class="lang-btn" data-lang="en">EN</button>
  </div>

  <div id="cookieBanner" class="cookie-banner" role="dialog" aria-label="Consentement cookies" hidden>
    <p class="cookie-banner__text">
      <span data-i18n="cookie.text">Ce site utilise Google Analytics pour mesurer son audience de façon anonymisée.</span>
      <a href="/confidentialite" data-i18n="cookie.learn_more">En savoir plus</a>
    </p>
    <div class="cookie-banner__actions">
      <button id="cookieRefuse" class="cookie-btn cookie-btn--refuse" data-i18n="cookie.refuse">Refuser</button>
      <button id="cookieAccept" class="cookie-btn cookie-btn--accept" data-i18n="cookie.accept">Accepter</button>
    </div>
  </div>
  <script is:inline>
    // Haptic feedback — Android vibration + iOS scale animation
    window.hapticFeedback = function(intensity) {
      var patterns = { light: 10, medium: 20, success: [10, 50, 10] };
      if (navigator.vibrate) navigator.vibrate(patterns[intensity] || 10);
    };

    // Sélecteur de langue fixe — affiché uniquement sur les pages sans nav
    var fixedSel = document.getElementById('langSelectorFixed');
    if (fixedSel && !document.querySelector('.nav')) {
      fixedSel.classList.add('active');
    }

    // Partie C — logo doré sur la page d'accueil
    const nav = document.getElementById('nav');
    if (nav) {
      if (window.location.pathname === '/' || window.location.pathname === '') {
        nav.classList.add('is-homepage');
      }
      window.addEventListener('scroll', () => {
        nav.classList.toggle('scrolled', window.scrollY > 60);
      }, { passive: true });
    }

    // Mobile menu toggle + overlay + animation slide
    const toggle  = document.getElementById('navToggle');
    const links   = document.getElementById('navLinks');
    const overlay = document.getElementById('navOverlay');

    function closeMenu() {
      if (!links) return;
      links.classList.remove('open');
      if (toggle) { toggle.classList.remove('open'); toggle.setAttribute('aria-label', 'Ouvrir le menu'); }
      if (overlay) overlay.classList.remove('active');
      document.body.style.overflow = '';
    }

    if (toggle && links) {
      toggle.addEventListener('click', () => {
        const isOpen = links.classList.toggle('open');
        toggle.classList.toggle('open', isOpen);
        toggle.setAttribute('aria-label', isOpen ? 'Fermer le menu' : 'Ouvrir le menu');
        if (overlay) overlay.classList.toggle('active', isOpen);
        document.body.style.overflow = isOpen ? 'hidden' : '';
      });
      links.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', closeMenu);
      });
    }
    if (overlay) overlay.addEventListener('click', closeMenu);

    // Fade-in on scroll (progressive enhancement) — re-joue à chaque passage
    document.body.classList.add('js-ready');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        entry.target.classList.toggle('visible', entry.isIntersecting);
      });
    }, { threshold: 0.12 });
    document.querySelectorAll('[data-anim]').forEach(el => observer.observe(el));

    // Cookie banner
    (function() {
      var pref = localStorage.getItem('zowe-cookies');
      if (pref) return;
      var banner = document.getElementById('cookieBanner');
      if (!banner) return;
      banner.hidden = false;
      document.getElementById('cookieAccept').addEventListener('click', function() {
        localStorage.setItem('zowe-cookies', 'accepted');
        banner.hidden = true;
        if (typeof gtag !== 'undefined') gtag('consent', 'update', { analytics_storage: 'granted' });
      });
      document.getElementById('cookieRefuse').addEventListener('click', function() {
        localStorage.setItem('zowe-cookies', 'refused');
        banner.hidden = true;
      });
    })();
  </script>
  <!-- i18n : détection langue + application traductions -->
  <script is:inline>
  (function() {
    var LANGS = ['fr', 'nl', 'en'];
    var _cache = {};
    var _fr    = {};

    // Lecture d'une clé dot-notation dans un objet imbriqué ("services.tiers.0.name")
    function getVal(obj, key) {
      if (!obj || typeof obj !== 'object') return undefined;
      return key.split('.').reduce(function(o, k) {
        return (o != null && typeof o === 'object') ? o[k] : undefined;
      }, obj);
    }

    function saveFr() {
      document.querySelectorAll('[data-i18n]').forEach(function(el) {
        _fr['t:' + el.getAttribute('data-i18n')] = el.textContent;
      });
      document.querySelectorAll('[data-i18n-html]').forEach(function(el) {
        _fr['h:' + el.getAttribute('data-i18n-html')] = el.innerHTML;
      });
    }

    function hasVal(v) { return v !== null && v !== undefined && v !== ''; }

    function applyTranslations(lang, t) {
      document.querySelectorAll('[data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n');
        var val = t ? getVal(t, key) : undefined;
        el.textContent = hasVal(val) ? val
                       : (hasVal(_fr['t:' + key]) ? _fr['t:' + key] : el.textContent);
      });
      document.querySelectorAll('[data-i18n-html]').forEach(function(el) {
        var key = el.getAttribute('data-i18n-html');
        var val = t ? getVal(t, key) : undefined;
        el.innerHTML = hasVal(val) ? val
                     : (hasVal(_fr['h:' + key]) ? _fr['h:' + key] : el.innerHTML);
      });
      document.documentElement.lang = lang;
      document.querySelectorAll('.lang-btn').forEach(function(btn) {
        btn.classList.toggle('active', btn.dataset.lang === lang);
      });
      window._i18n = t || null;
      localStorage.setItem('zowe-lang', lang);
      try { window.dispatchEvent(new CustomEvent('zowe:langchange', { detail: { lang: lang } })); } catch(_) {}
    }

    function autoTranslatePage(lang) {
      var elems = [];
      document.querySelectorAll('[data-i18n]').forEach(function(el) {
        elems.push({ el: el, type: 'text', orig: _fr['t:' + el.getAttribute('data-i18n')] || el.textContent });
      });
      document.querySelectorAll('[data-i18n-html]').forEach(function(el) {
        elems.push({ el: el, type: 'html', orig: _fr['h:' + el.getAttribute('data-i18n-html')] || el.innerHTML });
      });
      if (!elems.length) return;
      fetch('/.netlify/functions/translate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ texts: elems.map(function(e) { return e.orig; }), lang: lang }),
      })
        .then(function(r) { return r.ok ? r.json() : null; })
        .then(function(data) {
          if (!data || !Array.isArray(data.translations)) return;
          data.translations.forEach(function(tr, i) {
            if (!hasVal(tr)) return;
            if (elems[i].type === 'text') elems[i].el.textContent = tr;
            else elems[i].el.innerHTML = tr;
          });
        })
        .catch(function() {});
    }

    // Fusionne deux objets imbriqués — source remplace target uniquement si target est undefined
    function mergeDeep(target, source) {
      Object.keys(source || {}).forEach(function(k) {
        if (target[k] === undefined) {
          target[k] = source[k];
        } else if (typeof target[k] === 'object' && !Array.isArray(target[k]) && typeof source[k] === 'object') {
          mergeDeep(target[k], source[k]);
        }
      });
      return target;
    }

    function setLang(lang) {
      if (LANGS.indexOf(lang) === -1) lang = 'fr';
      if (lang === 'fr') { applyTranslations('fr', null); return; }

      var mode = window.__translationMode || 'manual';

      // Étape 1 — toujours appliquer les traductions depuis les JSON (contenu + UI strings)
      if (_cache[lang]) { applyTranslations(lang, _cache[lang]); }

      var content = window.__i18nContent && window.__i18nContent[lang];
      if (content && !_cache[lang]) { applyTranslations(lang, content); }

      fetch('/i18n/' + lang + '.json')
        .then(function(r) { return r.ok ? r.json() : null; })
        .then(function(ui) {
          if (!ui) return;
          var merged = content ? mergeDeep(JSON.parse(JSON.stringify(content)), ui) : ui;
          _cache[lang] = merged;
          applyTranslations(lang, merged);

          // Étape 2 — mode auto : compléter via IA les éléments encore en français
          if (mode === 'auto') {
            var toTranslate = [];
            document.querySelectorAll('[data-i18n]').forEach(function(el) {
              var frText = _fr['t:' + el.getAttribute('data-i18n')];
              if (frText && el.textContent.trim() === frText.trim()) {
                toTranslate.push({ el: el, type: 'text', text: frText });
              }
            });
            document.querySelectorAll('[data-i18n-html]').forEach(function(el) {
              var frText = _fr['h:' + el.getAttribute('data-i18n-html')];
              if (frText && el.innerHTML.trim() === frText.trim()) {
                toTranslate.push({ el: el, type: 'html', text: frText });
              }
            });
            if (toTranslate.length) {
              fetch('/.netlify/functions/translate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ texts: toTranslate.map(function(e) { return e.text; }), lang: lang }),
              })
                .then(function(r) { return r.ok ? r.json() : null; })
                .then(function(data) {
                  if (!data || !Array.isArray(data.translations)) return;
                  data.translations.forEach(function(tr, i) {
                    if (!hasVal(tr)) return;
                    if (toTranslate[i].type === 'text') toTranslate[i].el.textContent = tr;
                    else toTranslate[i].el.innerHTML = tr;
                  });
                })
                .catch(function() {});
            }
          }
        })
        .catch(function() { if (content) _cache[lang] = content; });
    }

    saveFr();

    var stored   = localStorage.getItem('zowe-lang');
    var browser  = (navigator.language || 'fr').slice(0, 2).toLowerCase();
    var detected = stored || browser;
    var lang = LANGS.indexOf(detected) !== -1 ? detected : 'fr';

    if (lang !== 'fr') {
      setLang(lang);
    } else {
      document.querySelectorAll('.lang-btn').forEach(function(btn) {
        btn.classList.toggle('active', btn.dataset.lang === 'fr');
      });
    }

    document.addEventListener('click', function(e) {
      var btn = e.target.closest('.lang-btn');
      if (btn && btn.dataset.lang) {
        window.hapticFeedback('light');
        setLang(btn.dataset.lang);
      }
    });

    // Helper global : window.__t('form.submit')
    window.__t = function(key) { return window._i18n ? getVal(window._i18n, key) : null; };
    window.__setLang = setLang;
  })();
  </script>
  <script is:inline>
    // Redirige vers la page dédiée si un token identity est dans l'URL
    var hash = window.location.hash;
    if (hash.includes('recovery_token') || hash.includes('invite_token') || hash.includes('confirmation_token')) {
      window.location.href = '/identity/' + hash;
    }

    if (window.netlifyIdentity) {
      window.netlifyIdentity.on('init', function(user) {
        if (!user) {
          window.netlifyIdentity.on('login', function() {
            document.location.href = '/admin/';
          });
        }
      });
    }
    window.addEventListener('load', function() {
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('login', function() {
          document.location.href = '/admin/';
        });
      }
    });
  </script>
  <script is:inline>
  /* ── Préchargement intelligent ── */
  (function() {
    // Ne rien faire si économie de données ou connexion lente
    var conn = navigator.connection;
    if (conn && (conn.saveData || conn.effectiveType === '2g' || conn.effectiveType === 'slow-2g')) return;

    var preloaded = new Set();
    function preloadHref(href, as) {
      if (!href || preloaded.has(href)) return;
      preloaded.add(href);
      var link = document.createElement('link');
      link.rel = as === 'document' ? 'prefetch' : 'preload';
      link.as  = as;
      link.href = href;
      if (as === 'font') link.crossOrigin = 'anonymous';
      document.head.appendChild(link);
    }

    // Préchargement images des sections suivantes via IntersectionObserver
    var sections = document.querySelectorAll('.section');
    if (sections.length) {
      var secObs = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (!entry.isIntersecting) return;
          // Précharger les images lazy de la section suivante
          var next = entry.target.nextElementSibling;
          if (next) {
            next.querySelectorAll('img[loading="lazy"]').forEach(function(img) {
              if (img.src) preloadHref(img.src, 'image');
            });
          }
        });
      }, { rootMargin: '300px' });
      sections.forEach(function(s) { secObs.observe(s); });
    }

    // Prefetch pages internes au survol (>200ms)
    document.querySelectorAll('a[href^="/"]').forEach(function(link) {
      var timer;
      link.addEventListener('mouseenter', function() {
        timer = setTimeout(function() { preloadHref(link.href, 'document'); }, 200);
      });
      link.addEventListener('mouseleave', function() { clearTimeout(timer); });
    });
  })();
  </script>
  <script is:inline>
  /* ── Curseur doré custom — desktop uniquement ── */
  (function() {
    if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;
    var dot    = document.querySelector('.cursor-dot');
    var circle = document.querySelector('.cursor-circle');
    if (!dot || !circle) return;

    document.addEventListener('mousemove', function(e) {
      dot.style.left    = e.clientX + 'px';
      dot.style.top     = e.clientY + 'px';
      circle.style.left = e.clientX + 'px';
      circle.style.top  = e.clientY + 'px';
    }, { passive: true });

    var selectors = 'a, button, input, textarea, select, [role="button"], label[for], .beltra-card, .faq-item summary, .lang-btn, .testimonials-btn, .cadeau-card, .loc-social-btn, .localisation-cta, .nav-cta, .sticky-cta, .interactive';
    document.querySelectorAll(selectors).forEach(function(el) {
      el.addEventListener('mouseenter', function() {
        dot.classList.add('is-hover');
        circle.classList.add('is-hover');
      });
      el.addEventListener('mouseleave', function() {
        dot.classList.remove('is-hover');
        circle.classList.remove('is-hover');
      });
    });
  })();
  </script>

  <!-- PWA — Service Worker + popup iOS -->
  <script is:inline>
  /* ── Service Worker ── */
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', function() {
      navigator.serviceWorker.register('/sw.js').catch(function(){});
    });
  }

  /* ── Popup installation iOS Safari ── */
  (function() {
    function isIOS() { return /iphone|ipad|ipod/i.test(navigator.userAgent); }
    function isStandalone() { return window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone === true; }
    if (!isIOS() || isStandalone() || localStorage.getItem('zowe-install-prompt')) return;

    var popup = document.createElement('div');
    popup.className = 'pwa-install-prompt';
    popup.setAttribute('role', 'dialog');
    popup.setAttribute('aria-label', 'Installer Zowe');
    popup.innerHTML = '<button class="pwa-install-close" onclick="this.parentElement.remove();localStorage.setItem(\'zowe-install-prompt\',\'seen\')" aria-label="Fermer">×</button>'
