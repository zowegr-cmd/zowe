---
import infos from '../content/infos.json';
import gallery from '../content/gallery.json';
import session from '../content/session.json';
const pathname = Astro.url.pathname;
const showNav  = !pathname.startsWith('/merci');
const isDark   = pathname === '/' || pathname === '' || pathname.startsWith('/galerie');

export interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;

const _waLink     = `https://wa.me/32471783746?text=${encodeURIComponent("Bonjour Zoé, je souhaite en savoir plus sur l'expérience Zowe.")}`;
const _igLink     = infos.instagram || 'https://www.instagram.com/kine.zowe';
const _reviewLink = infos.googleReviews || '';
const _mapsUrl    = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent((infos.address||'') + ', ' + (infos.city||'') + ', Belgique')}`;

const GA4_ID  = 'G-P7ZL8QPS87';
const GSC_CODE = 'L-ZMZr7109ivNV3YWlnWh7mgmSHN_kzAz2-Woa316AA';
const siteUrl  = 'https://zowekine.com';
const ogImage  = `${siteUrl}/og-image.png`;
const pageUrl  = Astro.url.href;          // URL complète de la page courante
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, viewport-fit=cover">
  <meta name="description" content={description}>
  <title>{title}</title>

  <!-- Canonical -->
  <link rel="canonical" href={pageUrl}>

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={pageUrl}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:locale" content="fr_BE">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>

  {GSC_CODE && <meta name="google-site-verification" content={GSC_CODE}>}

  <!-- Hreflang : même URL par langue (contenu JS client-side) -->
  <link rel="alternate" hreflang="fr" href={pageUrl}>
  <link rel="alternate" hreflang="nl" href={pageUrl}>
  <link rel="alternate" hreflang="en" href={pageUrl}>
  <link rel="alternate" hreflang="x-default" href={pageUrl}>

  <!-- Favicon -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">

  <!-- PWA Manifest -->
  <link rel="manifest" href="/manifest.json">

  <!-- iOS Safari PWA -->
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Zowe">
  <link rel="apple-touch-icon" href="/icons/icon-192x192.png">
  <link rel="apple-touch-icon" sizes="152x152" href="/icons/icon-152x152.png">
  <link rel="apple-touch-startup-image" href="/icons/splash-640x1136.png" media="(device-width: 320px) and (-webkit-device-pixel-ratio: 2)">
  <link rel="apple-touch-startup-image" href="/icons/splash-750x1334.png" media="(device-width: 375px) and (-webkit-device-pixel-ratio: 2)">
  <link rel="apple-touch-startup-image" href="/icons/splash-1170x2532.png" media="(device-width: 390px) and (-webkit-device-pixel-ratio: 3)">
  <link rel="apple-touch-startup-image" href="/icons/splash-1179x2556.png" media="(device-width: 393px) and (-webkit-device-pixel-ratio: 3)">
  <link rel="apple-touch-startup-image" href="/icons/splash-1290x2796.png" media="(device-width: 430px) and (-webkit-device-pixel-ratio: 3)">

  <!-- Android Chrome -->
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="theme-color" content="#F5F0E8">

  <!-- Preconnect critiques -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://www.googletagmanager.com">

  <!-- DNS-prefetch APIs externes -->
  <link rel="dns-prefetch" href="https://maps.googleapis.com">
  <link rel="dns-prefetch" href="https://api.mapbox.com">
  <link rel="dns-prefetch" href="https://api.resend.com">
  <link rel="dns-prefetch" href="https://api.brevo.com">
  <link rel="dns-prefetch" href="https://formspree.io">
  <link rel="dns-prefetch" href="https://www.google-analytics.com">

  <!-- Préchargement image signature (visible sans scroll) -->
  <link rel="preload" href="/images/signature_zoe_premium.png" as="image">

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Inter:wght@300;400;500&family=Great+Vibes&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">

  <!-- Google Analytics 4 — Consent Mode -->
  <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
  <script is:inline define:vars={{ GA4_ID }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('consent', 'default', { analytics_storage: 'denied' });
    gtag('js', new Date());
    gtag('config', GA4_ID, { anonymize_ip: true });
    if (localStorage.getItem('zowe-cookies') === 'accepted') {
      gtag('consent', 'update', { analytics_storage: 'granted' });
    }
  </script>

  <!-- Netlify Identity -->
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <!-- Schema.org LocalBusiness + MedicalBusiness -->
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "MedicalBusiness"],
    "name": "Zowe — Zoé Grêde",
    "description": "Kinésithérapie de haute précision à Rhode-Saint-Genèse. Méthode BELTRA. Soins premium au cabinet et à domicile.",
    "url": "https://zowekine.com",
    "telephone": "+32471783746",
    "email": "zoegrede.kine@gmail.com",
    "image": "https://zowekine.com/images/zoe.jpg",
    "priceRange": "€€€",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Rue des Iris, Boîte 2",
      "addressLocality": "Rhode-Saint-Genèse",
      "postalCode": "1640",
      "addressCountry": "BE"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 50.74625,
      "longitude": 4.357579
    },
    "areaServed": [
      "Rhode-Saint-Genèse","Linkebeek","Beersel","Lot","Braine-l'Alleud"
    ],
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "08:00", "closes": "19:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "09:00", "closes": "14:00" }
    ],
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5.0",
      "reviewCount": "26",
      "bestRating": "5"
    },
    "sameAs": ["https://www.instagram.com/kine.zowe"]
  })}</script>
</head>
<body>
