  <style is:global>
  .pwa-install-prompt {
    position: fixed;
    bottom: -200px;
    left: 1rem;
    right: 1rem;
    z-index: 9999;
    background: #F5F0E8;
    border: 1px solid rgba(107,31,42,0.2);
    border-radius: 10px;
    padding: 1.1rem 1.25rem;
    box-shadow: 0 -4px 24px rgba(0,0,0,0.12);
    transition: bottom 0.4s cubic-bezier(0.34,1.56,0.64,1);
  }
  .pwa-install-prompt.visible { bottom: 1rem; }
  .pwa-install-body {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }
  .pwa-install-title {
    font-family: Georgia, serif;
    font-style: italic;
    font-size: 0.88rem;
    color: #6B1F2A;
    margin-bottom: 0.3rem;
    line-height: 1.3;
  }
  .pwa-install-hint {
    font-family: system-ui, sans-serif;
    font-size: 0.75rem;
    color: #5C5C5C;
    line-height: 1.4;
  }
  .pwa-install-hint strong { color: #1A1A1A; }
  .pwa-install-close {
    position: absolute;
    top: 0.6rem;
    right: 0.75rem;
    background: none;
    border: none;
    font-size: 1.2rem;
    color: #AAAAAA;
    cursor: pointer;
    line-height: 1;
    padding: 0.1rem 0.3rem;
  }
  </style>

  <!-- FAB + Sticky global JS -->
  <script is:inline>
  /* ── FAB toggle ── */
  (function(){
    var fabContainer = document.getElementById('fabContainer');
    var fabMain      = document.getElementById('fabMain');
    var fabOverlay   = document.getElementById('fabOverlay');
    var fabActions   = document.getElementById('fabActions');
    if (!fabMain) return;

    function openFab() {
      fabContainer.classList.add('open');
      fabOverlay.classList.add('visible');
      fabMain.setAttribute('aria-expanded', 'true');
      fabMain.setAttribute('aria-label', 'Fermer les actions rapides');
      fabActions.setAttribute('aria-hidden', 'false');
      if (navigator.vibrate) navigator.vibrate(10);
      if (typeof gtag === 'function') gtag('event', 'fab_open');
    }
    function closeFab() {
      fabContainer.classList.remove('open');
      fabOverlay.classList.remove('visible');
      fabMain.setAttribute('aria-expanded', 'false');
      fabMain.setAttribute('aria-label', 'Ouvrir les actions rapides');
      fabActions.setAttribute('aria-hidden', 'true');
    }

    fabMain.addEventListener('click', function(e) {
      e.stopPropagation();
      fabContainer.classList.contains('open') ? closeFab() : openFab();
    });
    fabOverlay.addEventListener('click', closeFab);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && fabContainer.classList.contains('open')) {
        closeFab(); fabMain.focus();
      }
    });
    document.querySelectorAll('.fab-sub').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var action = this.getAttribute('data-action');
        if (navigator.vibrate) navigator.vibrate(8);
        if (typeof gtag === 'function' && action) gtag('event', action);
        setTimeout(closeFab, 300);
      });
    });
  })();

  /* ── Sticky CTA — visible dès le chargement sur les pages hors accueil ── */
  (function() {
    var path = window.location.pathname;
    if (path === '/' || path === '') return;
    var s = document.getElementById('stickyCta');
    if (!s) return;
    s.style.opacity   = '1';
    s.style.transform = 'translateY(0)';
    s.style.pointerEvents = 'auto';
  })();

  /* ── KinoQuick FAB — activation globale ── */
  (function() {
    fetch('/.netlify/functions/settings?type=kinoquick')
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(kq) {
        if (!kq || !kq.enabled || !kq.url) return;
        var item = document.getElementById('kqFabItem');
        var tip  = document.getElementById('kqFabTooltip');
        if (!item) return;
        if (tip && kq.btn) {
          var lang = localStorage.getItem('zowe-lang') || 'fr';
          tip.textContent = (kq.btn[lang] || kq.btn.fr) || 'Réserver';
        }
        item.style.display = '';
        var container = document.getElementById('fabContainer');
        if (container) container.classList.add('kq-fab-active');
      }).catch(function() {});
  })();
  </script>
