    <nav class={`nav${isDark ? ' is-homepage' : ''}`} id="nav" aria-label="Navigation principale">
      <a href="/" class="nav-logo" aria-label="Zowe — Accueil">
        <svg class="nav-monogram" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 43.95 42.15" aria-hidden="true" focusable="false">
