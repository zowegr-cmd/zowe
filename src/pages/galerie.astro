---
import Layout from '../layouts/Layout.astro';
import gallery from '../content/gallery.json';

if (!gallery.visible) {
  return Astro.redirect('/');
}

const photos = gallery.photos;

function initialPos(i: number, n: number): string {
  let p = i;
  if (p > n / 2) p -= n;
  if (p <= -3) return 'fl';
  if (p >= 3)  return 'fr';
  return String(p);
}

function getAlt(photo: any, i: number): string {
  const title = photo.title_fr;
  if (title && title !== 'Expérience Zowe') return title;
  if (i === 0) return 'Cabinet Kinovea Rhode-Saint-Genèse — Kinésithérapie Zowe BELTRA';
  const m = (photo.image as string).match(/(\d+(?:-\d+)?)\./);
  const num = m ? m[1] : String(i + 1);
  return `Soin kinésithérapie BELTRA — Zoé Grêde Rhode-Saint-Genèse — ${num}`;
}

function padNum(n: number): string {
  return n < 10 ? '0' + n : String(n);
}

const EAGER = 5;

function webpOf(src: string): string {
  return src.replace(/\.(jpg|jpeg)$/i, '.webp');
}
---
<Layout
  title="Galerie — Zowe · Kinésithérapie BELTRA Rhode-Saint-Genèse"
  description="Découvrez l'expérience Zowe en images — cabinet Kinovea, soins et protocoles BELTRA à Rhode-Saint-Genèse.">

  <style>
    /* ══════════════════════════════════════
       PAGE
    ══════════════════════════════════════ */
    .gc-page {
      background: #1A0508;
      min-height: 100vh;
      color: #F5F0E8;
      padding-top: 6rem;
    }

    /* ══════════════════════════════════════
       HEADER (desktop only)
    ══════════════════════════════════════ */
    .gc-header {
      max-width: 860px;
      margin: 0 auto;
      padding: 0 2rem 2.5rem;
    }
    /* langSelectorFixed inutile — le nav a son propre sélecteur */
    :global(#langSelectorFixed) { display: none !important; }
    /* Nav caché sur mobile — gc-mobile prend le relais */
    @media (max-width: 768px) {
      :global(#nav) { display: none !important; }
    }


    .gc-back {
      display: inline-flex; align-items: center; gap: .5rem;
      font-size: .68rem; letter-spacing: .14em; text-transform: uppercase;
      color: rgba(245,240,232,.6); text-decoration: none;
      margin-bottom: 2rem; transition: color .2s;
    }
    .gc-back:hover { color: #F5F0E8; }
    .gc-header h1 {
      font-family: 'Cinzel', Georgia, serif;
      font-size: clamp(1.5rem, 4vw, 2.4rem);
      font-weight: 400; letter-spacing: .1em; text-transform: uppercase;
      color: #F5F0E8; margin-bottom: .75rem; line-height: 1.2;
    }
    .gc-header p {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1rem; font-style: italic;
      color: rgba(245,240,232,.7); line-height: 1.65;
    }

    /* ══════════════════════════════════════
       DESKTOP CAROUSEL
    ══════════════════════════════════════ */
    .gc-wrap {
      position: relative;
      user-select: none; -webkit-user-select: none;
    }
    .gc-track {
      position: relative; height: 760px; overflow: hidden;
    }
    .gc-slide {
      position: absolute; top: 50%; left: 50%;
      border-radius: 8px; overflow: hidden;
      will-change: transform;
      transition: transform .4s ease-out, width .4s ease-out, height .4s ease-out,
                  opacity .4s ease-out, box-shadow .4s ease-out;
    }
    .gc-slide picture { display: block; width: 100%; height: 100%; }
    .gc-slide img {
      width: 100%; height: 100%;
      object-fit: cover; object-position: center;
      display: block; pointer-events: none; background: #2A0810;
    }
    .gc-overlay {
      position: absolute; inset: 0; pointer-events: none;
      transition: background .4s ease-out;
    }
    .gc-slide::before {
      content: ''; position: absolute; inset: 0;
      background: #1A0508; z-index: 1; transition: opacity .3s;
    }
    .gc-slide.loaded::before { opacity: 0; pointer-events: none; }

    .gc-slide[data-pos="0"] {
      width: 580px; height: 680px;
      transform: translate(-50%, -50%);
      z-index: 3; cursor: zoom-in;
      border-radius: 12px;
      box-shadow: 0 0 80px rgba(107,31,42,.55), 0 25px 70px rgba(0,0,0,.55);
    }
    .gc-slide[data-pos="0"] .gc-overlay { background: transparent; }
    .gc-slide[data-pos="-1"] {
      width: 280px; height: 480px;
      transform: translate(calc(-50% - 450px), calc(-50% + 40px));
      z-index: 2; cursor: pointer; border-radius: 10px;
    }
    .gc-slide[data-pos="-1"] .gc-overlay { background: rgba(26,5,8,.42); }
    .gc-slide[data-pos="-1"]:hover { transform: translate(calc(-50% - 450px), calc(-50% + 36px)); }
    .gc-slide[data-pos="-1"]:hover .gc-overlay { background: rgba(26,5,8,.28); }
    .gc-slide[data-pos="1"] {
      width: 280px; height: 480px;
      transform: translate(calc(-50% + 450px), calc(-50% + 40px));
      z-index: 2; cursor: pointer; border-radius: 10px;
    }
    .gc-slide[data-pos="1"] .gc-overlay { background: rgba(26,5,8,.42); }
    .gc-slide[data-pos="1"]:hover { transform: translate(calc(-50% + 450px), calc(-50% + 36px)); }
    .gc-slide[data-pos="1"]:hover .gc-overlay { background: rgba(26,5,8,.28); }
    .gc-slide[data-pos="-2"] {
      width: 280px; height: 480px;
      transform: translate(calc(-50% - 760px), calc(-50% + 40px));
      z-index: 1; cursor: pointer;
    }
    .gc-slide[data-pos="-2"] .gc-overlay { background: rgba(26,5,8,.62); }
    .gc-slide[data-pos="2"] {
      width: 280px; height: 480px;
      transform: translate(calc(-50% + 760px), calc(-50% + 40px));
      z-index: 1; cursor: pointer;
    }
    .gc-slide[data-pos="2"] .gc-overlay { background: rgba(26,5,8,.62); }
    .gc-slide[data-pos="fl"] {
      width: 280px; height: 480px;
      transform: translate(calc(-50% - 1150px), calc(-50% + 40px));
      z-index: 0; opacity: 0; pointer-events: none;
    }
    .gc-slide[data-pos="fr"] {
      width: 280px; height: 480px;
      transform: translate(calc(-50% + 1150px), calc(-50% + 40px));
      z-index: 0; opacity: 0; pointer-events: none;
    }

    /* ── ARROWS ── */
    .gc-arrow {
      position: absolute; top: 50%; transform: translateY(-50%);
      z-index: 10; width: 46px; height: 46px; border-radius: 50%;
      border: 1px solid rgba(201,169,110,.22);
      background: rgba(15,5,8,.65); color: rgba(201,169,110,.75);
      cursor: pointer; display: flex; align-items: center; justify-content: center;
      transition: border-color .2s, color .2s, background .2s;
      backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
    }
    .gc-arrow:hover { border-color: rgba(201,169,110,.55); color: #C9A96E; background: rgba(15,5,8,.88); }
    .gc-arrow--prev { left: 1.25rem; }
    .gc-arrow--next { right: 1.25rem; }
    .gc-arrow svg { width: 18px; height: 18px; fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }

    /* ── INFO PANEL ── */
    .gc-info {
      max-width: 560px; margin: 1.75rem auto 0;
      padding: 0 2rem; text-align: center; min-height: 110px;
      transition: opacity .18s ease;
    }
    .gc-info.fading { opacity: 0; }
    .gc-badge {
      display: inline-block; font-size: .56rem; font-weight: 600;
      letter-spacing: .22em; text-transform: uppercase;
      color: #C9A96E; border: 1px solid rgba(201,169,110,.3);
      padding: .22rem .65rem; margin-bottom: .75rem;
    }
    .gc-info__title {
      font-family: 'Cinzel', Georgia, serif;
      font-size: 1.05rem; font-weight: 400;
      letter-spacing: .18em; text-transform: uppercase;
      color: #F5F0E8; margin-bottom: .5rem; line-height: 1.4;
    }
    .gc-info__desc {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: .93rem; font-style: italic;
      color: rgba(245,240,232,.6); line-height: 1.7;
    }
    .gc-counter {
      font-size: .62rem; letter-spacing: .18em;
      color: rgba(245,240,232,.22); margin-top: 1.1rem;
    }

    /* ── DOTS ── */
    .gc-dots {
      display: flex; align-items: center; justify-content: center;
      gap: 7px; margin-top: 1.5rem; padding: 0 2rem;
      flex-wrap: nowrap; max-width: 100%; overflow: hidden;
    }
    .gc-dot {
      width: 5px; height: 5px; border-radius: 50%;
      background: rgba(245,240,232,.18);
      border: none; cursor: pointer; padding: 0;
      flex-shrink: 0;
      transition: background .25s, transform .25s, opacity .25s;
    }
    .gc-dot--active { background: #C9A96E; transform: scale(1.5); }

    /* ── CTA desktop ── */
    .gc-cta {
      background: #6B1F2A; padding: 4.5rem 2rem;
      text-align: center; margin-top: 4rem;
    }
    .gc-cta__title {
      font-family: Georgia, 'Cormorant Garamond', serif;
      font-size: clamp(1.4rem, 3.5vw, 1.85rem);
      font-weight: 300; font-style: italic;
      color: #F5F0E8; margin-bottom: .75rem; line-height: 1.3;
    }
    .gc-cta__sub {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1rem; font-style: italic;
      color: rgba(245,240,232,.65); margin-bottom: 2.25rem; line-height: 1.55;
    }
    .gc-cta__btns { display: flex; align-items: center; justify-content: center; gap: 1rem; flex-wrap: wrap; }
    .gc-cta-btn {
      display: inline-flex; align-items: center; gap: .45rem;
      padding: .85rem 2rem; font-size: .72rem; font-weight: 600;
      letter-spacing: .14em; text-transform: uppercase;
      text-decoration: none; transition: background .2s, color .2s;
    }
    .gc-cta-btn--solid { background: #F5F0E8; color: #6B1F2A; }
    .gc-cta-btn--solid:hover { background: #fff; }
    .gc-cta-btn--outline { border: 1px solid rgba(245,240,232,.55); color: #F5F0E8; }
    .gc-cta-btn--outline:hover { border-color: #F5F0E8; }

    /* ── LIGHTBOX ── */
    .gc-lightbox {
      display: none; position: fixed; inset: 0; z-index: 9000;
      background: rgba(0,0,0,.95); align-items: center; justify-content: center;
    }
    .gc-lightbox.open { display: flex; }
    .gc-lightbox__img { max-height: 90vh; max-width: 90vw; object-fit: contain; border-radius: 2px; box-shadow: 0 0 80px rgba(0,0,0,.8); }
    .gc-lightbox__close { position: fixed; top: 1.25rem; right: 1.5rem; font-size: 1.75rem; color: rgba(245,240,232,.75); background: none; border: none; cursor: pointer; line-height: 1; z-index: 9001; transition: color .2s; }
    .gc-lightbox__close:hover { color: #F5F0E8; }
    .gc-lightbox__prev, .gc-lightbox__next {
      position: fixed; top: 50%; transform: translateY(-50%);
      background: rgba(245,240,232,.12); border: 1px solid rgba(245,240,232,.2);
      color: rgba(245,240,232,.8); width: 44px; height: 44px;
      border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center;
      font-size: 1.2rem; z-index: 9001; transition: background .2s;
    }
    .gc-lightbox__prev:hover, .gc-lightbox__next:hover { background: rgba(245,240,232,.22); }
    .gc-lightbox__prev { left: 1.25rem; }
    .gc-lightbox__next { right: 1.25rem; }

    /* ── EMPTY ── */
    .gc-empty {
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      height: 520px; gap: 1.5rem;
    }
    .gc-empty p { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; font-size: 1.1rem; color: rgba(245,240,232,.3); }

    /* ══════════════════════════════════════
       MOBILE FULLSCREEN
    ══════════════════════════════════════ */
    .gc-mobile { display: none; }

    @media (max-width: 768px) {
      /* Masquer tout le desktop */
      .gc-page        { padding-top: 0; }
      .gc-header      { display: none; }
      .gc-desktop     { display: none; }
      .gc-lightbox    { display: none !important; }

      /* Afficher le mobile — page immersive sans scroll */
      .gc-mobile {
        display: flex;
        flex-direction: column;
        height: 100dvh;
        overflow: hidden;
        background: #1A0508;
      }

      /* ── Barre du haut — 8% ── */
      .gc-m-topbar {
        flex: 0 0 8%;
        background: #1A0508;
        display: flex;
        align-items: center;
        padding: 0 20px;
        padding-top: env(safe-area-inset-top);
      }
      /* ── Titre — 15% ── */
      .gc-m-title {
        flex: 0 0 15%;
        background: #1A0508;
        padding: 0 20px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        border: none;
      }
      .gc-m-title h1 {
        font-family: Georgia, serif;
        font-size: 26px;
        font-style: italic;
        font-weight: 300;
        color: #F5F0E8;
        margin: 0 0 3px;
        line-height: 1.2;
      }
      .gc-m-title p {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 13px;
        font-style: italic;
        color: rgba(245,240,232,.6);
        line-height: 1.4;
        margin: 0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      /* ── Photo section — flex:1 (~65% restant) ── */
      .gc-m-photo {
        flex: 1;
        min-height: 0;
        position: relative;
        width: 100vw;
        overflow: hidden;
        background: #1A0508;
        display: flex;
        flex-direction: column;
      }

      /* ── Scroll bloqué + fond bordeaux jusqu'en bas ── */
      :global(html) {
        overflow: hidden !important;
        height: 100dvh !important;
        background-color: #1A0508 !important;
      }
      :global(body) {
        overflow: hidden !important;
        height: 100dvh !important;
        background-color: #1A0508 !important;
      }
      :global(body)::after {
        content: '';
        display: block;
        position: fixed;
        bottom: 0; left: 0; right: 0;
        height: env(safe-area-inset-bottom);
        background-color: #1A0508;
        z-index: 9999;
      }

      /* ── Barre de progression dorée centrée ── */
      .gc-m-prog-bar {
        position: absolute;
        top: 12px;
        left: 50%;
        transform: translateX(-50%);
        width: 120px;
        height: 2px;
        background: rgba(245,240,232,.15);
        border-radius: 1px;
        overflow: hidden;
        z-index: 10;
        pointer-events: none;
      }
      .gc-m-prog-fill {
        height: 100%;
        background: #C9A96E;
        border-radius: 1px;
        transition: width .3s ease;
        width: 0%;
      }

      /* Back link dans topbar */
      .gc-m-back {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
        color: rgba(245,240,232,.5); text-decoration: none;
        transition: color .2s;
      }
      .gc-m-back:hover { color: #F5F0E8; }

      /* Track container */
      .gc-m-outer {
        flex: 1;
        min-height: 0;
        width: 100%;
        overflow: hidden;
        touch-action: pan-y;
        background: #1A0508;
      }

      /* Flex track */
      .gc-m-track {
        display: flex;
        height: 100%;
        padding-left: 12px;
        will-change: transform;
        transform: translateZ(0) translateX(0);
        transition: transform .35s cubic-bezier(.25,.46,.45,.94);
        background: #1A0508;
      }
      @media (prefers-reduced-motion: reduce) {
        .gc-m-track { transition: none !important; }
      }

      /* Chaque slide — non-active par défaut */
      .gc-m-slide {
        width: calc(100vw - 24px);
        min-width: calc(100vw - 24px);
        height: 100%;
        flex-shrink: 0;
        position: relative;
        overflow: hidden;
        background: #1A0508;
        border-radius: 10px;
        transform-origin: center;
        transform: scale(0.88);
        filter: blur(3px);
        opacity: 0.7;
        transition:
          transform  .45s cubic-bezier(.25,.46,.45,.94),
          filter     .45s cubic-bezier(.25,.46,.45,.94),
          opacity    .45s cubic-bezier(.25,.46,.45,.94),
          box-shadow .45s cubic-bezier(.25,.46,.45,.94);
      }
      /* Photo active */
      .gc-m-slide.active {
        transform: scale(1);
        filter: none;
        opacity: 1;
        z-index: 2;
        border-radius: 12px;
        box-shadow: 0 0 40px rgba(107,31,42,.5);
      }
      .gc-m-slide picture { display: block; width: 100%; height: 100%; }
      .gc-m-img {
        width: 100%; height: 100%;
        object-fit: cover; object-position: center;
        display: block; background: #1A0508;
      }

      /* Overlay obscurcissant les non-actives */
      .gc-m-slide::after {
        content: '';
        position: absolute; inset: 0;
        background: rgba(26,5,8,.45);
        transition: opacity .45s cubic-bezier(.25,.46,.45,.94);
        pointer-events: none;
        z-index: 2;
      }
      .gc-m-slide.active::after { opacity: 0; }

      /* Gradient info bas photo */
      .gc-m-slide-info {
        position: absolute; bottom: 0; left: 0; right: 0;
        z-index: 3;
        background: linear-gradient(to top, rgba(8,2,4,.9) 0%, rgba(8,2,4,.5) 50%, transparent 100%);
        padding: 60px 20px 20px;
        pointer-events: none;
        opacity: 0;
        transition: opacity .35s ease;
      }
      .gc-m-slide.active .gc-m-slide-info { opacity: 1; }
      .gc-m-slide-counter {
        font-size: .62rem; letter-spacing: .2em;
        color: #C9A96E; display: block; margin-bottom: 6px;
        font-family: Georgia, serif;
      }
      .gc-m-slide-title {
        font-family: Georgia, 'Cormorant Garamond', serif;
        font-size: .88rem; font-style: italic;
        color: rgba(245,240,232,.9);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        margin: 0;
      }

      /* ── Footer — dots 12% ── */
      .gc-m-footer {
        flex: 0 0 12%;
        min-height: 72px;
        background: #1A0508;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        padding-bottom: env(safe-area-inset-bottom);
      }

      /* ── Dots — pill animé (dans le flux) ── */
      .gc-m-dots {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        pointer-events: none;
      }

      /* ── Sticky caché + FAB sous la photo ── */
      :global(.sticky-cta) { display: none !important; }
      :global(.fab-container) {
        bottom: calc(24px + env(safe-area-inset-bottom)) !important;
        right: 20px !important;
      }
      .gc-m-dot {
        height: 6px;
        width: 6px;
        border-radius: 3px;
        background: rgba(245,240,232,.3);
        border: none; padding: 0;
        flex-shrink: 0;
        pointer-events: all;
        cursor: pointer;
        transition: width .3s ease, background .3s ease, opacity .25s, margin .25s;
      }
      .gc-m-dot.active { width: 20px; background: #C9A96E; }

      /* ── Section info sous la photo ── */
      .gc-m-info {
        background: #1A0508;
        padding: 24px 20px 20px;
      }
      .gc-m-info__title {
        font-family: Georgia, 'Cormorant Garamond', serif;
        font-size: 1.15rem; font-style: italic; font-weight: 300;
        color: #F5F0E8; margin-bottom: 8px; line-height: 1.3;
      }
      .gc-m-info__sub {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: .88rem; font-style: italic;
        color: rgba(245,240,232,.55); line-height: 1.55;
      }

      /* ── CTA mobile ── */
      .gc-m-cta {
        background: #6B1F2A;
        padding: 40px 20px;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .gc-m-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 48px;
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        text-decoration: none;
        transition: background .2s, color .2s;
      }
      .gc-m-btn--solid  { background: #F5F0E8; color: #6B1F2A; }
      .gc-m-btn--solid:hover { background: #fff; }
      .gc-m-btn--outline { border: 1px solid rgba(245,240,232,.6); color: #F5F0E8; }
      .gc-m-btn--outline:hover { border-color: #F5F0E8; }
    }
  </style>

  <div class="gc-page">

    <!-- HEADER — desktop only -->
    <div class="gc-header">
      <a href="/" class="gc-back" data-i18n="pages.back">← Retour à l'accueil</a>
      <h1
        data-lang-fr={gallery.title_fr}
        data-lang-nl={gallery.title_nl}
        data-lang-en={gallery.title_en}
      >{gallery.title_fr}</h1>
      <p
        data-lang-fr={gallery.intro_fr}
        data-lang-nl={gallery.intro_nl}
        data-lang-en={gallery.intro_en}
      >{gallery.intro_fr}</p>
    </div>

    {photos.length === 0 ? (
      <div class="gc-empty">
