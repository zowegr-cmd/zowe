---
import Layout from '../layouts/Layout.astro';
import gallery from '../content/gallery.json';

if (!gallery.visible) {
  return Astro.redirect('/');
}

const photos = gallery.photos;

function initialPos(i: number, n: number): string {
  let p = i;
  if (p > n / 2) p -= n;
  if (p <= -3) return 'fl';
  if (p >= 3)  return 'fr';
  return String(p);
}

function getAlt(photo: any, i: number): string {
  const title = photo.title_fr;
  if (title && title !== 'Expérience Zowe') return title;
  if (i === 0) return 'Cabinet Kinovea Rhode-Saint-Genèse — Kinésithérapie Zowe BELTRA';
  const m = (photo.image as string).match(/(\d+(?:-\d+)?)\./);
  const num = m ? m[1] : String(i + 1);
  return `Soin kinésithérapie BELTRA — Zoé Grêde Rhode-Saint-Genèse — ${num}`;
}

// Eager load only the 5 first slides
const EAGER = 5;
---
<Layout
  title="Galerie — Zowe · Kinésithérapie BELTRA Rhode-Saint-Genèse"
  description="Découvrez l'expérience Zowe en images — cabinet Kinovea, soins et protocoles BELTRA à Rhode-Saint-Genèse.">

  <style>
    /* ═══ FONTS ═══ */
    .gc-cinzel   { font-family: 'Cinzel', Georgia, serif; }
    .gc-cormorant{ font-family: 'Cormorant Garamond', Georgia, serif; }

    /* ═══ PAGE ═══ */
    .gc-page {
      background: #1A0508;
      min-height: 100vh;
      color: #F5F0E8;
      padding-top: 4rem;
    }

    /* ═══ HEADER ═══ */
    .gc-header {
      max-width: 860px;
      margin: 0 auto;
      padding: 0 2rem 2.5rem;
    }
    .gc-back {
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      font-size: .68rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: rgba(201,169,110,.55);
      text-decoration: none;
      margin-bottom: 2rem;
      transition: color .2s;
    }
    .gc-back:hover { color: #C9A96E; }
    .gc-header h1 {
      font-family: 'Cinzel', Georgia, serif;
      font-size: clamp(1.5rem, 4vw, 2.4rem);
      font-weight: 400;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: #F5F0E8;
      margin-bottom: .75rem;
      line-height: 1.2;
    }
    .gc-header p {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1rem;
      font-style: italic;
      color: rgba(245,240,232,.45);
      line-height: 1.65;
    }

    /* ═══ CAROUSEL WRAP ═══ */
    .gc-wrap {
      position: relative;
      user-select: none;
      -webkit-user-select: none;
    }

    /* ═══ TRACK ═══ */
    .gc-track {
      position: relative;
      height: 760px;
      overflow: hidden;
    }

    /* ═══ SLIDES ═══ */
    .gc-slide {
      position: absolute;
      top: 50%; left: 50%;
      border-radius: 4px;
      overflow: hidden;
      will-change: transform;
      transition:
        transform  .4s ease-out,
        width      .4s ease-out,
        height     .4s ease-out,
        opacity    .4s ease-out,
        box-shadow .4s ease-out;
    }
    .gc-slide img {
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
      pointer-events: none;
      background: #2A0810;
    }
    .gc-overlay {
      position: absolute; inset: 0;
      pointer-events: none;
      transition: background .4s ease-out;
    }
    /* Placeholder spinner while loading */
    .gc-slide::before {
      content: '';
      position: absolute;
      inset: 0;
      background: #1A0508;
      z-index: 1;
      transition: opacity .3s;
    }
    .gc-slide.loaded::before { opacity: 0; pointer-events: none; }

    /* ── CENTER ── */
    .gc-slide[data-pos="0"] {
      width: 580px; height: 680px;
      transform: translate(-50%, -50%);
      z-index: 3;
      box-shadow: 0 0 80px rgba(107,31,42,.55), 0 25px 70px rgba(0,0,0,.55);
      cursor: zoom-in;
    }
    .gc-slide[data-pos="0"] .gc-overlay { background: transparent; }

    /* ── LEFT ── */
    .gc-slide[data-pos="-1"] {
      width: 280px; height: 480px;
      transform: translate(calc(-50% - 450px), calc(-50% + 40px));
      z-index: 2; cursor: pointer;
    }
    .gc-slide[data-pos="-1"] .gc-overlay { background: rgba(26,5,8,.42); }
    .gc-slide[data-pos="-1"]:hover { transform: translate(calc(-50% - 450px), calc(-50% + 36px)); }
    .gc-slide[data-pos="-1"]:hover .gc-overlay { background: rgba(26,5,8,.28); }

    /* ── RIGHT ── */
    .gc-slide[data-pos="1"] {
      width: 280px; height: 480px;
      transform: translate(calc(-50% + 450px), calc(-50% + 40px));
      z-index: 2; cursor: pointer;
    }
    .gc-slide[data-pos="1"] .gc-overlay { background: rgba(26,5,8,.42); }
    .gc-slide[data-pos="1"]:hover { transform: translate(calc(-50% + 450px), calc(-50% + 36px)); }
    .gc-slide[data-pos="1"]:hover .gc-overlay { background: rgba(26,5,8,.28); }

    /* ── FAR LEFT ── */
    .gc-slide[data-pos="-2"] {
      width: 280px; height: 480px;
      transform: translate(calc(-50% - 760px), calc(-50% + 40px));
      z-index: 1; cursor: pointer;
    }
    .gc-slide[data-pos="-2"] .gc-overlay { background: rgba(26,5,8,.62); }

    /* ── FAR RIGHT ── */
    .gc-slide[data-pos="2"] {
      width: 280px; height: 480px;
      transform: translate(calc(-50% + 760px), calc(-50% + 40px));
      z-index: 1; cursor: pointer;
    }
    .gc-slide[data-pos="2"] .gc-overlay { background: rgba(26,5,8,.62); }

    /* ── HIDDEN ── */
    .gc-slide[data-pos="fl"] {
      width: 280px; height: 480px;
      transform: translate(calc(-50% - 1150px), calc(-50% + 40px));
      z-index: 0; opacity: 0; pointer-events: none;
    }
    .gc-slide[data-pos="fr"] {
      width: 280px; height: 480px;
      transform: translate(calc(-50% + 1150px), calc(-50% + 40px));
      z-index: 0; opacity: 0; pointer-events: none;
    }

    /* ═══ MOBILE INFO OVERLAY ═══ */
    .gc-info-mobile {
      display: none;
      position: absolute;
      bottom: 0; left: 0; right: 0;
      z-index: 4;
      background: linear-gradient(to top, rgba(15,3,5,.92) 0%, rgba(15,3,5,.5) 55%, transparent 100%);
      padding: 3.5rem 1.5rem 1.25rem;
      pointer-events: none;
      transition: opacity .2s ease, transform .2s ease;
    }
    .gc-info-mobile.fading { opacity: 0; transform: translateY(8px); }
    .gc-info-mobile__title {
      font-family: 'Cinzel', Georgia, serif;
      font-size: 1rem;
      font-weight: 400;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: #F5F0E8;
      margin-bottom: .35rem;
    }
    .gc-info-mobile__desc {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: .88rem;
      font-style: italic;
      color: rgba(245,240,232,.65);
      line-height: 1.5;
    }
    .gc-info-mobile__badge {
      display: inline-block;
      font-size: .55rem;
      font-weight: 600;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: #C9A96E;
      border: 1px solid rgba(201,169,110,.35);
      padding: .18rem .55rem;
      margin-bottom: .55rem;
    }

    /* ═══ ARROWS ═══ */
    .gc-arrow {
      position: absolute;
      top: 50%; transform: translateY(-50%);
      z-index: 10;
      width: 46px; height: 46px;
      border-radius: 50%;
      border: 1px solid rgba(201,169,110,.22);
      background: rgba(15,5,8,.65);
      color: rgba(201,169,110,.75);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: border-color .2s, color .2s, background .2s;
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
    }
    .gc-arrow:hover {
      border-color: rgba(201,169,110,.55);
      color: #C9A96E;
      background: rgba(15,5,8,.88);
    }
    .gc-arrow--prev { left: 1.25rem; }
    .gc-arrow--next { right: 1.25rem; }
    .gc-arrow svg {
      width: 18px; height: 18px;
      fill: none; stroke: currentColor;
      stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;
    }

    /* ═══ INFO PANEL (desktop) ═══ */
    .gc-info {
      max-width: 560px;
      margin: 1.75rem auto 0;
      padding: 0 2rem;
      text-align: center;
      min-height: 110px;
      transition: opacity .18s ease;
    }
    .gc-info.fading { opacity: 0; }
    .gc-badge {
      display: inline-block;
      font-size: .56rem;
      font-weight: 600;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: #C9A96E;
      border: 1px solid rgba(201,169,110,.3);
      padding: .22rem .65rem;
      margin-bottom: .75rem;
    }
    .gc-info__title {
      font-family: 'Cinzel', Georgia, serif;
      font-size: 1.05rem;
      font-weight: 400;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: #F5F0E8;
      margin-bottom: .5rem;
      line-height: 1.4;
    }
    .gc-info__desc {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: .93rem;
      font-style: italic;
      color: rgba(245,240,232,.6);
      line-height: 1.7;
    }
    .gc-counter {
      font-size: .62rem;
      letter-spacing: .18em;
      color: rgba(245,240,232,.22);
      margin-top: 1.1rem;
    }

    /* ═══ DOTS ═══ */
    .gc-dots {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
      margin-top: 1.5rem;
      padding: 0 2rem;
      flex-wrap: nowrap;
      max-width: 100%;
      overflow: hidden;
    }
    .gc-dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: rgba(245,240,232,.18);
      border: none; cursor: pointer; padding: 0;
      flex-shrink: 0;
      transition: background .25s, transform .25s, opacity .25s;
    }
    .gc-dot--active { background: #C9A96E; transform: scale(1.5); }

    /* ═══ CTA ═══ */
    .gc-cta {
      background: #6B1F2A;
      padding: 4.5rem 2rem;
      text-align: center;
      margin-top: 4rem;
    }
    .gc-cta__title {
      font-family: Georgia, 'Cormorant Garamond', serif;
      font-size: clamp(1.4rem, 3.5vw, 1.85rem);
      font-weight: 300;
      font-style: italic;
      color: #F5F0E8;
      margin-bottom: .75rem;
      line-height: 1.3;
    }
    .gc-cta__sub {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1rem;
      font-style: italic;
      color: rgba(245,240,232,.65);
      margin-bottom: 2.25rem;
      line-height: 1.55;
    }
    .gc-cta__btns {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .gc-cta-btn {
      display: inline-flex;
      align-items: center;
      gap: .45rem;
      padding: .85rem 2rem;
      font-size: .72rem;
      font-weight: 600;
      letter-spacing: .14em;
      text-transform: uppercase;
      text-decoration: none;
      transition: background .2s, color .2s;
    }
    .gc-cta-btn--solid {
      background: #F5F0E8;
      color: #6B1F2A;
    }
    .gc-cta-btn--solid:hover { background: #fff; }
    .gc-cta-btn--outline {
      border: 1px solid rgba(245,240,232,.55);
      color: #F5F0E8;
    }
    .gc-cta-btn--outline:hover { border-color: #F5F0E8; }

    /* ═══ LIGHTBOX ═══ */
    .gc-lightbox {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 9000;
      background: rgba(0,0,0,.95);
      align-items: center;
      justify-content: center;
    }
    .gc-lightbox.open { display: flex; }
    .gc-lightbox__img {
      max-height: 90vh;
      max-width: 90vw;
      object-fit: contain;
      border-radius: 2px;
      box-shadow: 0 0 80px rgba(0,0,0,.8);
    }
    .gc-lightbox__close {
      position: fixed;
      top: 1.25rem; right: 1.5rem;
      font-size: 1.75rem;
      color: rgba(245,240,232,.75);
      background: none;
      border: none;
      cursor: pointer;
      line-height: 1;
      z-index: 9001;
      transition: color .2s;
    }
    .gc-lightbox__close:hover { color: #F5F0E8; }
    .gc-lightbox__prev,
    .gc-lightbox__next {
      position: fixed;
      top: 50%; transform: translateY(-50%);
      background: rgba(245,240,232,.12);
      border: 1px solid rgba(245,240,232,.2);
      color: rgba(245,240,232,.8);
      width: 44px; height: 44px;
      border-radius: 50%;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      z-index: 9001;
      transition: background .2s;
    }
    .gc-lightbox__prev:hover,
    .gc-lightbox__next:hover { background: rgba(245,240,232,.22); }
    .gc-lightbox__prev { left: 1.25rem; }
    .gc-lightbox__next { right: 1.25rem; }

    /* ═══ EMPTY ═══ */
    .gc-empty {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 520px;
      gap: 1.5rem;
    }
    .gc-empty p {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-style: italic;
      font-size: 1.1rem;
      color: rgba(245,240,232,.3);
    }

    /* ═══ MOBILE ═══ */
    @media (max-width: 767px) {
      .gc-page { padding-top: 3.5rem; }
      .gc-track { height: 75vh; min-height: 380px; }

      /* Center: full width, 75vh */
      .gc-slide[data-pos="0"] {
        width: 100vw;
        height: 75vh;
        min-height: 380px;
        transform: translate(-50%, -50%);
        border-radius: 0;
        box-shadow: none;
        cursor: default;
      }

      /* Left peek: 60px visible */
      .gc-slide[data-pos="-1"] {
        width: 120px; height: calc(75vh - 60px);
        min-height: 300px;
        transform: translate(calc(-50vw - 60px), calc(-50% + 30px));
        border-radius: 0 4px 4px 0;
      }
      .gc-slide[data-pos="-1"]:hover {
        transform: translate(calc(-50vw - 60px), calc(-50% + 30px));
      }
      .gc-slide[data-pos="-1"] .gc-overlay { background: rgba(26,5,8,.52); }

      /* Right peek: 60px visible */
      .gc-slide[data-pos="1"] {
        width: 120px; height: calc(75vh - 60px);
        min-height: 300px;
        transform: translate(calc(50vw - 60px), calc(-50% + 30px));
        border-radius: 4px 0 0 4px;
      }
      .gc-slide[data-pos="1"]:hover {
        transform: translate(calc(50vw - 60px), calc(-50% + 30px));
      }
      .gc-slide[data-pos="1"] .gc-overlay { background: rgba(26,5,8,.52); }

      /* Far and hidden: off-screen */
      .gc-slide[data-pos="-2"],
      .gc-slide[data-pos="2"]  { opacity: 0; pointer-events: none; }
      .gc-slide[data-pos="fl"],
      .gc-slide[data-pos="fr"] { opacity: 0; pointer-events: none; }

      /* Mobile overlay info: visible */
      .gc-info-mobile { display: block; }

      /* Desktop info: hidden */
      .gc-info { display: none; }

      /* Arrows: hidden */
      .gc-arrow { display: none; }

      /* Dots: smaller, tighter */
      .gc-dots { gap: 5px; margin-top: 1rem; }
      .gc-dot  { width: 4px; height: 4px; }

      .gc-cta { margin-top: 2.5rem; padding: 3.5rem 1.5rem; }
      .gc-cta__btns { flex-direction: column; align-items: stretch; }
      .gc-cta-btn { justify-content: center; }

      .gc-lightbox__prev { left: .5rem; }
      .gc-lightbox__next { right: .5rem; }
    }
  </style>

  <div class="gc-page">

    <!-- Header -->
    <div class="gc-header">
      <a href="/" class="gc-back" data-i18n="pages.back">← Retour à l'accueil</a>
      <h1
        data-lang-fr={gallery.title_fr}
        data-lang-nl={gallery.title_nl}
        data-lang-en={gallery.title_en}
      >{gallery.title_fr}</h1>
      <p
        data-lang-fr={gallery.intro_fr}
        data-lang-nl={gallery.intro_nl}
        data-lang-en={gallery.intro_en}
      >{gallery.intro_fr}</p>
    </div>

    {photos.length === 0 ? (
      <div class="gc-empty">
        <svg width="64" height="60" viewBox="0 0 44 42" fill="rgba(245,240,232,.12)" aria-hidden="true"><path d="M37.44,29.86c.39.11.68.24.85.43.18.18.32.37.46.56.11.17.3.27.53.33.26.06.48.05.67-.09.18-.12.33-.31.46-.59l3.41-6.7c.1-.22.16-.42.12-.59-.03-.17-.14-.31-.36-.41-.18-.09-.35-.12-.5-.06-.17.05-.31.16-.46.34l-1.16,1.66c-.59.85-1.14,1.52-1.61,2.03-.49.49-.98.85-1.45,1.07-.47.21-1.01.3-1.59.28-.57-.03-1.23-.14-2.01-.35l-9.84-2.55.05-.18,14.33-3.79c.4-.1.71-.12.95-.04.25.07.47.17.68.26.18.08.39.09.62.03.27-.08.44-.19.54-.41.1-.18.14-.43.12-.74l-.31-7.51c-.02-.25-.07-.45-.19-.59-.1-.14-.28-.19-.51-.18-.21,0-.38.07-.47.19-.13.12-.18.3-.22.53l-.2,2.03c-.11,1.03-.24,1.88-.41,2.55-.18.67-.42,1.21-.73,1.64-.31.43-.74.76-1.25,1.02-.52.26-1.16.48-1.93.69l-10.12,2.68,10.9-10.59c.29-.29.55-.46.81-.5.25-.06.49-.08.72-.1.2-.02.39-.12.55-.29.2-.19.3-.38.28-.61,0-.22-.1-.46-.27-.71l-3.95-6.4c-.15-.21-.29-.35-.45-.42-.16-.07-.33-.03-.54.1-.18.12-.28.25-.31.41-.05.16-.02.34.07.57l.81,1.86c.42.96.72,1.76.9,2.43.17.67.22,1.26.16,1.79-.06.52-.26,1.03-.59,1.51-.33.48-.77.98-1.35,1.54l-7.53,7.31,4.32-14.58c.12-.38.26-.67.46-.83.2-.17.38-.31.58-.44.17-.11.28-.29.35-.51.08-.27.07-.48-.06-.68-.12-.18-.3-.34-.58-.48L24.58.15c-.22-.11-.42-.17-.59-.14-.17.03-.31.13-.42.34-.09.18-.13.35-.08.51.04.16.16.31.33.46l1.63,1.22c.83.63,1.49,1.19,1.97,1.68.47.5.82,1,1.02,1.48.2.48.27,1.02.22,1.59-.04.58-.18,1.24-.41,2l-3.3,11.15-.58,1.97c-.29,1.02-1.21,1.79-2.33,1.82-1.12.03-2.08-.68-2.43-1.68l-.63-2.09-3.34-11.14c-.23-.77-.37-1.43-.42-2-.06-.58.02-1.12.21-1.61.21-.48.54-.98,1.02-1.48.49-.49,1.14-1.05,1.97-1.69l1.61-1.23c.18-.16.29-.3.33-.46.07-.15.03-.33-.08-.51-.11-.22-.24-.32-.42-.35-.17-.03-.37.02-.6.15l-6.56,3.66c-.28.15-.47.31-.58.5-.12.18-.14.4-.06.67.07.22.18.39.36.51.18.12.38.27.57.43.2.17.34.45.45.84l4.37,14.56-7.55-7.27c-.58-.55-1.01-1.06-1.35-1.54-.32-.47-.53-.98-.59-1.5-.06-.52,0-1.12.16-1.79.18-.68.48-1.48.89-2.44l.81-1.86c.08-.22.11-.4.06-.56-.03-.17-.14-.3-.31-.41-.2-.12-.37-.15-.5