  <!-- ════════════════════════════════
       JS DESKTOP CAROUSEL
  ════════════════════════════════ -->
  <script is:inline define:vars={{ __photos: photos }}>
  (function() {
    if (window.innerWidth <= 768) return;

    var photos = __photos;
    var total  = photos.length;
    if (!total) return;

    var current    = 0;
    var autoTimer  = null;
    var resumeTimer= null;
    var txStart    = null;
    var lbOpen     = false;
    var loaded     = new Set();

    var getLang = function() { return localStorage.getItem('zowe-lang') || 'fr'; };

    function getPos(idx) {
      var d = ((idx - current) % total + total) % total;
      if (d > total / 2) d -= total;
      return d;
    }

    function loadSlide(idx) {
      if (loaded.has(idx)) return;
      var slide = document.querySelector('.gc-slide[data-index="' + idx + '"]');
      if (!slide) return;
      var img = slide.querySelector('.gc-img');
      if (!img) return;
      if (img.src && !img.src.endsWith('#')) { loaded.add(idx); slide.classList.add('loaded'); return; }
      var src = img.dataset.src;
      if (!src) return;
      var tmp = new Image();
      tmp.onload = function() {
        var source = slide.querySelector('source[data-srcset]');
        if (source) source.srcset = source.dataset.srcset;
        img.src = src;
        loaded.add(idx);
        slide.classList.add('loaded');
      };
      tmp.src = src;
    }

    function preloadNearby() {
      for (var i = -2; i <= 2; i++) loadSlide(((current + i) % total + total) % total);
    }
    function preloadAll() {
      var q = [], i;
      for (i = 0; i < total; i++) if (!loaded.has(i)) q.push(i);
      var idx = 0;
      function next() { if (idx < q.length) { loadSlide(q[idx++]); setTimeout(next, 80); } }
      next();
    }

    function render() {
      document.querySelectorAll('.gc-slide').forEach(function(slide) {
        var i = parseInt(slide.dataset.index, 10);
        var p = getPos(i);
        slide.dataset.pos = p <= -3 ? 'fl' : p >= 3 ? 'fr' : String(p);
      });
      var photo = photos[current];
      var lang  = getLang();
      var title = photo['title_' + lang]       || photo.title_fr       || '';
      var desc  = photo['description_' + lang] || photo.description_fr || '';
      var badge = photo.protocol || '';
      var infoEl = document.getElementById('gcInfo');
      if (infoEl) {
        infoEl.classList.add('fading');
        setTimeout(function() {
          var t = document.getElementById('gcTitle');
          var d = document.getElementById('gcDesc');
          var b = document.getElementById('gcBadge');
          var c = document.getElementById('gcCounter');
          if (t) t.textContent = title;
          if (d) d.textContent = desc;
          if (b) { b.textContent = badge; b.style.display = badge ? '' : 'none'; }
          if (c) c.textContent = (current + 1) + ' / ' + total;
          infoEl.classList.remove('fading');
        }, 180);
      }
      document.querySelectorAll('.gc-dot').forEach(function(dot, i) {
        dot.classList.toggle('gc-dot--active', i === current);
      });
    }

    function goTo(idx) {
      current = ((idx % total) + total) % total;
      render(); preloadNearby();
      if (navigator.vibrate) navigator.vibrate(8);
      scheduleResume();
    }
    function next() { goTo(current + 1); }
    function prev() { goTo(current - 1); }

    function startAuto() { if (autoTimer) clearInterval(autoTimer); autoTimer = setInterval(next, 2500); }
    function stopAuto()  { if (autoTimer) { clearInterval(autoTimer); autoTimer = null; } }
    function scheduleResume() {
      if (resumeTimer) clearTimeout(resumeTimer);
      resumeTimer = setTimeout(startAuto, 3000);
    }

    document.querySelectorAll('.gc-slide').forEach(function(slide) {
      slide.addEventListener('click', function() {
        var idx = parseInt(slide.dataset.index, 10);
        if (slide.dataset.pos === '0') openLightbox(idx);
        else { goTo(idx); stopAuto(); }
      });
    });

    var btnP = document.getElementById('gcPrev');
    var btnN = document.getElementById('gcNext');
    if (btnP) btnP.addEventListener('click', function() { prev(); stopAuto(); });
    if (btnN) btnN.addEventListener('click', function() { next(); stopAuto(); });

    document.querySelectorAll('.gc-dot').forEach(function(dot) {
      dot.addEventListener('click', function() { goTo(parseInt(dot.dataset.index, 10)); stopAuto(); });
    });

    var wrap = document.getElementById('gcWrap');
    if (wrap) {
      wrap.addEventListener('mouseenter', stopAuto);
      wrap.addEventListener('mouseleave', startAuto);
    }

    // Lightbox
    var lb = document.getElementById('gcLightbox');
    var lbImg = document.getElementById('gcLbImg');
    var lbIdx = 0;
    function openLightbox(idx) {
      if (!lb) return;
      lbIdx = idx; lbImg.src = photos[lbIdx].image; lbImg.alt = photos[lbIdx].title_fr || '';
      lb.classList.add('open'); document.body.style.overflow = 'hidden'; lbOpen = true;
    }
    function closeLightbox() {
      if (!lb) return;
      lb.classList.remove('open'); document.body.style.overflow = ''; lbOpen = false;
    }
    function lbNext() { lbIdx = (lbIdx + 1) % total; lbImg.src = photos[lbIdx].image; lbImg.alt = photos[lbIdx].title_fr || ''; }
    function lbPrev() { lbIdx = (lbIdx - 1 + total) % total; lbImg.src = photos[lbIdx].image; lbImg.alt = photos[lbIdx].title_fr || ''; }

    var lbClose = document.getElementById('gcLbClose');
    var lbP = document.getElementById('gcLbPrev');
    var lbN = document.getElementById('gcLbNext');
    if (lbClose) lbClose.addEventListener('click', closeLightbox);
    if (lbP) lbP.addEventListener('click', lbPrev);
    if (lbN) lbN.addEventListener('click', lbNext);
    if (lb) lb.addEventListener('click', function(e) { if (e.target === lb) closeLightbox(); });
    document.addEventListener('keydown', function(e) {
      if (!lbOpen) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight') lbNext();
      if (e.key === 'ArrowLeft') lbPrev();
    });

    // KQ CTA
    fetch('/.netlify/functions/settings?type=kinoquick')
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(kq) { if (kq && kq.enabled) { var b = document.getElementById('gcCtaReserver'); if (b) b.style.display = ''; } })
      .catch(function() {});

    window.addEventListener('zowe:langchange', render);
    preloadNearby(); render(); startAuto();
    setTimeout(preloadAll, 1200);
  })();
  </script>

  <!-- ════════════════════════════════
       JS MOBILE CAROUSEL
  ════════════════════════════════ -->
  <script is:inline define:vars={{ __photosM: photos }}>
  (function() {
    if (window.innerWidth > 768) return;

    var photos = __photosM;
    var total  = photos.length;
    if (!total) return;

    var mCur      = 0;
    var mAuto     = null;
    var mResume   = null;
    var isDrag    = false;
    var startX    = 0;
    var mLoaded   = new Set();

    var outer = document.getElementById('gcMOuter');
    var track = document.getElementById('gcMTrack');
    if (!outer || !track) return;

    var SW = window.innerWidth - 24; // slide width (12px peek each side)
    var lastHapticDist = 0;

    function mTX(idx) { return -(idx * SW); }

    function mSetTX(x, ease) {
      track.style.transition = ease
        ? 'transform .35s cubic-bezier(.25,.46,.45,.94)'
        : 'none';
      track.style.transform = 'translateZ(0) translateX(' + x + 'px)';
    }

    function mSetTXSpring(x) {
      track.style.transition = 'transform .4s cubic-bezier(.34,1.56,.64,1)';
      track.style.transform  = 'translateZ(0) translateX(' + x + 'px)';
    }

    /* ── Lazy loading ── */
    function mLoad(idx) {
      if (mLoaded.has(idx)) return;
      var sl = document.querySelector('.gc-m-slide[data-index="' + idx + '"]');
      if (!sl) return;
      var img = sl.querySelector('.gc-m-img');
      if (!img) return;
      if (img.src && img.src.length > 10 && !img.src.endsWith('#')) { mLoaded.add(idx); return; }
      var src = img.dataset.src;
      if (!src) return;
      var source = sl.querySelector('source[data-srcset]');
      if (source) source.srcset = source.dataset.srcset;
      img.src = src;
      mLoaded.add(idx);
    }
    function mLoadNearby(idx) {
      for (var i = -2; i <= 2; i++) mLoad(((idx + i) % total + total) % total);
    }

    /* ── Barre de progression dorée ── */
    function mUpdateProgress(idx) {
      var fill = document.getElementById('gcMProgFill');
      if (fill) fill.style.width = ((idx + 1) / total * 100) + '%';
    }

    /* ── Dots pill ── */
    function mUpdateDots(idx) {
      var MAX = 7, half = 3;
      var start = Math.max(0, Math.min(idx - half, total - MAX));
      var end   = Math.min(start + MAX - 1, total - 1);
      document.querySelectorAll('.gc-m-dot').forEach(function(dot, i) {
        var active  = i === idx;
        var visible = i >= start && i <= end;
        var edge    = visible && (i === start || i === end) && total > MAX;
        dot.classList.toggle('active', active);
        dot.style.width   = !visible ? '0' : active ? '20px' : edge ? '4px' : '6px';
        dot.style.opacity = !visible ? '0' : active ? '1' : edge ? '0.25' : '0.35';
        dot.style.margin  = !visible ? '0' : '';
      });
    }

    /* ── Slides active class ── */
    function mUpdateSlides(idx) {
      document.querySelectorAll('.gc-m-slide').forEach(function(sl) {
        sl.classList.toggle('active', parseInt(sl.dataset.index, 10) === idx);
      });
    }

    /* ── Compteur top-right ── */
    function mUpdateCounter(idx) {
      var el = document.getElementById('gcMCounterTop');
      if (el) el.textContent = (idx + 1 < 10 ? '0' : '') + (idx + 1) + ' / ' + total;
    }

    /* ── Navigation ── */
    function mGoTo(idx, anim) {
      var atEdge = (idx <= 0 && mCur === 0) || (idx >= total - 1 && mCur === total - 1);
      mCur = ((idx % total) + total) % total;
      if (anim === false) mSetTX(mTX(mCur), false);
      else mSetTX(mTX(mCur), true);
      mLoadNearby(mCur);
      mUpdateDots(mCur);
      mUpdateSlides(mCur);
      mUpdateCounter(mCur);
      mUpdateProgress(mCur);
      if (navigator.vibrate) {
        navigator.vibrate(atEdge ? [4, 30, 4] : 8);
      }
    }
    function mNext() { mGoTo(mCur + 1); }
    function mPrev() { mGoTo(mCur - 1); }

    function mStartAuto() { if (mAuto) clearInterval(mAuto); mAuto = setInterval(mNext, 2500); }
    function mStopAuto()  { if (mAuto) { clearInterval(mAuto); mAuto = null; } }
    function mScheduleResume() {
      mStopAuto();
      if (mResume) clearTimeout(mResume);
      mResume = setTimeout(mStartAuto, 3000);
    }

    /* ── Pointer Events swipe + rubber band ── */
    outer.addEventListener('pointerdown', function(e) {
      e.currentTarget.setPointerCapture(e.pointerId);
      startX  = e.clientX;
      isDrag  = true;
      lastHapticDist = 0;
      mStopAuto();
      mSetTX(mTX(mCur), false);
    }, { passive: true });

    outer.addEventListener('pointermove', function(e) {
      if (!isDrag) return;
      var raw = e.clientX - startX;

      // Rubber band aux extrémités (résistance 25%)
      var isFirst = mCur === 0 && raw > 0;
      var isLast  = mCur === total - 1 && raw < 0;
      var dx = (isFirst || isLast) ? raw * 0.25 : raw;

      mSetTX(mTX(mCur) + dx, false);

      // Haptic gradué toutes les 100px
      var dist = Math.abs(raw);
      if (dist > lastHapticDist + 100) {
        if (navigator.vibrate) navigator.vibrate(2);
        lastHapticDist = Math.floor(dist / 100) * 100;
      }
    }, { passive: true });

    outer.addEventListener('pointerup', function(e) {
      if (!isDrag) return;
      isDrag = false;
      var dx = startX - e.clientX;
      if (Math.abs(dx) > 50) {
        // Swipe
        dx > 0 ? mNext() : mPrev();
      } else {
        // Tap → navigation story gauche/droite
        var rect = outer.getBoundingClientRect();
        if (e.clientX - rect.left > rect.width / 2) mNext();
        else mPrev();
      }
      mScheduleResume();
    }, { passive: true });

    outer.addEventListener('pointercancel', function() {
      if (!isDrag) return;
      isDrag = false;
      mSetTXSpring(mTX(mCur));
      mScheduleResume();
    }, { passive: true });

    /* ── Dots clicks ── */
    document.querySelectorAll('.gc-m-dot').forEach(function(dot) {
      dot.addEventListener('click', function() {
        mGoTo(parseInt(dot.dataset.index, 10));
        mStopAuto(); mScheduleResume();
      });
    });

    /* ── KQ CTA ── */
    fetch('/.netlify/functions/settings?type=kinoquick')
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(kq) {
        if (kq && kq.enabled) { var b = document.getElementById('gcMCtaReserver'); if (b) b.style.display = ''; }
      }).catch(function() {});

    /* ── Bloquer le scroll natif de la page ── */
    document.addEventListener('touchmove', function(e) {
      if (!e.target.closest('#gcMOuter')) e.preventDefault();
    }, { passive: false });

    /* ── Init ── */
    mGoTo(0, false);
    mStartAuto();
    // Background load de toutes les photos
    setTimeout(function() {
      for (var i = 0; i < total; i++) {
        (function(idx) { setTimeout(function() { mLoad(idx); }, idx * 80); })(i);
      }
    }, 1500);
  })();
  </script>

  <!-- data-lang support -->
  <script is:inline>
  (function() {
    function applyLang(l) {
      document.querySelectorAll('[data-lang-fr]').forEach(function(el) {
        var v = el.getAttribute('data-lang-' + l) || el.getAttribute('data-lang-fr');
        if (v !== null) el.textContent = v;
      });
    }
    window.addEventListener('zowe:langchange', function(e) { applyLang(e.detail.lang); });
    applyLang(localStorage.getItem('zowe-lang') || 'fr');
  })();
  </script>

  <!-- theme-color bordeaux pour Safari + Android sur /galerie -->
  <script is:inline>
  (function() {
    var m = document.querySelector('meta[name="theme-color"]');
    if (m) m.setAttribute('content', '#1A0508');
  })();
  </script>

</Layout>
