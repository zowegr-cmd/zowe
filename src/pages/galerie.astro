        <p data-i18n="pages.gallery.empty">La galerie sera bientôt disponible.</p>
      </div>
    ) : (
      <>
        <!-- ═══ CAROUSEL ═══ -->
        <div class="gc-wrap" id="gcWrap">
          <div class="gc-track" id="gcTrack">

            {photos.map((photo, i) => (
              <div
                class="gc-slide"
                data-index={String(i)}
                data-pos={initialPos(i, photos.length)}
              >
                <img
                  src={i < EAGER ? photo.image : undefined}
                  data-src={photo.image}
                  alt={getAlt(photo, i)}
                  width="580"
                  height="680"
                  loading={i < EAGER ? 'eager' : 'lazy'}
                  decoding={i < EAGER ? 'sync' : 'async'}
                  class={i < EAGER ? 'gc-img loaded-img' : 'gc-img'}
                >
                <div class="gc-overlay"></div>
              </div>
            ))}

            <!-- Mobile overlay info -->
            <div class="gc-info-mobile" id="gcInfoMobile">
              <span class="gc-info-mobile__badge" id="gcMBadge" style="display:none"></span>
              <p class="gc-info-mobile__title" id="gcMTitle"></p>
              <p class="gc-info-mobile__desc"  id="gcMDesc"></p>
            </div>

          </div><!-- /track -->

          <button class="gc-arrow gc-arrow--prev" id="gcPrev" aria-label="Photo précédente">
            <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button class="gc-arrow gc-arrow--next" id="gcNext" aria-label="Photo suivante">
            <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div><!-- /wrap -->

        <!-- ═══ INFO PANEL desktop ═══ -->
        <div class="gc-info" id="gcInfo">
          <span class="gc-badge"      id="gcBadge"   style="display:none"></span>
          <p   class="gc-info__title" id="gcTitle"></p>
          <p   class="gc-info__desc"  id="gcDesc"></p>
          <p   class="gc-counter"     id="gcCounter">1 / {photos.length}</p>
        </div>

        <!-- ═══ DOTS ═══ -->
        <div class="gc-dots" id="gcDots">
          {photos.map((_, i) => (
            <button
              class={`gc-dot${i === 0 ? ' gc-dot--active' : ''}`}
              data-index={String(i)}
              aria-label={`Photo ${i + 1}`}
            ></button>
          ))}
        </div>

        <!-- ═══ CTA ═══ -->
        <section class="gc-cta">
          <h2 class="gc-cta__title">Prêt à vivre l'expérience ?</h2>
          <p class="gc-cta__sub">Chaque séance est unique, comme votre corps.</p>
          <div class="gc-cta__btns">
            <a href="/#contact" class="gc-cta-btn gc-cta-btn--solid">Initier mon accompagnement</a>
            <a href="/reserver" class="gc-cta-btn gc-cta-btn--outline" id="gcCtaReserver" style="display:none">Réserver un Bilan</a>
          </div>
        </section>

        <!-- ═══ LIGHTBOX ═══ -->
        <div class="gc-lightbox" id="gcLightbox" role="dialog" aria-modal="true" aria-label="Photo en plein écran">
          <img class="gc-lightbox__img" id="gcLbImg" src="" alt="">
          <button class="gc-lightbox__close" id="gcLbClose" aria-label="Fermer">×</button>
          <button class="gc-lightbox__prev" id="gcLbPrev" aria-label="Précédente">&#8249;</button>
          <button class="gc-lightbox__next" id="gcLbNext" aria-label="Suivante">&#8250;</button>
        </div>
      </>
    )}
  </div><!-- /page -->

  <script is:inline define:vars={{ __photos: photos }}>
  (function() {
    var photos  = __photos;
    var total   = photos.length;
    if (!total) return;

    var current    = 0;
    var autoTimer  = null;
    var resumeTimer= null;
    var txStart    = null;
    var lbOpen     = false;
    var loaded     = new Set();

    var MOB = function() { return window.innerWidth < 768; };
    var getLang = function() { return localStorage.getItem('zowe-lang') || 'fr'; };

    /* ── Position ── */
    function getPos(idx) {
      var d = ((idx - current) % total + total) % total;
      if (d > total / 2) d -= total;
      return d;
    }

    /* ── Lazy load ── */
    function loadSlide(idx) {
      if (loaded.has(idx)) return;
      var slide = document.querySelector('.gc-slide[data-index="' + idx + '"]');
      if (!slide) return;
      var img = slide.querySelector('.gc-img');
      if (!img) return;
      if (img.src && !img.src.endsWith('#')) { loaded.add(idx); slide.classList.add('loaded'); return; }
      var src = img.dataset.src;
      if (!src) return;
      var tmp = new Image();
      tmp.onload = function() {
        img.src = src;
        loaded.add(idx);
        slide.classList.add('loaded');
      };
      tmp.src = src;
    }

    function preloadNearby() {
      for (var i = -2; i <= 2; i++) {
        loadSlide(((current + i) % total + total) % total);
      }
    }

    function preloadAll() {
      var queue = [];
      for (var i = 0; i < total; i++) {
        if (!loaded.has(i)) queue.push(i);
      }
      var idx = 0;
      function next() {
        if (idx >= queue.length) return;
        loadSlide(queue[idx++]);
        setTimeout(next, 80);
      }
      next();
    }

    /* ── Render ── */
    function render() {
      /* Slide positions */
      document.querySelectorAll('.gc-slide').forEach(function(slide) {
        var i = parseInt(slide.dataset.index, 10);
        var p = getPos(i);
        slide.dataset.pos = p <= -3 ? 'fl' : p >= 3 ? 'fr' : String(p);
      });

      /* Info */
      var photo = photos[current];
      var lang  = getLang();
      var title = photo['title_' + lang]       || photo.title_fr       || '';
      var desc  = photo['description_' + lang] || photo.description_fr || '';
      var badge = photo.protocol || '';

      /* Desktop info */
      var infoEl = document.getElementById('gcInfo');
      if (infoEl) {
        infoEl.classList.add('fading');
        setTimeout(function() {
          var t = document.getElementById('gcTitle');
          var d = document.getElementById('gcDesc');
          var b = document.getElementById('gcBadge');
          var c = document.getElementById('gcCounter');
          if (t) t.textContent = title;
          if (d) d.textContent = desc;
          if (b) { b.textContent = badge; b.style.display = badge ? '' : 'none'; }
          if (c) c.textContent  = (current + 1) + ' / ' + total;
          infoEl.classList.remove('fading');
        }, 180);
      }

      /* Mobile overlay */
      var mobEl = document.getElementById('gcInfoMobile');
      if (mobEl) {
        mobEl.classList.add('fading');
        setTimeout(function() {
          var mt = document.getElementById('gcMTitle');
          var md = document.getElementById('gcMDesc');
          var mb = document.getElementById('gcMBadge');
          if (mt) mt.textContent = title;
          if (md) md.textContent = desc;
          if (mb) { mb.textContent = badge; mb.style.display = badge ? '' : 'none'; }
          mobEl.classList.remove('fading');
        }, 180);
      }

      /* Dots — window of max 8 on mobile */
      updateDots();
    }

    function updateDots() {
      var dots = document.querySelectorAll('.gc-dot');
      var MAX  = 8;
      if (!MOB() || total <= MAX) {
        dots.forEach(function(dot, i) {
          dot.classList.toggle('gc-dot--active', i === current);
          dot.style.display  = '';
          dot.style.opacity  = '';
        });
        return;
      }
      var half  = Math.floor(MAX / 2);
      var start = Math.max(0, Math.min(current - half, total - MAX));
      var end   = start + MAX - 1;
      dots.forEach(function(dot, i) {
        if (i < start || i > end) { dot.style.display = 'none'; return; }
        dot.style.display = '';
        dot.classList.toggle('gc-dot--active', i === current);
        var edge = Math.min(i - start, end - i);
        dot.style.opacity = edge === 0 ? '0.35' : '';
      });
    }

    /* ── Navigate ── */
    function goTo(idx, skipResume) {
      current = ((idx % total) + total) % total;
      render();
      preloadNearby();
      if (navigator.vibrate) navigator.vibrate(8);
      if (!skipResume) scheduleResume();
    }
    function next() { goTo(current + 1); }
    function prev() { goTo(current - 1); }

    /* ── Auto-play ── */
    function startAuto() {
      if (autoTimer) clearInterval(autoTimer);
      autoTimer = setInterval(next, 2500);
    }
    function stopAuto() {
      if (autoTimer) { clearInterval(autoTimer); autoTimer = null; }
    }
    function scheduleResume() {
      if (resumeTimer) clearTimeout(resumeTimer);
      resumeTimer = setTimeout(startAuto, 3000);
    }

    /* ── Slide clicks ── */
    document.querySelectorAll('.gc-slide').forEach(function(slide) {
      slide.addEventListener('click', function() {
        var idx = parseInt(slide.dataset.index, 10);
        if (slide.dataset.pos === '0') {
          if (!MOB()) openLightbox(idx);
        } else {
          goTo(idx);
          stopAuto();
        }
      });
    });

    /* ── Arrows ── */
    var btnP = document.getElementById('gcPrev');
    var btnN = document.getElementById('gcNext');
    if (btnP) btnP.addEventListener('click', function() { prev(); stopAuto(); });
    if (btnN) btnN.addEventListener('click', function() { next(); stopAuto(); });

    /* ── Dots ── */
    document.querySelectorAll('.gc-dot').forEach(function(dot) {
      dot.addEventListener('click', function() {
        goTo(parseInt(dot.dataset.index, 10));
        stopAuto();
      });
    });

    /* ── Hover pause ── */
    var wrap = document.getElementById('gcWrap');
    if (wrap) {
      wrap.addEventListener('mouseenter', stopAuto);
      wrap.addEventListener('mouseleave', startAuto);
    }

    /* ── Touch swipe ── */
    if (wrap) {
      wrap.addEventListener('touchstart', function(e) {
        txStart = e.touches[0].clientX;
        stopAuto();
      }, { passive: true });
      wrap.addEventListener('touchend', function(e) {
        if (txStart === null) return;
        var dx = e.changedTouches[0].clientX - txStart;
        txStart = null;
        if (Math.abs(dx) > 50) dx < 0 ? next() : prev();
      }, { passive: true });
    }

    /* ── Lightbox ── */
    var lb    = document.getElementById('gcLightbox');
    var lbImg = document.getElementById('gcLbImg');
    var lbIdx = 0;

    function openLightbox(idx) {
      if (!lb) return;
      lbIdx = idx;
      lbImg.src = photos[lbIdx].image;
      lbImg.alt = photos[lbIdx].title_fr || '';
      lb.classList.add('open');
      document.body.style.overflow = 'hidden';
      lbOpen = true;
    }
    function closeLightbox() {
      if (!lb) return;
      lb.classList.remove('open');
      document.body.style.overflow = '';
      lbOpen = false;
    }
    function lbNext() { lbIdx = (lbIdx + 1) % total; lbImg.src = photos[lbIdx].image; lbImg.alt = photos[lbIdx].title_fr || ''; }
    function lbPrev() { lbIdx = (lbIdx - 1 + total) % total; lbImg.src = photos[lbIdx].image; lbImg.alt = photos[lbIdx].title_fr || ''; }

    var lbClose = document.getElementById('gcLbClose');
    var lbP     = document.getElementById('gcLbPrev');
    var lbN     = document.getElementById('gcLbNext');
    if (lbClose) lbClose.addEventListener('click', closeLightbox);
    if (lbP)     lbP.addEventListener('click', lbPrev);
    if (lbN)     lbN.addEventListener('click', lbNext);
    if (lb) lb.addEventListener('click', function(e) { if (e.target === lb) closeLightbox(); });

    document.addEventListener('keydown', function(e) {
      if (!lbOpen) return;
      if (e.key === 'Escape')     closeLightbox();
      if (e.key === 'ArrowRight') lbNext();
      if (e.key === 'ArrowLeft')  lbPrev();
    });

    /* ── KinoQuick CTA button ── */
    fetch('/.netlify/functions/settings?type=kinoquick')
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(kq) {
        if (kq && kq.enabled) {
          var btn = document.getElementById('gcCtaReserver');
          if (btn) btn.style.display = '';
        }
      }).catch(function() {});

    /* ── Lang change ── */
    window.addEventListener('zowe:langchange', render);

    /* ── Init ── */
    preloadNearby();
    render();
    startAuto();
    // Background-load the rest after 1s
    setTimeout(preloadAll, 1200);

  })();
  </script>

  <script is:inline>
  (function() {
    var lang = localStorage.getItem('zowe-lang') || 'fr';
    function applyLang(l) {
      document.querySelectorAll('[data-lang-fr]').forEach(function(el) {
        var v = el.getAttribute('data-lang-' + l) || el.getAttribute('data-lang-fr');
        if (v !== null) el.textContent = v;
      });
    }
    window.addEventListener('zowe:langchange', function(e) { applyLang(e.detail.lang); });
    applyLang(lang);
  })();
  </script>

</Layout>
