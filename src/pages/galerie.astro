---
import Layout from '../layouts/Layout.astro';
import gallery from '../content/gallery.json';

if (!gallery.visible) {
  return Astro.redirect('/');
}
---
<Layout
  title="Galerie — Zowe · Kinésithérapie BELTRA"
  description="Découvrez l'expérience Zowe en images — cabinet, soins et protocoles BELTRA à Rhode-Saint-Genèse.">

  <style>
    .gallery-page {
      padding: 8rem 0 6rem;
    }
    .gallery-page .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
    .gallery-back {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--bordeaux); text-decoration: none; margin-bottom: 3rem;
      transition: opacity 0.2s;
    }
    .gallery-back:hover { opacity: 0.7; }
    .gallery-header { margin-bottom: 4rem; }
    .gallery-header h1 {
      font-family: var(--serif);
      font-size: clamp(2.5rem, 6vw, 4rem);
      font-weight: 300; font-style: italic;
      color: var(--bordeaux); line-height: 1.05;
      margin-bottom: 1rem;
    }
    .gallery-header p {
      font-family: var(--serif);
      font-size: 1.05rem; font-style: italic;
      color: var(--mid); max-width: 520px; line-height: 1.65;
    }
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    .gallery-card {
      position: relative;
      overflow: hidden;
      background: var(--cream);
      border: 1px solid var(--border);
    }
    .gallery-card img {
      width: 100%; aspect-ratio: 4/5;
      object-fit: cover; display: block;
      transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .gallery-card:hover img { transform: scale(1.04); }
    .gallery-card__overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(107,31,42,0.88) 0%, rgba(107,31,42,0.1) 55%, transparent 100%);
      opacity: 0; transition: opacity 0.35s ease;
      display: flex; flex-direction: column;
      justify-content: flex-end; padding: 1.75rem;
      gap: 0.5rem;
    }
    .gallery-card:hover .gallery-card__overlay { opacity: 1; }
    .gallery-card__badge {
      display: inline-block; align-self: flex-start;
      font-size: 0.58rem; font-weight: 600;
      letter-spacing: 0.15em; text-transform: uppercase;
      background: rgba(201,169,110,0.18);
      border: 1px solid rgba(201,169,110,0.45);
      color: var(--or);
      padding: 0.25rem 0.65rem;
      margin-bottom: 0.25rem;
    }
    .gallery-card__title {
      font-family: var(--serif);
      font-size: 1.2rem; font-style: italic;
      color: var(--off-white); line-height: 1.2;
    }
    .gallery-card__desc {
      font-size: 0.78rem; color: rgba(245,240,232,0.7);
      line-height: 1.6;
    }
    .gallery-card__share {
      position: absolute; top: 0.85rem; right: 0.85rem;
      width: 34px; height: 34px;
      background: rgba(15,15,15,0.5);
      border: 1px solid rgba(201,169,110,0.25);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; color: var(--or); opacity: 0;
      transition: opacity 0.25s ease;
      padding: 0;
    }
    .gallery-card:hover .gallery-card__share { opacity: 1; }
    .gallery-card__share svg { width: 14px; height: 14px; fill: currentColor; }
    .gallery-empty {
      grid-column: 1 / -1;
      text-align: center; padding: 5rem 2rem;
      font-family: var(--serif); font-size: 1.2rem;
      font-style: italic; color: var(--light);
    }
    @media (max-width: 860px) { .gallery-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 540px) { .gallery-grid { grid-template-columns: 1fr; } }
  </style>

  <div class="gallery-page">
    <div class="container">
      <a href="/" class="gallery-back" data-i18n="pages.back">← Retour à l'accueil</a>
      <div class="gallery-header">
        <h1 data-lang-fr={gallery.title_fr} data-lang-nl={gallery.title_nl || gallery.title_fr} data-lang-en={gallery.title_en || gallery.title_fr}>{gallery.title_fr}</h1>
        <p data-lang-fr={gallery.intro_fr} data-lang-nl={gallery.intro_nl || gallery.intro_fr} data-lang-en={gallery.intro_en || gallery.intro_fr}>{gallery.intro_fr}</p>
      </div>
      <div class="gallery-grid">
        {gallery.photos.length === 0 ? (
          <p class="gallery-empty" data-i18n="pages.gallery.empty">La galerie sera bientôt disponible.</p>
        ) : gallery.photos.map((photo, i) => (
          <div class="gallery-card"
               data-share-title={photo.title_fr}
               data-share-text={photo.description_fr}>
            <img
              src={photo.image}
              alt={photo.title_fr}
              loading="lazy"
              width="600" height="750">
            <div class="gallery-card__overlay">
              {photo.protocol && <span class="gallery-card__badge">{photo.protocol}</span>}
              <p class="gallery-card__title"
                 data-lang-fr={photo.title_fr}
                 data-lang-nl={photo.title_nl || photo.title_fr}
                 data-lang-en={photo.title_en || photo.title_fr}>{photo.title_fr}</p>
              <p class="gallery-card__desc"
                 data-lang-fr={photo.description_fr}
                 data-lang-nl={photo.description_nl || photo.description_fr}
                 data-lang-en={photo.description_en || photo.description_fr}>{photo.description_fr}</p>
            </div>
            <button class="gallery-card__share" aria-label="Partager" data-share>
              <svg viewBox="0 0 24 24"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92c0-1.61-1.31-2.92-2.92-2.92z"/></svg>
            </button>
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
// Traduction du contenu CMS multilingue (data-lang-*)
(function() {
  function applyDataLang(lang) {
    var attr = 'data-lang-' + (lang || 'fr');
    document.querySelectorAll('[data-lang-nl],[data-lang-en],[data-lang-fr]').forEach(function(el) {
      var val = el.getAttribute(attr) || el.getAttribute('data-lang-fr');
      if (val !== null) el.textContent = val;
    });
  }
  window.addEventListener('zowe:langchange', function(e) { applyDataLang(e.detail.lang); });
  applyDataLang(localStorage.getItem('zowe-lang') || 'fr');
})();

document.querySelectorAll('[data-share]').forEach(function(btn) {
  var card = btn.closest('[data-share-title]');
  if (!card) return;
  btn.addEventListener('click', function(e) {
    e.preventDefault();
    var title = card.dataset.shareTitle || 'Zowe — Kinésithérapie BELTRA';
    var url   = 'https://zowekine.com/galerie';
    if (navigator.share) {
      navigator.share({ title: title, url: url });
    } else {
      window.open('https://wa.me/?text=' + encodeURIComponent(title + ' — ' + url), '_blank');
    }
  });
});
</script>
