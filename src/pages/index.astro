---
import Layout from '../layouts/Layout.astro';
import hero         from '../content/hero.json';
import experience   from '../content/experience.json';
import about        from '../content/about.json';
import services     from '../content/services.json';
import testimonials from '../content/testimonials.json';
import faq          from '../content/faq.json';
import infos        from '../content/infos.json';
import contact      from '../content/contact.json';
import meta         from '../content/meta.json';

const formAction = `https://formspree.io/f/${contact.formspreeId}`;
// Duplicate testimonials for seamless carousel
const allTestimonials = [...testimonials.items, ...testimonials.items];
---

<Layout title={meta.siteTitle} description={meta.description}>

  <!-- Navigation -->
  <nav class="nav" id="nav">
    <a href="#hero" class="nav-logo">ZOWE</a>
    <ul class="nav-links" id="navLinks">
      <li><a href="#experience">Concept</a></li>
      <li><a href="#about">Approche</a></li>
      <li><a href="#services">Protocoles</a></li>
      <li><a href="#faq">FAQ</a></li>
      <li><a href="#contact" class="nav-cta">Initier mon accompagnement</a></li>
    </ul>
    <button class="nav-toggle" id="navToggle" aria-label="Ouvrir le menu">
      <span></span><span></span>
    </button>
  </nav>

  <!-- ① HERO -->
  <section id="hero" class="hero">
    <div class="hero-inner">
      <p class="hero-label">{hero.label}</p>
      <h1 class="hero-title">{hero.title}</h1>
      <p class="hero-tagline" set:html={hero.tagline.replace(/\n/g,'<br>')}></p>
      <a href="#contact" class="btn btn-primary">{hero.cta}</a>
    </div>
    <div class="hero-scroll" aria-hidden="true">&#8595;</div>
  </section>

  <!-- ② L'EXPÉRIENCE BELTRA -->
  <section id="experience" class="section experience">
    <div class="container">
      <div class="section-header" data-anim="up">
        <span class="section-number">01</span>
        <h2 class="section-title">{experience.title}</h2>
      </div>
      <p class="experience-subtitle" data-anim="up" data-delay="1">{experience.subtitle}</p>
      <p class="experience-intro" data-anim="up" data-delay="2">{experience.intro}</p>
      <div class="experience-blocks">
        {experience.blocks.map((block, i) => (
          <div class="experience-block" data-anim="up" data-delay={String(i + 1)}>
            <span class="experience-block__num">0{i + 1}</span>
            <h3>{block.title}</h3>
            <p>{block.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ③ QUI SUIS-JE -->
  <section id="about" class="section about">
    <div class="container">
      <div class="section-header" data-anim="up">
        <span class="section-number">02</span>
        <h2 class="section-title">{about.title}</h2>
      </div>
      <div class="about-grid">
        <div class="about-photo" data-anim="left">
          {about.image
            ? <img src={about.image} alt="Zoé — Kinésithérapeute BELTRA" loading="lazy">
            : <div class="about-photo__placeholder"><span>Photo professionnelle<br>à venir</span></div>
          }
        </div>
        <div class="about-content" data-anim="right">
          <p class="about-lead">{about.lead}</p>
          <p>{about.paragraph1}</p>
          <p>{about.paragraph2}</p>
          <p>{about.paragraph3}</p>
          <div class="about-signature">{about.signature}</div>
          <div class="about-formation">
            <p class="label">Formation</p>
            <p class="formation-school">{about.school}</p>
            <p class="formation-degree">{about.degree}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ④ PROTOCOLES & INVESTISSEMENTS -->
  <section id="services" class="section services">
    <div class="container">
      <div class="section-header" data-anim="up">
        <span class="section-number">03</span>
        <h2 class="section-title">{services.title}</h2>
      </div>
      <p class="services-intro" data-anim="up" data-delay="1">{services.intro}</p>
      <div class="beltra-grid">
        {services.tiers.map((tier, i) => (
          <div class={`beltra-card${i === 2 ? ' beltra-card--featured' : ''}`} data-anim="up" data-delay={String(i + 1)}>
            <div class="beltra-card__header">
              <div class="beltra-card__meta">
                <span class="beltra-card__duration">{tier.duration}</span>
                <span class="beltra-card__price">{tier.price}</span>
              </div>
              <h3 class="beltra-card__name">{tier.name}</h3>
              <p class="beltra-card__tagline">{tier.tagline}</p>
            </div>
            <div class="beltra-card__body">
              <p class="beltra-card__desc">{tier.description}</p>
              <div class="beltra-card__tools">
                <p class="beltra-label">Protocole</p>
                <ul>{tier.tools.map(t => <li>{t}</li>)}</ul>
              </div>
              <div class="beltra-card__ideal">
                <p class="beltra-label">Idéal pour</p>
                <p>{tier.ideal}</p>
              </div>
            </div>
            <a href="#contact" class={`btn ${i === 2 ? 'btn-light' : 'btn-primary'}`}>En savoir plus</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑤ TÉMOIGNAGES -->
  <section id="testimonials" class="section testimonials">
    <div class="container">
      <div class="section-header" data-anim="up">
        <span class="section-number">04</span>
        <h2 class="section-title">Témoignages</h2>
      </div>
    </div>
    <div class="testimonials-track-wrapper">
      <div class="testimonials-track" id="testimonialsTrack">
        {allTestimonials.map((t) => (
          <div class="testimonial-card">
            <div class="testimonial-stars">{'★'.repeat(t.rating)}</div>
            <p class="testimonial-text">"{t.text}"</p>
            <div class="testimonial-meta">
              <span class="testimonial-name">{t.name}</span>
              <span class="testimonial-date">{t.date}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑥ FAQ -->
  <section id="faq" class="section faq-section">
    <div class="container">
      <div class="section-header" data-anim="up">
        <span class="section-number">05</span>
        <h2 class="section-title">Questions fréquentes</h2>
      </div>
      <div class="faq-list">
        {faq.items.map((item, i) => (
          <details class="faq-item" id={`faq-${i}`} data-anim="up" data-delay={String(Math.min(i, 3))}>
            <summary class="faq-question">
              <span>{item.question}</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </summary>
            <p class="faq-answer">{item.answer}</p>
          </details>
        ))}
      </div>

      <div class="faq-map-card" data-anim="up">
        <div class="faq-map-card__map">
          <iframe
            src="https://maps.google.com/maps?q=Kinovea+Rhode-Saint-Genese+Belgium&t=&z=15&ie=UTF8&iwloc=&output=embed"
            width="100%" loading="lazy" style="border:0;"
            title="Localisation Kinovea Rhode-Saint-Genèse">
          </iframe>
        </div>
        <div class="faq-map-card__info">
          <p class="faq-map-label">Cabinet</p>
          <p class="faq-map-name">{infos.cabinet}</p>
          <p class="faq-map-detail">{infos.cabinetText}</p>
          <p class="faq-map-zones">{infos.zones}</p>
          <a
            href="https://maps.google.com/maps?q=Kinovea+Rhode-Saint-Genese+Belgium"
            target="_blank" rel="noopener"
            class="faq-map-link">
            Voir l'itinéraire →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ⑦ CONCIERGERIE -->
  <section id="contact" class="section contact">
    <div class="container">
      <div class="section-header" data-anim="up">
        <span class="section-number">06</span>
        <h2 class="section-title">Conciergerie</h2>
      </div>
      <p class="contact-intro" data-anim="up" data-delay="1">{contact.intro}</p>

      <div class="mf-wrapper" data-anim="up" data-delay="2">
        <div class="mf-progress">
          <div class="mf-progress__step active" data-step="1">
            <div class="mf-progress__dot"><span>1</span></div>
            <p>Identité</p>
          </div>
          <div class="mf-progress__line"></div>
          <div class="mf-progress__step" data-step="2">
            <div class="mf-progress__dot"><span>2</span></div>
            <p>Protocole</p>
          </div>
          <div class="mf-progress__line"></div>
          <div class="mf-progress__step" data-step="3">
            <div class="mf-progress__dot"><span>3</span></div>
            <p>Disponibilités</p>
          </div>
        </div>

        <form id="mainForm" action={formAction} method="POST">
          <input type="hidden" name="_subject" value="Nouvelle demande — Zowe BELTRA">
          <input type="text"   name="_gotcha"  style="display:none" tabindex="-1" autocomplete="off">
          <input type="hidden" name="soin_choisi" id="hiddenSoin">

          <!-- Étape 1 : Identité -->
          <div class="mf-panel" id="panel1">
            <div class="form-row">
              <div class="form-group">
                <label for="prenom">Prénom *</label>
                <input type="text" id="prenom" name="prenom" autocomplete="given-name" placeholder="Votre prénom">
              </div>
              <div class="form-group">
                <label for="nom">Nom *</label>
                <input type="text" id="nom" name="nom" autocomplete="family-name" placeholder="Votre nom">
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="email">Email *</label>
                <input type="email" id="email" name="email" autocomplete="email" placeholder="votre@email.com">
              </div>
              <div class="form-group">
                <label for="telephone">GSM</label>
                <input type="tel" id="telephone" name="telephone" autocomplete="tel" placeholder="0470 00 00 00">
              </div>
            </div>
            <div class="form-group">
              <label for="message">Votre situation</label>
              <textarea id="message" name="message" rows="3" placeholder="Décrivez brièvement vos douleurs, objectifs ou questions…"></textarea>
            </div>
            <div class="mf-nav mf-nav--right">
              <button type="button" class="btn btn-primary" id="toStep2">Continuer <span>→</span></button>
            </div>
          </div>

          <!-- Étape 2 : Sélection du protocole -->
          <div class="mf-panel mf-panel--hidden" id="panel2">
            <div class="soin-cards">
              {services.tiers.map((tier, i) => (
                <div class={`soin-card${i === 2 ? ' soin-card--premium' : ''}`} data-soin={`${tier.name} — ${tier.duration} — ${tier.price}`}>
                  <div class="soin-card__top">
                    <span class="soin-card__duration">{tier.duration}</span>
                    <span class="soin-card__price">{tier.price}</span>
                  </div>
                  <h3>{tier.name}</h3>
                  <p>{tier.description}</p>
                  <div class="soin-card__check">✓</div>
                </div>
              ))}
            </div>
            <div class="mf-nav">
              <button type="button" class="mf-back" id="toStep1">← Retour</button>
              <button type="button" class="btn btn-primary" id="toStep3">Continuer <span>→</span></button>
            </div>
          </div>

          <!-- Étape 3 : Disponibilités -->
          <div class="mf-panel mf-panel--hidden" id="panel3">
            <div class="form-group">
              <label for="disponibilites">Vos disponibilités préférées</label>
              <textarea id="disponibilites" name="disponibilites" rows="4" placeholder="Ex : lundi matin, jeudi après-midi, en semaine uniquement…"></textarea>
            </div>
            <p class="mf-note">Zoé vous contactera dans les 24h pour convenir ensemble d'un moment qui vous correspond.</p>
            <div class="mf-nav">
              <button type="button" class="mf-back" id="toStep2b">← Retour</button>
              <button type="submit" class="btn btn-primary">Écrire à Zoé</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- ⑧ FOOTER -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <p class="footer-logo">ZOWE</p>
          <p class="footer-tagline">Kinésithérapie de haute précision<br>Méthode BELTRA</p>
        </div>
        <div class="footer-col">
          <p class="footer-col__title">Cabinet</p>
          <p>{infos.cabinet}</p>
          <p>{infos.cabinetText}</p>
          <p class="footer-zones">{infos.zones}</p>
        </div>
        <div class="footer-col">
          <p class="footer-col__title">Contact</p>
          <p><a href={`tel:${infos.phone.replace(/\s/g,'')}`}>{infos.phone}</a></p>
          <p><a href={`mailto:${infos.email}`}>{infos.email}</a></p>
          <p class="footer-tarif">{infos.tarifsTitle}</p>
        </div>
        <div class="footer-col">
          <p class="footer-col__title">Mentions légales</p>
          <p>N° d'entreprise : <em>à compléter</em></p>
          <p>Assurance RC Pro : <em>à compléter</em></p>
          <p>Visa INAMI : <em>à compléter</em></p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {meta.copyright} Zowe — Zoé Grêde. Tous droits réservés.</p>
      </div>
    </div>
  </footer>

  <!-- Bouton sticky mobile -->
  <a href="#contact" class="sticky-cta" id="stickyCta" aria-label="Initier mon accompagnement">
    Initier mon accompagnement
  </a>

</Layout>

<script is:inline>
(function () {
  /* ── Formulaire multi-étapes ── */
  var selSoin = '';

  function showPanel(n) {
    for (var i = 1; i <= 3; i++) {
      var p = document.getElementById('panel' + i);
      if (p) p.classList.toggle('mf-panel--hidden', i !== n);
    }
    document.querySelectorAll('.mf-progress__step').forEach(function(el) {
      var s = parseInt(el.dataset.step);
      el.classList.toggle('active', s === n);
      el.classList.toggle('done', s < n);
    });
  }

  var b12 = document.getElementById('toStep2');
  if (b12) b12.addEventListener('click', function () {
    var p = document.getElementById('prenom').value.trim();
    var e = document.getElementById('email').value.trim();
    if (!p || !e) { alert('Veuillez renseigner votre prénom et votre email.'); return; }
    showPanel(2);
  });
  var b21 = document.getElementById('toStep1');
  if (b21) b21.addEventListener('click', function () { showPanel(1); });
  var b23 = document.getElementById('toStep3');
  if (b23) b23.addEventListener('click', function () {
    if (!selSoin) { alert('Veuillez sélectionner un protocole.'); return; }
    showPanel(3);
  });
  var b32 = document.getElementById('toStep2b');
  if (b32) b32.addEventListener('click', function () { showPanel(2); });

  document.querySelectorAll('.soin-card').forEach(function (c) {
    c.addEventListener('click', function () {
      document.querySelectorAll('.soin-card').forEach(function(x){ x.classList.remove('selected'); });
      this.classList.add('selected');
      selSoin = this.dataset.soin;
      document.getElementById('hiddenSoin').value = selSoin;
    });
  });

  /* ── AJAX submit → /merci/ ── */
  (function () {
    function attach() {
      var form = document.getElementById('mainForm');
      if (!form) return;
      form.addEventListener('submit', function (e) {
        e.preventDefault(); e.stopPropagation();
        if (!selSoin) { alert('Veuillez sélectionner un protocole.'); showPanel(2); return; }
        var btn = form.querySelector('button[type="submit"]');
        if (btn) { btn.textContent = 'Envoi en cours…'; btn.disabled = true; }
        fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { 'Accept': 'application/json' }
        }).then(function(r){
          if (r.ok) { window.location.href = '/merci/'; }
          else {
            r.json().then(function(d){ alert('Erreur : '+(d.error||'Veuillez réessayer.')); })
             .catch(function(){ alert('Erreur. Veuillez réessayer.'); });
            if(btn){ btn.textContent='Écrire à Zoé'; btn.disabled=false; }
          }
        }).catch(function(){
          alert('Erreur réseau. Veuillez réessayer.');
          if(btn){ btn.textContent='Écrire à Zoé'; btn.disabled=false; }
        });
      });
    }
    document.readyState==='loading' ? document.addEventListener('DOMContentLoaded',attach) : attach();
  })();

  /* ── FAQ accordion icon ── */
  document.querySelectorAll('.faq-item').forEach(function(d){
    d.addEventListener('toggle', function(){
      var icon = this.querySelector('.faq-icon');
      if(icon) icon.textContent = this.open ? '−' : '+';
    });
  });

  /* ── Sticky CTA : masquer quand on est dans la section contact ── */
  var stickyCta = document.getElementById('stickyCta');
  var contactSection = document.getElementById('contact');
  if (stickyCta && contactSection) {
    var stickyObs = new IntersectionObserver(function(entries) {
      stickyCta.classList.toggle('sticky-cta--hidden', entries[0].isIntersecting);
    }, { threshold: 0.15 });
    stickyObs.observe(contactSection);
  }

})();
</script>
