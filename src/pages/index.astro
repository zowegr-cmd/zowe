            <circle cx="26" cy="26" r="23" fill="none" stroke="#C9A96E" stroke-width="1.5"/>
            <path class="form-success__tick" fill="none" stroke="#C9A96E" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round" d="M 14,26 L 22,34 L 38,18"/>
          </svg>
          <p data-i18n="form.success_msg">Votre demande est en route. Zoé revient vers vous bientôt.</p>
        </div>
      </div>
    </div>
  </section>

