                  </span>
                  <span class="cm-social-label">Instagram</span>
                </a>
                <a href={`mailto:${infos.email}`} class="cm-social-btn" aria-label="Email">
                  <span class="cm-social-icon">
                    <svg viewBox="0 0 24 24" width="24" height="24" fill="#6B1F2A"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
