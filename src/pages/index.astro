  /* ── Haptic feedback — CTA principaux ── */
  // Sticky CTA + nav CTA
  document.querySelectorAll('.sticky-cta, .nav-cta').forEach(function(el) {
    el.addEventListener('click', function() { window.hapticFeedback('medium'); });
  });
  // WhatsApp (tous liens wa.me)
  document.querySelectorAll('a[href*="wa.me"]').forEach(function(a) {
    a.addEventListener('click', function() { window.hapticFeedback('medium'); });
  });
  // Bouton itinéraire
  var dirBtn = document.querySelector('.localisation-cta');
  if (dirBtn) dirBtn.addEventListener('click', function() { window.hapticFeedback('medium'); });

  /* ── Tracking analytics ── */
  function track(evt) {
    fetch('/.netlify/functions/track', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ event: evt })
    }).catch(function(){});
  }
  // Clics WhatsApp (tous les liens wa.me)
  document.querySelectorAll('a[href*="wa.me"]').forEach(function(a) {
    a.addEventListener('click', function() { track('wa_click'); if(typeof gtag!=='undefined') gtag('event','cta_click',{cta_type:'whatsapp'}); });
  });
  // Clics Instagram
  document.querySelectorAll('a[href*="instagram.com"]').forEach(function(a) {
    a.addEventListener('click', function() { track('ig_click'); if(typeof gtag!=='undefined') gtag('event','cta_click',{cta_type:'instagram'}); });
  });
  // Bouton itinéraire
  var _dirBtn = document.querySelector('.localisation-cta');
  if (_dirBtn) _dirBtn.addEventListener('click', function() { track('cta_itinerary'); if(typeof gtag!=='undefined') gtag('event','cta_click',{cta_type:'itinerary'}); });
  // Langue sélectionnée
  window.addEventListener('zowe:langchange', function(e) {
    var lang = e.detail && e.detail.lang;
    if (lang) {
      track('lang_' + lang);
      if (typeof gtag !== 'undefined') gtag('event', 'language_used', { language: lang });
    }
  });

  /* ── Boutons partage (Web Share API) ── */
  document.querySelectorAll('[data-share]').forEach(function(btn) {
    var card = btn.closest('[data-share-title]');
    if (!card) return;
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      var title = card.dataset.shareTitle || 'Zowe — Kinésithérapie BELTRA';
      var text  = card.dataset.shareText  || 'Découvrez les protocoles Zowe.';
      var url   = window.location.origin + '/#services';
      if (navigator.share) {
        navigator.share({ title: title, text: text + ' — ' + title, url: url });
      } else {
        var wa = 'https://wa.me/?text=' + encodeURIComponent(title + ' — ' + url);
        window.open(wa, '_blank');
      }
    });
  });

  /* ── Sticky CTA : caché sur le hero et la section contact ── */
  var stickyCta     = document.getElementById('stickyCta');
  var heroSection   = document.getElementById('hero');
  var contactSection = document.getElementById('contact');
  if (stickyCta) {
    var _heroVisible    = true;  // caché par défaut (on commence sur le hero)
    var _contactVisible = false;
    function _updateSticky() {
      var hidden = _heroVisible || _contactVisible;
      stickyCta.classList.toggle('sticky-cta--hidden', hidden);
      stickyCta.style.display    = hidden ? 'none' : '';
      stickyCta.style.background = hidden ? 'transparent' : '';
    }
    if (heroSection) {
      new IntersectionObserver(function(e) {
        _heroVisible = e[0].isIntersecting;
        _updateSticky();
      }, { threshold: 0.1 }).observe(heroSection);
    }
    if (contactSection) {
      new IntersectionObserver(function(e) {
        _contactVisible = e[0].isIntersecting;
        _updateSticky();
      }, { threshold: 0.15 }).observe(contactSection);
    }
    _updateSticky();
  }

})();

  /* ── KinoQuick — activation côté client ── */
  (function() {
    fetch('/.netlify/functions/settings?type=kinoquick')
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(kq) {
        if (!kq || !kq.enabled || !kq.url) return;
        var lang = localStorage.getItem('zowe-lang') || 'fr';
        function g(field) { return kq[field] && (kq[field][lang] || kq[field]['fr']) || ''; }

        function trackKq(source) {
          if (typeof gtag === 'function') gtag('event', 'kinoquick_click', { source: source });
        }

        // Hero
        var heroLink = document.getElementById('kqHeroLink');
        if (heroLink) {
          heroLink.style.display = '';
          heroLink.addEventListener('click', function() { trackKq('hero'); });
        }

        // Nav desktop
        var navBtn = document.getElementById('kqNavBtn');
        if (navBtn) {
          navBtn.style.display = '';
          navBtn.addEventListener('click', function() { trackKq('nav'); });
        }

        // Menu mobile
        var menuBtn = document.getElementById('kqMenuBtn');
        var menuLink = document.getElementById('kqMenuLink');
        if (menuBtn && menuLink) {
          menuLink.textContent = g('button_text');
          menuBtn.style.display = '';
          menuLink.addEventListener('click', function() { trackKq('menu'); });
        }

        // Liens discrets protocoles
        document.querySelectorAll('.kq-card-link').forEach(function(lnk) {
          lnk.style.display = '';
          lnk.addEventListener('click', function() { trackKq('protocoles'); });
        });

        // Section contact — layout 2 chemins
        var col  = document.getElementById('kqColumn');
        var sep  = document.getElementById('kqSep');
        var wrap = document.getElementById('kqContactWrap');
        if (col) {
          var ge = function(id) { return document.getElementById(id); };
          var badge = ge('kqBadge');      if (badge) badge.textContent = g('badge');
          var titre = ge('kqTitre');      if (titre) titre.textContent = g('titre');
          var desc  = ge('kqDesc');       if (desc)  desc.textContent  = g('description');
          var det   = ge('kqDetail');     if (det)   det.textContent   = g('detail');
          var sepTx = ge('kqSepText');    if (sepTx) sepTx.textContent = g('separateur');
          var btn   = ge('kqContactBtn');
          if (btn) {
            btn.textContent = g('btn');
            btn.addEventListener('click', function() { trackKq('contact'); });
          }
          // Afficher éléments KinoQuick
          col.style.display = '';
          if (sep) sep.style.display = '';
          // Activer la grille 2 colonnes
          if (wrap) wrap.classList.add('kq-active');
          // Sous-titre
          var sub = document.getElementById('kqSubtitle');
          if (sub) sub.style.display = '';
          // Masquer icônes contact (remplacées par les colonnes)
          var meta = document.getElementById('contactMeta');
          if (meta) meta.style.display = 'none';
          // Titres colonne formulaire
          var ft = ge('kqFormTitle'); if (ft) ft.style.display = '';
          var fd = ge('kqFormDesc');  if (fd) fd.style.display = '';
        }

        // FAB
        var fabItem = document.getElementById('kqFabItem');
        var fabBtn  = document.getElementById('kqFabBtn');
        var fabTip  = document.getElementById('kqFabTooltip');
        if (fabItem && fabBtn) {
          if (fabTip) fabTip.textContent = g('btn');
          fabItem.style.display = '';
          fabBtn.addEventListener('click', function() { trackKq('fab'); });
          // Stagger : KinoQuick visible = 6 items actifs
          var container = document.getElementById('fabContainer');
          if (container) container.classList.add('kq-fab-active');
        }
      })
      .catch(function() {});
  })();
</script>

