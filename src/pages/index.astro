<!-- theme-color + safe-area-top dynamiques — mobile uniquement -->
<script is:inline>
(function() {
  if (window.innerWidth > 768) return;

  /* En PWA standalone, le hero remplit tout l'écran — pas besoin des barres */
  var isPWA = window.matchMedia('(display-mode: standalone)').matches;

  /* ── Injecter les styles des barres safe-area en JS pur (bypass cache CSS) ── */
  var s = document.createElement('style');
  var barCSS = isPWA ? '' : [
    '#homeTopBar{display:block !important;position:fixed;top:-30px;left:0;right:0;',
    'height:calc(env(safe-area-inset-top,50px) + 30px);background-color:#120305;',
    'z-index:9999;pointer-events:none;transition:background-color .3s ease;}',
    '#homeBottomBar{display:block !important;position:fixed;bottom:0;left:0;right:0;',
    'height:env(safe-area-inset-bottom,0px);background-color:#120305;',
    'z-index:5;pointer-events:none;transition:background-color .3s ease;}'
  ].join('');
  s.textContent = barCSS + 'body.is-home .sticky-cta-hidden-home{display:none !important;}';
  document.head.appendChild(s);
  document.body.classList.add('is-home');

  var sections = [
    { selector: '.hero',     color: '#120305' },
    { selector: '#about',    color: '#F5F0E8' },
    { selector: '#services', color: '#F5F0E8' },
    { selector: '#faq',      color: '#F5F0E8' },
    { selector: '#contact',  color: '#F5F0E8' },
    { selector: 'footer',    color: '#0F0F0F' }
  ];

  var topBar    = document.getElementById('homeTopBar');
  var bottomBar = document.getElementById('homeBottomBar');

  function updateThemeColor(color) {
    var m = document.querySelector('meta[name="theme-color"]');
    if (m) m.setAttribute('content', color);
    if (topBar)    topBar.style.backgroundColor    = color;
    if (bottomBar) bottomBar.style.backgroundColor = color;
  }

  function getCurrentColor() {
    var scrollY = window.scrollY;
    for (var i = 0; i < sections.length; i++) {
      var s = sections[i];
      var el = document.querySelector(s.selector);
      if (!el) continue;
      var top = el.offsetTop - 10;
      var bottom = top + el.offsetHeight;
      if (scrollY >= top && scrollY < bottom) return s.color;
    }
    return '#120305';
  }

  var ticking = false;
  window.addEventListener('scroll', function() {
    if (!ticking) {
      requestAnimationFrame(function() {
        updateThemeColor(getCurrentColor());
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });

  updateThemeColor(getCurrentColor());
})();
</script>

