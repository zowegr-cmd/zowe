<script is:inline define:vars={{ mapboxToken, mapLng, mapLat }}>
(function () {

  /* ── Formulaire ── */
  (function() {
    var form        = document.getElementById('mainForm');
    if (!form) return;
    var btn         = document.getElementById('submitBtn');
    var btnText     = document.getElementById('submitBtnText');
    var spinner     = document.getElementById('btnSpinner');
    var formError   = document.getElementById('formError');
    var formErrorMsg= document.getElementById('formErrorMsg');
    var formSuccess = document.getElementById('formSuccess');
    var isSubmitting= false;

    /* Validation email */
    var EMAIL_RE = /^[^\s@]{1,64}@[^\s@]{1,255}\.[^\s@]{2,}$/;
    function validateEmailField(el) {
      var val = (el.value || '').trim();
      var hint = el.parentElement.querySelector('.field-hint');
      if (!val) {
        el.classList.remove('field-valid','field-error');
        if (hint) hint.classList.remove('is-visible');
        return;
      }
      var ok = EMAIL_RE.test(val);
      el.classList.toggle('field-valid', ok);
      el.classList.toggle('field-error', !ok);
      if (hint) hint.classList.toggle('is-visible', !ok);
    }
    var emailEl = document.getElementById('email');
    if (emailEl) {
      var hint = document.createElement('span');
      hint.className = 'field-hint';
      hint.setAttribute('data-i18n', 'form.hint_email');
      hint.textContent = 'Vérifiez le format de votre email';
      emailEl.parentElement.appendChild(hint);
      emailEl.addEventListener('blur',  function(){ validateEmailField(this); });
      emailEl.addEventListener('input', function(){ if (this.classList.contains('field-error')) validateEmailField(this); });
    }
    /* Validation champs requis au blur */
    ['prenom','telephone','message'].forEach(function(id){
      var el = document.getElementById(id);
      if (!el) return;
      el.addEventListener('blur', function(){
        if (this.value.trim()) { this.classList.remove('field-error'); this.classList.add('field-valid'); }
        else                   { this.classList.remove('field-valid'); this.classList.add('field-error'); }
      });
      el.addEventListener('input', function(){
        if (this.value.trim()) { this.classList.remove('field-error'); }
      });
    });

    /* État chargement */
    function setLoading(on) {
      form.querySelectorAll('input,textarea,button').forEach(function(f){ f.disabled = on; });
      if (spinner) spinner.style.display = on ? '' : 'none';
      if (btn) { btn.style.opacity = on ? '0.82' : ''; btn.style.pointerEvents = on ? 'none' : ''; }
      if (btnText) btnText.textContent = on
        ? ((window.__t && window.__t('form.sending')) || 'Envoi en cours…')
        : ((window.__t && window.__t('form.submit'))  || 'Écrire à Zoé');
    }

    /* Afficher erreur */
    function showError(msg) {
      if (formErrorMsg) formErrorMsg.textContent = msg ||
        (window.__t && window.__t('form.error_network')) ||
        'Un instant — la connexion semble lente. Réessayez ou contactez Zoé directement au 0471 78 37 46.';
      if (formError) formError.hidden = false;
    }

    /* Afficher succès puis rediriger */
    function showSuccess() {
      form.style.transition = 'opacity 0.35s';
      form.style.opacity    = '0';
      form.style.pointerEvents = 'none';
      if (formSuccess) {
        formSuccess.hidden = false;
        requestAnimationFrame(function(){
          requestAnimationFrame(function(){ formSuccess.classList.add('is-visible'); });
        });
      }
      setTimeout(function(){ window.location.href = '/merci/'; }, 2000);
    }

    /* Soumission */
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      if (isSubmitting) return;
      if (formError) formError.hidden = true;

      var prenom = (document.getElementById('prenom')    ||{}).value || '';
      var email  = (document.getElementById('email')     ||{}).value || '';
      var tel    = (document.getElementById('telephone') ||{}).value || '';

      if (!prenom.trim() || !email.trim() || !tel.trim()) {
        ['prenom','email','telephone'].forEach(function(id){
          var el = document.getElementById(id);
          if (el && !el.value.trim()) el.classList.add('field-error');
        });
        showError((window.__t && window.__t('form.error_required')) ||
          'Veuillez renseigner votre prénom, email et numéro de téléphone.');
        return;
      }

      window.hapticFeedback('medium');
      isSubmitting = true;
      setLoading(true);

      fetch('/.netlify/functions/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          prenom:    prenom.trim(),
          nom:       ((document.getElementById('nom')     ||{}).value||'').trim(),
          email:     email.trim(),
          telephone: tel.trim(),
          message:   ((document.getElementById('message') ||{}).value||'').trim(),
          newsletter: document.getElementById('newsletter')
            ? document.getElementById('newsletter').checked : false,
          website:   (document.getElementById('website_hp')||{}).value||'',
          recaptchaToken: window._recaptchaToken || '',
          lang:      localStorage.getItem('zowe-lang') || 'fr',
        }),
      }).then(function(r) {
        if (r.ok) {
          window.hapticFeedback('success');
          showSuccess();
        } else {
          r.json().then(function(d){ showError(d.error); }).catch(function(){ showError(); });
          setLoading(false); isSubmitting = false;
        }
      }).catch(function() {
        showError((window.__t && window.__t('form.error_network')) ||
          'Un instant — la connexion semble lente. Réessayez ou contactez Zoé directement au 0471 78 37 46.');
        setLoading(false); isSubmitting = false;
      });
    });
  })();

  /* ── Skeleton map — fade-out quand l'iframe est chargée ── */
  (function() {
    var skeleton = document.getElementById('mapSkeleton');
    var iframe   = document.getElementById('mapIframe');
    if (!skeleton) return;
    function hideSkeleton() {
      skeleton.classList.add('skeleton-map--hidden');
      setTimeout(function() { skeleton.style.display = 'none'; }, 420);
    }
    if (iframe) iframe.addEventListener('load', hideSkeleton);
    setTimeout(hideSkeleton, 5000); // fallback 5s
  })();

  /* ── Skeleton reviews — révèle le vrai track ── */
  window._revealReviews = function() {
    var skTrack = document.getElementById('testimonialsSkeletonTrack');
    var realTrack = document.getElementById('testimonialsTrack');
    if (!skTrack || !realTrack) return;
    skTrack.style.transition = 'opacity 0.35s';
    skTrack.style.opacity = '0';
    setTimeout(function() {
      skTrack.style.display = 'none';
      realTrack.style.display = '';
      if (window._carouselReload) window._carouselReload();
    }, 360);
  };
  // Fallback 5s : si l'API ne répond pas, afficher les avis statiques
  setTimeout(function() {
    var skTrack = document.getElementById('testimonialsSkeletonTrack');
    if (skTrack && skTrack.style.display !== 'none') window._revealReviews();
  }, 5000);

  /* ── Carrousel témoignages — moteur JS (auto-scroll + nav manuelle + swipe) ── */
  (function() {
    var track   = document.getElementById('testimonialsTrack');
    var wrapper = track && track.parentElement;
    if (!track || !wrapper) return;

    var pos       = 0;      // position courante en px
    var paused    = false;  // pause hover/interaction
    var pauseTimer= null;
    var halfWidth = 0;
    var SPEED     = 0.45;   // px/frame (~27px/s à 60fps)
    var GAP       = 24;     // gap CSS en px

    function calcHalf() {
      halfWidth = track.scrollWidth / 2;
      // Si pos est hors limites après recalcul (remplacement dynamique des cartes), on recadre
      if (halfWidth > 0 && pos >= halfWidth) pos = pos % halfWidth;
    }
    function cardStep() {
      var c = track.querySelector('.testimonial-card');
      return c ? c.offsetWidth + GAP : 340;
    }

    // Boucle rAF principale
    function tick() {
      if (!paused) {
        pos += SPEED;
        if (pos >= halfWidth) pos -= halfWidth;
        track.style.transform = 'translateX(-' + pos + 'px)';
      }
      requestAnimationFrame(tick);
    }

    function pauseFor(ms) {
      paused = true;
      clearTimeout(pauseTimer);
      pauseTimer = setTimeout(function() { paused = false; }, ms);
    }

    // Pause au hover (desktop)
    wrapper.addEventListener('mouseenter', function() { paused = true; });
    wrapper.addEventListener('mouseleave', function() {
      if (!pauseTimer) paused = false;
    });

    // Navigation manuelle (prev / next) — snap sur bord de carte
    function navigate(dir) {
      var step = cardStep();
      // Aligner d'abord sur le bord le plus proche, puis avancer d'un cran
      var snapped = Math.round(pos / step) * step;
      var dest    = snapped + step * dir;
      if (dest >= halfWidth) dest -= halfWidth;
      if (dest < 0)          dest += halfWidth;
      track.style.transition = 'transform 0.38s ease';
      pos = dest;
      track.style.transform  = 'translateX(-' + pos + 'px)';
      setTimeout(function() { track.style.transition = ''; }, 380);
      pauseFor(3000);
    }

    var prevBtn = document.getElementById('testimonialsPrev');
    var nextBtn = document.getElementById('testimonialsNext');
    if (prevBtn) prevBtn.addEventListener('click', function() { navigate(-1); });
    if (nextBtn) nextBtn.addEventListener('click', function() { navigate(1); });

    // Swipe tactile
    var txStart = null, posStart = 0;
    wrapper.addEventListener('touchstart', function(e) {
      txStart  = e.touches[0].clientX;
      posStart = pos;
      paused   = true;
    }, { passive: true });
    wrapper.addEventListener('touchmove', function(e) {
      if (txStart === null) return;
      var dx = txStart - e.touches[0].clientX;
      pos = posStart + dx;
      if (pos >= halfWidth) pos -= halfWidth;
      if (pos < 0)          pos += halfWidth;
      track.style.transform = 'translateX(-' + pos + 'px)';
    }, { passive: true });
    wrapper.addEventListener('touchend', function() {
      txStart = null;
      pauseFor(3000);
    });

    calcHalf();
    tick();

    // Recalcule après chargement dynamique (Google Reviews)
    window._carouselReload = function() { setTimeout(calcHalf, 250); };
  })();

  /* ── Google Reviews dynamiques ── */
  (function loadReviews() {
    var track = document.getElementById('testimonialsTrack');
    if (!track) return;
    function escHtml(s) {
      return String(s).replace(/[&<>"']/g, function(c) {
        return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
      });
    }
    fetch('/.netlify/functions/reviews')
      .then(function(r){ return r.ok ? r.json() : null; })
      .then(function(reviews) {
        if (reviews && reviews.length >= 2) {
          reviews.sort(function(a, b) {
            return (/beltra/i.test(b.text) ? 1 : 0) - (/beltra/i.test(a.text) ? 1 : 0);
          });
          var doubled = reviews.concat(reviews);
          track.innerHTML = doubled.map(function(t) {
            return '<div class="testimonial-card">'
              + '<div class="testimonial-stars">' + '★'.repeat(t.rating) + '</div>'
              + '<p class="testimonial-text">&ldquo;' + escHtml(t.text) + '&rdquo;</p>'
              + '<div class="testimonial-meta">'
              + '<span class="testimonial-name">' + escHtml(t.name) + '</span>'
              + '</div></div>';
          }).join('');
        }
        window._revealReviews();
      })
      .catch(function(){ window._revealReviews(); });
  })();

  /* ── Mapbox ── */
  (function initMapbox() {
    var token = typeof mapboxToken !== 'undefined' ? mapboxToken : '';
    var el    = document.getElementById('mapbox-map');
    if (!token || !el) return;

    // Lazy-load Mapbox GL JS depuis le CDN
    var css = document.createElement('link');
    css.rel = 'stylesheet';
    css.href = 'https://api.mapbox.com/mapbox-gl-js/v3.4.0/mapbox-gl.css';
    document.head.appendChild(css);

    var script = document.createElement('script');
    script.src = 'https://api.mapbox.com/mapbox-gl-js/v3.4.0/mapbox-gl.js';
    script.onload = function() {
      el.innerHTML = ''; // retirer le fallback iframe
      mapboxgl.accessToken = token;

      var map = new mapboxgl.Map({
        container   : 'mapbox-map',
        style       : 'mapbox://styles/mapbox/dark-v11',
        center      : [mapLng, mapLat],
        zoom        : 14.5,
        attributionControl: false,
        scrollZoom  : false,
      });

      map.addControl(new mapboxgl.NavigationControl({ showCompass: false }), 'bottom-right');

      map.on('style.load', function() {
        // Fond #0F0F0F
        try { map.setPaintProperty('background', 'background-color', '#0F0F0F'); } catch(_){}
        // Eau #1a0a0d
        ['water', 'water-shadow', 'waterway'].forEach(function(id) {
          try {
            if (map.getLayer(id)) {
              var type = map.getLayer(id).type;
              if (type === 'fill')  map.setPaintProperty(id, 'fill-color',   '#1a0a0d');
              if (type === 'line')  map.setPaintProperty(id, 'line-color',   '#1a0a0d');
            }
          } catch(_){}
        });
        // Terre sombre
        ['land', 'landcover', 'national-park', 'park'].forEach(function(id) {
          try { if (map.getLayer(id)) map.setPaintProperty(id, 'fill-color', '#0a0a0a'); } catch(_){}
        });
        // Routes crème (opacité réduite)
        map.getStyle().layers.forEach(function(layer) {
          if (layer['source-layer'] === 'road' && layer.type === 'line') {
            try { map.setPaintProperty(layer.id, 'line-color', '#F5F0E8'); } catch(_){}
            try { map.setPaintProperty(layer.id, 'line-opacity', 0.18); } catch(_){}
          }
        });
        // Labels plus discrets
        map.getStyle().layers.forEach(function(layer) {
          if (layer.type === 'symbol') {
            try { map.setPaintProperty(layer.id, 'text-color', 'rgba(245,240,232,0.45)'); } catch(_){}
          }
        });

        // Marqueur doré
        var markerEl = document.createElement('div');
        markerEl.style.cssText = [
          'width:14px', 'height:14px', 'border-radius:50%',
          'background:#C9A96E', 'border:2px solid rgba(201,169,110,0.35)',
          'box-shadow:0 0 0 6px rgba(201,169,110,0.12), 0 2px 8px rgba(0,0,0,0.4)',
          'cursor:pointer',
        ].join(';');
        new mapboxgl.Marker({ element: markerEl })
          .setLngLat([mapLng, mapLat])
          .addTo(map);
      });
    };
    document.head.appendChild(script);
  })();

