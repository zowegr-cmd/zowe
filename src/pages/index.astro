      <!-- Formulaire direct -->
      <form id="mainForm" class="simple-form" data-anim="up" data-delay="3" novalidate>
        <!-- Honeypot anti-bot : ne doit pas être rempli -->
        <input type="text" name="website" id="website_hp" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;pointer-events:none;height:0;width:0;" value="">
        <div class="ff-row">
          <div class="ff">
            <input type="text" id="prenom" name="prenom" placeholder=" " autocomplete="given-name" required>
            <label for="prenom" data-i18n="form.prenom">Prénom *</label>
          </div>
          <div class="ff">
            <input type="text" id="nom" name="nom" placeholder=" " autocomplete="family-name" required>
            <label for="nom" data-i18n="form.nom">Nom *</label>
          </div>
        </div>
        <div class="ff-row">
          <div class="ff">
            <input type="email" id="email" name="email" placeholder=" " autocomplete="email" required inputmode="email">
            <label for="email" data-i18n="form.email">Email *</label>
          </div>
          <div class="ff">
            <input type="tel" id="telephone" name="telephone" placeholder=" " autocomplete="tel" inputmode="tel" required>
            <label for="telephone" data-i18n="form.tel">Numéro de téléphone *</label>
          </div>
        </div>
        <div class="ff">
          <textarea id="message" name="message" placeholder=" " rows="5" required></textarea>
          <label for="message" data-i18n="form.message">Votre message *</label>
        </div>
        <div class="newsletter-opt">
          <input type="checkbox" id="newsletter" name="newsletter" value="true">
          <label for="newsletter">
            <span data-i18n="form.newsletter">J'accepte de recevoir les conseils et actualités de Zoé par email.</span>
            <span class="newsletter-opt__sub" data-i18n="form.newsletter_sub">Désinscription possible à tout moment.</span>
          </label>
        </div>
        <div class="simple-form__footer">
          <p class="mf-note" data-i18n="form.note">Zoé vous contactera dans la journée pour convenir ensemble d'un moment.</p>
          <button type="submit" class="btn btn-primary" id="submitBtn">
            <svg id="btnSpinner" class="btn-spinner" aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 2a10 10 0 0 1 0 20"/></svg>
            <span id="submitBtnText" data-i18n="form.submit">Écrire à Zoé</span>
          </button>
        </div>
        <div class="form-error" id="formError" hidden>
          <p class="form-error__msg" id="formErrorMsg">Un instant — la connexion semble lente. Réessayez ou contactez Zoé directement au 0471 78 37 46.</p>
          <a class="form-error__wa" id="formErrorWa" href={waLink} target="_blank" rel="noopener">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            Contacter via WhatsApp →
          </a>
