---
import Layout from '../layouts/Layout.astro';
import hero         from '../content/hero.json';
import experience   from '../content/experience.json';
import about        from '../content/about.json';
import gallery      from '../content/gallery.json';
import session      from '../content/session.json';
import services     from '../content/services.json';
import testimonials from '../content/testimonials.json';
import faq          from '../content/faq.json';
import infos        from '../content/infos.json';
import contact      from '../content/contact.json';
import meta         from '../content/meta.json';

const formAction = `https://formspree.io/f/${contact.formspreeId}`;
const allTestimonials = [...testimonials.items, ...testimonials.items];
const waLink = `https://wa.me/32471783746?text=${encodeURIComponent("Bonjour Zoé, je souhaite en savoir plus sur l'expérience Zowe.")}`;
const igLink = infos.instagram || 'https://www.instagram.com/kine.zowe';
const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN || '';
const mapLng = infos.mapLng ?? 4.3501;
const mapLat = infos.mapLat ?? 50.7474;
const mapsUrl = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent((infos.address || '') + ', ' + (infos.city || '') + ', Belgique')}`;
---

<Layout title={meta.siteTitle} description={meta.description}>

  <!-- Navigation -->
  <nav class="nav" id="nav">
    <a href="#hero" class="nav-logo">ZOWE</a>
    <ul class="nav-links" id="navLinks">
      <li><a href="#experience" data-i18n="nav.concept">Concept</a></li>
      <li><a href="#about" data-i18n="nav.approach">Approche</a></li>
      <li><a href="#services" data-i18n="nav.protocols">Protocoles</a></li>
      <li><a href="#faq" data-i18n="nav.faq">FAQ</a></li>
      {gallery.visible && <li><a href="/galerie" data-i18n="footer.gallery">Galerie</a></li>}
      {session.visible && <li><a href="/preparer-ma-seance" data-i18n="footer.before_session">Avant votre séance</a></li>}
      <li><a href="#contact" class="nav-cta" data-i18n="nav.cta">Initier mon accompagnement</a></li>
      <!-- Sélecteur de langue — visible uniquement dans le menu mobile -->
      <li class="nav-lang-mobile" aria-label="Choisir la langue">
        <button class="lang-btn" data-lang="fr">FR</button>
        <span aria-hidden="true">·</span>
        <button class="lang-btn" data-lang="nl">NL</button>
        <span aria-hidden="true">·</span>
        <button class="lang-btn" data-lang="en">EN</button>
      </li>
    </ul>
    <!-- Sélecteur de langue — visible uniquement sur desktop -->
    <div class="lang-selector" id="langSelector" aria-label="Choisir la langue">
      <button class="lang-btn" data-lang="fr">FR</button>
      <span aria-hidden="true">·</span>
      <button class="lang-btn" data-lang="nl">NL</button>
      <span aria-hidden="true">·</span>
      <button class="lang-btn" data-lang="en">EN</button>
    </div>
    <button class="nav-toggle" id="navToggle" aria-label="Ouvrir le menu">
      <span></span><span></span>
    </button>
  </nav>

  <!-- ① HERO -->
  <section id="hero" class="hero">
    <div class="hero-inner">
      <p class="hero-label" data-i18n="hero.label">{hero.label}</p>
      <h1 class="hero-title">{hero.title}</h1>
      <p class="hero-tagline" data-i18n="hero.tagline" set:html={hero.tagline.replace(/\n/g,'<br>')}></p>
      <a href="#contact" class="btn btn-primary" data-i18n="hero.cta">{hero.cta}</a>
    </div>
    <div class="hero-scroll" aria-hidden="true">&#8595;</div>
  </section>

  <!-- ② L'EXPÉRIENCE BELTRA -->
  <section id="experience" class="section experience">
    <div class="container">
      <div class="section-header" data-anim="up">
        <span class="section-number">01</span>
        <h2 class="section-title" data-i18n="experience.title">{experience.title}</h2>
      </div>
      <p class="experience-subtitle" data-anim="up" data-delay="1" data-i18n="experience.subtitle">{experience.subtitle}</p>
      <p class="experience-intro" data-anim="up" data-delay="2" data-i18n="experience.intro">{experience.intro}</p>
      <div class="experience-blocks">
        {experience.blocks.map((block, i) => (
          <div class="experience-block" data-anim="up" data-delay={String(i + 1)}>
            <span class="experience-block__num">0{i + 1}</span>
            <h3 data-i18n={`experience.blocks.${i}.title`}>{block.title}</h3>
            <p data-i18n={`experience.blocks.${i}.text`}>{block.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ③ QUI SUIS-JE -->
  <section id="about" class="section about">
    <div class="container">
      <div class="section-header" data-anim="up">
        <span class="section-number">02</span>
        <h2 class="section-title" data-i18n="about.title">{about.title}</h2>
      </div>
      <div class="about-grid">
        <div class="about-photo" data-anim="left">
          {about.image
            ? <img src={about.image} alt="Zoé — Kinésithérapeute BELTRA" loading="lazy">
            : <div class="about-photo__placeholder"><span>Photo professionnelle<br>à venir</span></div>
          }
        </div>
        <div class="about-content" data-anim="right">
          <p class="about-lead" data-i18n="about.lead">{about.lead}</p>
          <p data-i18n="about.paragraph1">{about.paragraph1}</p>
          <p data-i18n="about.paragraph2">{about.paragraph2}</p>
          <p data-i18n="about.paragraph3">{about.paragraph3}</p>
          <div class="about-signature">
            <img
              src="/images/signature_zoe_premium.png"
              alt="Signature Zoé Grêde"
              class="about-signature-img"
              loading="lazy"
            >
          </div>
          <div class="about-formation">
            <p class="label" data-i18n="about.formation">Formation</p>
            <p class="formation-school">{about.school}</p>
            <p class="formation-degree">{about.degree}</p>
            <p class="about-kine-mention">
              <span data-i18n="about.kine_mention">Zoé pratique également la kinésithérapie conventionnelle</span> —
              <a href="https://www.kinovea-lasne.com/praticiens/zoé-grêde" target="_blank" rel="noopener" class="kine-link">Kinovea Lasne</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ④ PROTOCOLES & INVESTISSEMENTS -->
  <section id="services" class="section services">
    <div class="container">
      <div class="section-header" data-anim="up">
        <span class="section-number">03</span>
        <h2 class="section-title" data-i18n="services.title">{services.title}</h2>
      </div>
      <p class="services-intro" data-anim="up" data-delay="1" data-i18n="services.intro">{services.intro}</p>
      <div class="beltra-grid">
        {services.tiers.map((tier, i) => (
          <div class={`beltra-card${i === 2 ? ' beltra-card--featured' : ''}`} data-anim="up" data-delay={String(i + 1)} data-share-title={tier.name} data-share-text={tier.tagline}>
            <div class="beltra-card__header">
              <div class="beltra-card__meta">
                <span class="beltra-card__duration">{tier.duration}</span>
                <span class="beltra-card__price">{tier.price}</span>
              </div>
              <h3 class="beltra-card__name" data-i18n={`services.tiers.${i}.name`}>{tier.name}</h3>
              <p class="beltra-card__tagline" data-i18n={`services.tiers.${i}.tagline`}>{tier.tagline}</p>
            </div>
            <div class="beltra-card__body">
              <p class="beltra-card__desc" data-i18n={`services.tiers.${i}.description`}>{tier.description}</p>
              <div class="beltra-card__tools">
                <p class="beltra-label" data-i18n="services.protocol">Protocole</p>
                <ul>{tier.tools.map((t, j) => <li data-i18n={`services.tiers.${i}.tools.${j}`}>{t}</li>)}</ul>
              </div>
              <div class="beltra-card__ideal">
                <p class="beltra-label" data-i18n="services.ideal">Idéal pour</p>
                <p data-i18n={`services.tiers.${i}.ideal`}>{tier.ideal}</p>
              </div>
            </div>
            <button class="share-btn" aria-label="Partager" data-share>
              <svg viewBox="0 0 24 24"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92c0-1.61-1.31-2.92-2.92-2.92z"/></svg>
            </button>
            <a href="#contact" class={`btn ${i === 2 ? 'btn-light' : 'btn-primary'}`} data-i18n="services.learn_more">En savoir plus</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GALERIE APERÇU (si activée dans le panel admin) -->
  {gallery.visible && gallery.photos.length > 0 && (
    <section class="section gallery-preview">
      <div class="container">
        <div class="section-header" data-anim="up">
          <h2 class="section-title">{gallery.title_fr}</h2>
        </div>
        <div class="gallery-grid gallery-grid--preview">
          {gallery.photos.slice(0, 3).map(photo => (
            <a href="/galerie" class="gallery-card">
              <img src={photo.image} alt={photo.title_fr} loading="lazy">
              <div class="gallery-card__overlay">
                {photo.protocol && <span class="gallery-card__badge">{photo.protocol}</span>}
                <p class="gallery-card__title">{photo.title_fr}</p>
              </div>
            </a>
          ))}
        </div>
        <div style="text-align:center;margin-top:2.5rem;">
          <a href="/galerie" class="btn btn-primary" data-anim="up" data-i18n="gallery.view_all">Voir toute la galerie</a>
        </div>
      </div>
    </section>
  )}

  <!-- ⑤ TÉMOIGNAGES (fallback statique · Google Reviews chargés dynamiquement) -->
  <section id="testimonials" class="section testimonials">
    <div class="container">
      <div class="section-header" data-anim="up">
        <span class="section-number">04</span>
        <h2 class="section-title" data-i18n="section.testimonials">Témoignages</h2>
      </div>
    </div>
    <div class="testimonials-track-wrapper">
      <div class="testimonials-track" id="testimonialsTrack">
        {allTestimonials.map((t) => (
          <div class="testimonial-card">
            <div class="testimonial-stars">{'★'.repeat(t.rating)}</div>
            <p class="testimonial-text">"{t.text}"</p>
            <div class="testimonial-meta">
              <span class="testimonial-name">{t.name}</span>
              <span class="testimonial-date">{t.date}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑥ FAQ -->
  <section id="faq" class="section faq-section">
    <div class="container">
      <div class="section-header" data-anim="up">
        <span class="section-number">05</span>
        <h2 class="section-title" data-i18n="section.faq">Questions fréquentes</h2>
      </div>
      <div class="faq-list">
        {faq.items.map((item, i) => (
          <details class="faq-item" id={`faq-${i}`} data-anim="up" data-delay={String(Math.min(i, 3))}>
            <summary class="faq-question">
              <span data-i18n={`faq.items.${i}.question`}>{item.question}</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </summary>
            <p class="faq-answer" data-i18n={`faq.items.${i}.answer`}>{item.answer}</p>
          </details>
        ))}
      </div>

    </div>
  </section>

  <!-- ⑥ PRISE DE CONTACT -->
  <section id="contact" class="section contact">
    <div class="container">
      <div class="section-header" data-anim="up">
        <span class="section-number">06</span>
        <h2 class="section-title" data-i18n="section.contact">Prise de contact</h2>
      </div>
      <p class="contact-intro" data-anim="up" data-delay="1" data-i18n="contact.intro">{contact.intro}</p>

      <!-- Infos contact + horaires -->
      <div class="contact-meta" data-anim="up" data-delay="2">
        <a href={`tel:${infos.phone.replace(/\s/g,'')}`} class="contact-meta__item">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
          {infos.phone}
        </a>
        <a href={`mailto:${infos.email}`} class="contact-meta__item">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
          {infos.email}
        </a>
        <a href={igLink} target="_blank" rel="noopener" class="contact-meta__item">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          @kine.zowe
        </a>
        {infos.hours.split('·').map(h => <span class="hours-pill">{h.trim()}</span>)}
      </div>

      <!-- Formulaire direct -->
      <form id="mainForm" class="simple-form" data-anim="up" data-delay="3" novalidate>
        <div class="ff-row">
          <div class="ff">
            <input type="text" id="prenom" name="prenom" placeholder=" " autocomplete="given-name" required>
            <label for="prenom" data-i18n="form.prenom">Prénom *</label>
          </div>
          <div class="ff">
            <input type="text" id="nom" name="nom" placeholder=" " autocomplete="family-name" required>
            <label for="nom" data-i18n="form.nom">Nom *</label>
          </div>
        </div>
        <div class="ff-row">
          <div class="ff">
            <input type="email" id="email" name="email" placeholder=" " autocomplete="email" required inputmode="email">
            <label for="email" data-i18n="form.email">Email *</label>
          </div>
          <div class="ff">
            <input type="tel" id="telephone" name="telephone" placeholder=" " autocomplete="tel" inputmode="tel">
            <label for="telephone" data-i18n="form.tel">GSM (optionnel)</label>
          </div>
        </div>
        <div class="ff">
          <textarea id="message" name="message" placeholder=" " rows="5" required></textarea>
          <label for="message" data-i18n="form.message">Votre message *</label>
        </div>
        <div class="newsletter-opt">
          <input type="checkbox" id="newsletter" name="newsletter" value="true">
          <label for="newsletter">
            <span data-i18n="form.newsletter">J'accepte de recevoir les conseils et actualités de Zoé par email.</span>
            <span class="newsletter-opt__sub" data-i18n="form.newsletter_sub">Désinscription possible à tout moment.</span>
          </label>
        </div>
        <div class="simple-form__footer">
          <p class="mf-note" data-i18n="form.note">Zoé vous contactera dans la journée pour convenir ensemble d'un moment.</p>
          <button type="submit" class="btn btn-primary" id="submitBtn" data-i18n="form.submit">Écrire à Zoé</button>
        </div>
      </form>
    </div>
  </section>

  <!-- ⑦ NOUS TROUVER -->
  <section id="localisation" class="section localisation-section">
    <div class="container">
      <div class="section-header" data-anim="up">
        <span class="section-number">07</span>
        <h2 class="section-title" data-i18n="section.localisation">Nous trouver</h2>
      </div>
      <div class="localisation-grid">
        <!-- Colonne gauche : infos -->
        <div class="localisation-info" data-anim="left">
          <div class="localisation-address-block">
            <p class="localisation-name">{infos.cabinet}</p>
            <p class="localisation-street">{infos.address}</p>
            <p class="localisation-street">{infos.city}</p>
          </div>
          <div class="hours-row">
            {infos.hours.split('·').map(h => <span class="hours-pill">{h.trim()}</span>)}
          </div>
          <p class="localisation-zones">{infos.zones}</p>
          <div class="localisation-contacts">
            <a href={`tel:${infos.phone.replace(/\s/g,'')}`}>{infos.phone}</a>
            <a href={`mailto:${infos.email}`}>{infos.email}</a>
          </div>
          <a href={mapsUrl} target="_blank" rel="noopener" class="btn btn-primary localisation-cta" data-i18n="localisation.directions">
            Obtenir l'itinéraire
          </a>
        </div>
        <!-- Colonne droite : carte -->
        <div class="localisation-map-col" id="mapbox-container" data-anim="right">
          <div id="mapbox-map">
            <iframe
              src="https://maps.google.com/maps?q=Kinovea+Rhode-Saint-Genese+Belgium&t=&z=15&ie=UTF8&iwloc=&output=embed"
              width="100%" height="100%" style="border:0;filter:grayscale(1) brightness(0.7);" loading="lazy"
              title="Localisation">
            </iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ⑧ FOOTER -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <p class="footer-logo">ZOWE</p>
          <p class="footer-tagline" data-i18n-html="footer.tagline">Kinésithérapie de haute précision<br>Méthode BELTRA</p>
        </div>
        <div class="footer-col">
          <p class="footer-col__title" data-i18n="footer.cabinet">Cabinet</p>
          <p>{infos.cabinet}</p>
          <p>{infos.cabinetText}</p>
          <p class="footer-zones">{infos.zones}</p>
        </div>
        <div class="footer-col">
          <p class="footer-col__title" data-i18n="footer.contact">Contact</p>
          <p><a href={`tel:${infos.phone.replace(/\s/g,'')}`}>{infos.phone}</a></p>
          <p><a href={`mailto:${infos.email}`}>{infos.email}</a></p>
          <p class="footer-tarif">{infos.tarifsTitle}</p>
        </div>
        <div class="footer-col">
          <p class="footer-col__title" data-i18n="footer.legal">Mentions légales</p>
          <p><span data-i18n="footer.entreprise">N° d'entreprise</span> : <em data-i18n="footer.to_complete">à compléter</em></p>
          <p><span data-i18n="footer.rcpro">Assurance RC Pro</span> : <em data-i18n="footer.to_complete">à compléter</em></p>
          <p><span data-i18n="footer.inami">Visa INAMI</span> : <em data-i18n="footer.to_complete">à compléter</em></p>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="footer-bottom__social">
          <a href={igLink} target="_blank" rel="noopener" class="instagram-link">
