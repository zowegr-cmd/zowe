<!-- ── Protocoles mobile : carousel plein écran + dots IntersectionObserver ── -->
<script is:inline>
(function() {
  if (window.innerWidth > 768) return;

  var grid = document.querySelector('#services .beltra-grid');
  if (!grid) return;

  var cards = Array.from(grid.querySelectorAll('.beltra-card'));
  var total = cards.length;
  if (!total) return;

  /* Dots */
  var dotsWrap = document.createElement('div');
  dotsWrap.className = 'beltra-dots';
  grid.parentNode.insertBefore(dotsWrap, grid.nextSibling);

  var dots = cards.map(function(_, i) {
    var d = document.createElement('button');
    d.className = 'beltra-dot' + (i === 0 ? ' active' : '');
    d.setAttribute('aria-label', 'Protocole ' + (i + 1));
    d.addEventListener('click', function() {
      grid.scrollTo({ left: i * window.innerWidth, behavior: 'smooth' });
    });
    dotsWrap.appendChild(d);
    return d;
  });

  /* IntersectionObserver — 1 card pleine largeur */
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        var idx = cards.indexOf(entry.target);
        if (idx !== -1) {
          dots.forEach(function(d, i) { d.classList.toggle('active', i === idx); });
        }
      }
    });
  }, { root: grid, threshold: 0.6 });

  cards.forEach(function(card) { observer.observe(card); });

  /* Bloquer scroll vertical pendant swipe horizontal */
  var startX = 0, startY = 0, lockH = false;
  grid.addEventListener('touchstart', function(e) {
    startX = e.touches[0].clientX;
    startY = e.touches[0].clientY;
    lockH  = false;
  }, { passive: true });

  grid.addEventListener('touchmove', function(e) {
    var dx = Math.abs(e.touches[0].clientX - startX);
    var dy = Math.abs(e.touches[0].clientY - startY);
    if (!lockH && dx > dy) { lockH = true; }
    if (lockH) e.preventDefault();
  }, { passive: false });
})();
</script>


