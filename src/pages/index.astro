---
import Layout from '../layouts/Layout.astro';
import hero         from '../content/hero.json';
import experience   from '../content/experience.json';
import about        from '../content/about.json';
import gallery      from '../content/gallery.json';
import session      from '../content/session.json';
import services     from '../content/services.json';
import testimonials from '../content/testimonials.json';
import faq          from '../content/faq.json';
import infos        from '../content/infos.json';
import contact      from '../content/contact.json';
import meta         from '../content/meta.json';

const formAction = `https://formspree.io/f/${contact.formspreeId}`;
// BELTRA en tête, puis les autres
const _sorted = [
  ...testimonials.items.filter(t => /beltra/i.test(t.text)),
  ...testimonials.items.filter(t => !/beltra/i.test(t.text)),
];
const allTestimonials = [..._sorted, ..._sorted];
const waLink = `https://wa.me/32471783746?text=${encodeURIComponent("Bonjour Zoé, je souhaite en savoir plus sur l'expérience Zowe.")}`;
const igLink = infos.instagram || 'https://www.instagram.com/kine.zowe';
const reviewLink = infos.googleReviews || `https://www.google.com/search?q=${encodeURIComponent('Kinovea Rhode-Saint-Genèse avis')}`;
const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN || '';
const mapLng = infos.mapLng ?? 4.3501;
const mapLat = infos.mapLat ?? 50.7474;
const mapsUrl = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent((infos.address || '') + ', ' + (infos.city || '') + ', Belgique')}`;
---

<Layout title={meta.siteTitle} description={meta.description}>

  <!-- Safe areas : prolongent la couleur de section sous les barres iOS -->
  <div id="homeTopBar"    aria-hidden="true"></div>
  <div id="homeBottomBar" aria-hidden="true"></div>

  <!-- ① HERO -->
  <section id="hero" class="hero">
    <div class="hero-inner">
      <p class="hero-label" data-i18n="hero.label">{hero.label.fr}</p>
      <h1 class="hero-title">
        <svg class="hero-logo-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 172.31 58.6" aria-label="Zowe" role="img" focusable="false">
          <path fill="currentColor" d="M34.7,44.62c-.31-.07-.57-.03-.77.1s-.38.36-.51.69l-1.09,2.9c-.55,1.47-1.08,2.66-1.6,3.57-.52.91-1.09,1.62-1.71,2.13-.63.51-1.37.85-2.22,1.02-.86.18-1.89.26-3.1.26H6.05L33.48,14.28c.24-.4.42-.75.54-1.05.12-.31.18-.58.18-.82,0-.33-.13-.61-.38-.84s-.64-.35-1.17-.35H8.83c-.55,0-.99-.14-1.33-.43s-.65-.57-.94-.84c-.29-.27-.62-.41-.99-.41s-.69.13-.94.38-.44.67-.58,1.24l-2.11,9.39c-.11.5-.08.9.08,1.19s.4.46.71.53c.33.07.63.01.91-.16.27-.17.5-.47.67-.89l.99-2.87c.46-1.25,1-2.25,1.63-3s1.35-1.28,2.18-1.6c.82-.32,1.73-.48,2.72-.48h16.39L.66,54.48c-.24.35-.41.67-.51.94-.1.27-.15.56-.15.84,0,.33.12.59.35.79.23.2.62.3,1.17.3h26.86c.61,0,1.09.1,1.42.31.33.21.62.42.87.63s.55.31.91.31c.42,0,.73-.13.95-.38s.37-.61.46-1.07l2.44-11.14c.09-.37.08-.68-.03-.92-.11-.24-.34-.4-.69-.46ZM78.21,17.62c-1.35-2.21-3.1-3.94-5.26-5.19-2.15-1.25-4.61-1.93-7.38-2.04-2.94-.11-5.84.35-8.68,1.37-2.84,1.02-5.5,2.52-7.97,4.5-2.47,1.98-4.62,4.33-6.46,7.07-1.83,2.73-3.22,5.76-4.17,9.08-1.08,3.74-1.49,7.15-1.25,10.25.24,3.1,1.02,5.78,2.32,8.06,1.31,2.27,3.04,4.06,5.19,5.36,2.15,1.3,4.62,2,7.42,2.11,3.18.13,6.25-.28,9.21-1.23,2.96-.96,5.68-2.43,8.17-4.42,2.49-1.99,4.65-4.44,6.47-7.36,1.82-2.92,3.21-6.26,4.15-10.02.86-3.54,1.12-6.79.77-9.75s-1.19-5.55-2.54-7.76ZM75.6,30.11c-.21,1.5-.54,3.11-1,4.83-1.03,3.8-2.33,7.07-3.89,9.82s-3.31,4.98-5.24,6.71-3.97,2.98-6.1,3.76-4.27,1.12-6.43,1c-3.21-.13-5.82-1.35-7.84-3.66s-3-5.7-2.93-10.18c.02-1.34.14-2.82.36-4.43s.57-3.37,1.05-5.26c.79-3.21,1.93-6.1,3.41-8.67,1.48-2.57,3.19-4.75,5.12-6.52,1.93-1.78,3.99-3.11,6.16-4,2.18-.89,4.34-1.27,6.49-1.14,2.02.11,3.86.7,5.52,1.78,1.66,1.08,2.99,2.6,4,4.56,1.01,1.97,1.54,4.37,1.58,7.2.02,1.3-.07,2.7-.28,4.2ZM153.68,8.89c.2.01.38-.03.56-.12l6.43-3.56c.79-.4,1.44-.8,1.96-1.2.52-.4.85-.92,1-1.53.13-.48.07-.96-.2-1.45-.26-.48-.69-.8-1.28-.96-.72-.17-1.38-.04-1.98.41-.59.45-1.26,1.09-2.01,1.93l-4.78,5.27c-.11.15-.21.32-.3.49s-.06.34.1.49c.13.13.3.2.49.21ZM142.05,14.01c.27.33.43.65.43,1.09v38.36c0,.44-.14.8-.43,1.09s-.69.47-1.22.56l-2.47.4c-.73.15-1.09.48-1.09.99,0,.24.1.44.3.61.2.16.5.25.92.25h26.16c.55,0,1.02.1,1.4.31s.75.42,1.09.63.7.31,1.07.31c.4,0,.71-.12.96-.35s.42-.58.53-1.04l2.54-10.84c.11-.42.09-.74-.05-.97-.14-.23-.39-.37-.74-.41-.26-.02-.5.03-.71.15s-.38.34-.51.64c-1.08,2.75-2.03,4.79-2.87,6.14-.84,1.35-1.71,2.25-2.62,2.7s-2.04.68-3.38.68h-10.08c-1.27,0-2.2-.21-2.78-.64-.58-.43-.87-1.07-.87-1.93v-17.23h11.76c.81,0,1.49.09,2.03.28.54.19,1.02.54,1.45,1.07s.88,1.31,1.37,2.34c.17.29.38.48.63.59.24.11.49.13.76.07.31-.09.51-.24.61-.46.1-.22.1-.5.02-.86l-2.44-9.1c-.18-.75-.55-1.07-1.12-.95-.29.04-.5.16-.64.36-.14.2-.24.48-.28.86-.11,1.47-.42,2.47-.94,2.98s-1.46.77-2.82.77h-10.38V13.25h12.75c1.08,0,1.99.08,2.74.25.75.17,1.42.5,2.01,1,.59.51,1.18,1.25,1.75,2.23s1.21,2.29,1.91,3.94c.18.39.41.66.69.79s.59.16.92.1c.31-.09.52-.25.64-.48.12-.23.13-.51.02-.84l-2.44-9.19c-.13-.48-.3-.82-.51-1.02-.21-.2-.5-.3-.87-.3-.42,0-.8.12-1.14.36s-.7.49-1.07.74-.86.38-1.45.38h-34.7c-.42,0-.76.09-1.02.26-.26.18-.4.41-.4.69,0,.44.4.76,1.19.95l2.01.43c.94.26,1.5.77,1.66,1.53s-.06,1.63-.68,2.62l-19.13,32.74c-.03-.67-.06-1.41-.09-2.26-.08-1.89-.16-4.04-.25-6.46-.09-2.42-.18-4.91-.28-7.48-.1-2.57-.2-5.04-.3-7.4-.1-2.36-.18-4.44-.25-6.23-.07-1.79-.11-3.11-.13-3.97-.02-.99.09-1.7.35-2.14.25-.44.77-.72,1.56-.86l2.67-.53c.33-.09.61-.22.84-.4.23-.17.35-.4.35-.69s-.09-.49-.28-.63c-.19-.13-.48-.2-.87-.2h-11.9c-.48,0-.86.08-1.12.25-.26.16-.39.4-.39.71,0,.22.1.41.3.58s.43.28.69.35l1.38.36c.62.13,1.04.41,1.29.84.24.43.41,1.09.49,1.99.07.99.15,2.42.25,4.3.01.21.02.45.03.66l-18.48,29.33c0-1.04-.01-2.15-.03-3.38-.02-2.09-.04-4.32-.07-6.69-.02-2.37-.04-4.76-.07-7.17-.02-2.41-.03-4.7-.03-6.89s0-4.16-.02-5.91c-.01-1.76,0-3.15.02-4.18.02-.9.19-1.55.51-1.96s.84-.66,1.56-.77l2.31-.43c.5-.09.88-.23,1.12-.43.24-.2.36-.43.36-.69,0-.29-.1-.5-.28-.64-.19-.14-.51-.21-.97-.21h-12.19c-.44,0-.77.08-1,.23-.23.15-.35.39-.35.69,0,.24.12.45.35.63.23.17.6.32,1.1.43l1.05.3c.57.11.98.37,1.22.79.24.42.37,1,.4,1.75.02,1.32.05,3,.08,5.04.03,2.04.07,4.27.1,6.69.03,2.42.07,4.85.1,7.31s.06,4.78.08,6.97c.02,2.19.04,4.07.05,5.65.01,1.58,0,2.68-.02,3.29,0,.55-.02,1.03-.07,1.43-.04.41-.15.83-.33,1.27l-.56,1.91c-.22.55-.21.98.03,1.28.24.31.67.46,1.28.46h2.37c.59,0,1.06-.13,1.4-.4.34-.26.6-.65.77-1.15l.46-1.75c.15-.55.36-1.03.61-1.43s.59-.9,1-1.47l16.26-26.69c.04.8.08,1.6.12,2.47.11,2.35.21,4.77.31,7.25.1,2.48.19,4.86.26,7.12.08,2.26.14,4.25.2,5.95.06,1.7.09,2.93.12,3.67,0,.46-.02.89-.05,1.28-.03.4-.13.82-.28,1.29l-.63,1.98c-.22.57-.21,1.03.02,1.37.23.34.61.51,1.14.51h2.7c.46,0,.86-.13,1.19-.38.33-.25.57-.64.72-1.17l.49-1.78c.17-.53.38-1,.61-1.42.23-.42.48-.82.74-1.22l19.24-33.18c.59-.92,1.14-1.7,1.63-2.32.49-.63.98-1.14,1.45-1.53.27-.24,1.12-.92,2.43-1.02,1.36-.1,2.33.39,2.63.69Z"/>
        </svg>
      </h1>
      <p class="hero-tagline" data-i18n="hero.tagline" set:html={hero.tagline.fr.replace(/\n/g,'<br>')}></p>
      <a href="#contact" class="btn btn-primary" data-i18n="hero.cta">{hero.cta.fr}</a>
      <a href="/reserver?s=hero" id="kqHeroLink" class="kq-hero-link" style="display:none" aria-hidden="true">ou réserver directement →</a>
    </div>
    <div class="hero-scroll" aria-hidden="true">&#8595;</div>
  </section>

  <!-- ② L'EXPÉRIENCE BELTRA -->
  <section id="experience" class="section experience">
    <div class="container">
      <div class="section-header" data-anim="up">
        <span class="section-number">01</span>
        <h2 class="section-title" data-i18n="experience.title">{experience.title.fr}</h2>
      </div>
      <p class="experience-subtitle" data-anim="up" data-delay="1" data-i18n="experience.subtitle">{experience.subtitle.fr}</p>
      <p class="experience-intro" data-anim="up" data-delay="2" data-i18n="experience.intro">{experience.intro.fr}</p>
      <div class="experience-blocks">
        {experience.blocks.map((block, i) => (
          <div class="experience-block" data-anim="up" data-delay={String(i + 1)}>
            <span class="experience-block__num">0{i + 1}</span>
            <h3 data-i18n={`experience.blocks.${i}.title`}>{block.title.fr}</h3>
            <p data-i18n={`experience.blocks.${i}.text`}>{block.text.fr}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ③ QUI SUIS-JE -->
  <section id="about" class="section about">
    <div class="container">
      <div class="section-header" data-anim="up">
        <span class="section-number">02</span>
        <h2 class="section-title" data-i18n="about.title">{about.title.fr}</h2>
      </div>
      <div class="about-grid">
        <div class="about-photo" data-anim="left">
          {about.image
            ? <img src={about.image} alt="Zoé — Kinésithérapeute BELTRA" loading="lazy">
            : <div class="about-photo__placeholder"><span>Photo professionnelle<br>à venir</span></div>
          }
        </div>
        <div class="about-content" data-anim="right">
          <p class="about-lead" data-i18n="about.lead">{about.lead.fr}</p>
          <p data-i18n="about.paragraph1">{about.paragraph1.fr}</p>
          <p data-i18n="about.paragraph2">{about.paragraph2.fr}</p>
          <p data-i18n="about.paragraph3">{about.paragraph3.fr}</p>
          <div class="about-signature">
            <img
              src="/images/signature_zoe_premium.png"
              alt="Signature Zoé Grêde"
              class="about-signature-img"
              loading="lazy"
            >
          </div>
          <div class="about-formation">
            <p class="label" data-i18n="about.formation">Formation</p>
            <p class="formation-school">{about.school}</p>
            <p class="formation-degree">{about.degree}</p>
            <p class="about-kine-mention">
              <span data-i18n="about.kine_mention">Zoé pratique également la kinésithérapie conventionnelle</span> —
              <a href="https://www.kinovea-lasne.com/praticiens/zoé-grêde" target="_blank" rel="noopener" class="kine-link">Kinovea Lasne</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ④ PROTOCOLES & INVESTISSEMENTS -->
  <section id="services" class="section services">
    <div class="container">
      <div class="section-header" data-anim="up">
        <span class="section-number">03</span>
        <h2 class="section-title" data-i18n="services.title">{services.title.fr}</h2>
      </div>
      <p class="services-intro" data-anim="up" data-delay="1" data-i18n="services.intro">{services.intro.fr}</p>
      <div class="beltra-grid">
        {services.tiers.map((tier, i) => (
          <div class={`beltra-card${i === 2 ? ' beltra-card--featured' : ''}`} data-anim="up" data-delay={String(i + 1)} data-share-title={tier.name.fr} data-share-text={tier.tagline.fr}>
            <div class="beltra-card__header">
              <div class="beltra-card__meta">
                <span class="beltra-card__duration">{tier.duration}</span>
                <span class="beltra-card__price">{tier.price}</span>
              </div>
              <h3 class="beltra-card__name" data-i18n={`services.tiers.${i}.name`}>{tier.name.fr}</h3>
              <p class="beltra-card__tagline" data-i18n={`services.tiers.${i}.tagline`}>{tier.tagline.fr}</p>
            </div>
            <div class="beltra-card__body">
              <p class="beltra-card__desc" data-i18n={`services.tiers.${i}.description`}>{tier.description.fr}</p>
              <div class="beltra-card__tools">
                <p class="beltra-label" data-i18n="services.protocol">Protocole</p>
                <ul>{tier.tools.fr.map((t, j) => <li data-i18n={`services.tiers.${i}.tools.${j}`}>{t}</li>)}</ul>
              </div>
              <div class="beltra-card__ideal">
                <p class="beltra-label" data-i18n="services.ideal">Idéal pour</p>
                <p data-i18n={`services.tiers.${i}.ideal`}>{tier.ideal.fr}</p>
              </div>
            </div>
            <button class="share-btn" aria-label="Partager" data-share>
              <svg viewBox="0 0 24 24"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92c0-1.61-1.31-2.92-2.92-2.92z"/></svg>
            </button>
            <a href="#contact" class={`btn ${i === 2 ? 'btn-light' : 'btn-primary'}`} data-i18n="services.learn_more">En savoir plus</a>
            {i === 0 && <a href="/reserver?s=protocoles" class="kq-card-link" style="display:none">ou réserver directement →</a>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GALERIE APERÇU (si activée dans le panel admin) -->
  {gallery.visible && gallery.photos.length > 0 && (
    <section class="section gallery-preview">
      <div class="container">
        <div class="section-header" data-anim="up">
          <h2 class="section-title">{gallery.title_fr}</h2>
        </div>
        <div class="gallery-grid gallery-grid--preview" id="galleryPreviewGrid">
          {gallery.photos.slice(0, 3).map((photo, i) => (
            <a href="/galerie" class="gallery-card" data-preview-idx={String(i)}>
              <img src={photo.image} alt={photo.title_fr} loading="lazy" style="height:280px;width:100%;object-fit:cover;display:block;">
              <div class="gallery-card__overlay">
                {photo.protocol && <span class="gallery-card__badge">{photo.protocol}</span>}
                <p class="gallery-card__title">{photo.title_fr}</p>
              </div>
            </a>
          ))}
        </div>
        <script is:inline>
          (function() {
            if (window.innerWidth > 768) return;
            var grid = document.getElementById('galleryPreviewGrid');
            if (!grid) return;
            grid.style.gridTemplateColumns = '1fr';
            grid.querySelectorAll('.gallery-card').forEach(function(card) {
              if (card.dataset.previewIdx !== '1') card.style.display = 'none';
            });
          })();
        </script>
        <div style="text-align:center;margin-top:2.5rem;">
          <a href="/galerie" class="btn btn-primary" data-anim="up" data-i18n="gallery.view_all">Voir toute la galerie</a>
        </div>
      </div>
    </section>
  )}

  <!-- ⑤ TÉMOIGNAGES (fallback statique · Google Reviews chargés dynamiquement) -->
  <section id="testimonials" class="section testimonials">
    <div class="container">
      <div class="section-header" data-anim="up">
        <span class="section-number">04</span>
        <h2 class="section-title" data-i18n="section.testimonials">Témoignages</h2>
      </div>
    </div>
    <div class="testimonials-outer">
      <div class="testimonials-track-wrapper">
        <div id="testimonialsSkeletonTrack" class="testimonials-track" role="status" aria-label="Chargement des avis" aria-live="polite">
          {Array(8).fill(0).map(() => (
            <div class="testimonial-card skeleton-card" aria-hidden="true">
              <div class="skeleton-line" style="width:28%;margin-bottom:.75rem"></div>
              <div class="skeleton-line" style="width:92%"></div>
              <div class="skeleton-line" style="width:85%"></div>
              <div class="skeleton-line" style="width:70%;margin-bottom:1rem"></div>
              <div style="display:flex;justify-content:space-between;padding-top:.75rem;border-top:1px solid var(--border)">
                <div class="skeleton-line" style="width:32%;margin:0"></div>
                <div class="skeleton-line" style="width:18%;margin:0"></div>
              </div>
            </div>
          ))}
        </div>
        <div class="testimonials-track" id="testimonialsTrack" style="display:none">
          {allTestimonials.map((t) => (
            <div class="testimonial-card">
              <div class="testimonial-stars">{'★'.repeat(t.rating)}</div>
              <p class="testimonial-text">"{t.text}"</p>
              <div class="testimonial-meta">
                <span class="testimonial-name">{t.name}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="testimonials-nav">
        <button class="testimonials-btn" id="testimonialsPrev" aria-label="Avis précédent">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button class="testimonials-btn" id="testimonialsNext" aria-label="Avis suivant">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- ⑥ FAQ -->
  <section id="faq" class="section faq-section">
    <div class="container">
      <div class="section-header" data-anim="up">
        <span class="section-number">05</span>
        <h2 class="section-title" data-i18n="section.faq">Questions fréquentes</h2>
      </div>
      <div class="faq-list">
        {faq.items.map((item, i) => (
          <details class={`faq-item${i >= 6 ? ' faq-item--extra' : ''}`} id={`faq-${i}`} data-anim="up" data-delay={String(Math.min(i, 3))}>
            <summary class="faq-question">
              <span data-i18n={`faq.items.${i}.question`}>{item.question.fr}</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </summary>
            <p class="faq-answer" data-i18n={`faq.items.${i}.answer`}>{item.answer.fr}</p>
          </details>
        ))}
      </div>
      <div class="faq-more-wrap">
        <button class="faq-more-btn" id="faqMoreBtn" aria-expanded="false">
          <span class="faq-more-label" data-i18n="faq.show_more">+ Voir toutes les questions</span>
        </button>
      </div>

    </div>
  </section>

  <!-- ⑥ PRISE DE CONTACT -->
  <section id="contact" class="section contact">
    <div class="container">
      <div class="section-header" data-anim="up">
        <span class="section-number">06</span>
        <h2 class="section-title" data-i18n="section.contact">Prise de contact</h2>
      </div>
      <p class="contact-intro" data-anim="up" data-delay="1" data-i18n="contact.intro">{contact.intro.fr}</p>

      <!-- Sous-titre KinoQuick (caché par défaut) -->
      <p class="kq-subtitle" id="kqSubtitle" style="display:none">Choisissez comment vous souhaitez commencer.</p>

      <!-- Icônes contact rapide (cachées quand KinoQuick actif) -->
      <div class="contact-meta" id="contactMeta" data-anim="up" data-delay="2">
