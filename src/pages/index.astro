      <p class="services-intro" data-anim="up" data-delay="1" data-i18n="services.intro">{services.intro.fr}</p>
      <div class="beltra-grid">
        {services.tiers.map((tier, i) => (
          <div class={`beltra-card${i === 2 ? ' beltra-card--featured' : ''}`} data-anim="up" data-delay={String(i + 1)} data-share-title={tier.name.fr} data-share-text={tier.tagline.fr}>
            <div class="beltra-card__header">
              <div class="beltra-card__meta">
                <span class="beltra-card__duration">{tier.duration}</span>
                <span class="beltra-card__price">{tier.price}</span>
