<script is:inline define:vars={{ mapboxToken, mapLng, mapLat }}>
(function () {

  /* ── Formulaire direct → Netlify Function ── */
  var form = document.getElementById('mainForm');
  if (form) {
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var prenom = (document.getElementById('prenom') || {}).value || '';
      var email  = (document.getElementById('email')  || {}).value || '';
      if (!prenom.trim() || !email.trim()) {
        alert((window._i18n && window._i18n['form.error_required']) || 'Veuillez renseigner votre prénom et votre email.');
        return;
      }
      var btn = document.getElementById('submitBtn');
      if (btn) { btn.textContent = (window._i18n && window._i18n['form.sending']) || 'Envoi en cours…'; btn.disabled = true; }

      var payload = {
        prenom:    prenom.trim(),
        nom:       ((document.getElementById('nom') || {}).value || '').trim(),
        email:     email.trim(),
        telephone: ((document.getElementById('telephone') || {}).value || '').trim(),
        message:   ((document.getElementById('message')   || {}).value || '').trim(),
        newsletter: document.getElementById('newsletter') ? document.getElementById('newsletter').checked : false,
      };

      fetch('/.netlify/functions/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      }).then(function (r) {
        if (r.ok) { window.location.href = '/merci/'; }
        else {
          r.json().then(function (d) { alert(d.error || (window._i18n && window._i18n['form.error_server']) || 'Une erreur est survenue. Veuillez réessayer.'); })
           .catch(function () { alert((window._i18n && window._i18n['form.error_server']) || 'Une erreur est survenue. Veuillez réessayer.'); });
          if (btn) { btn.textContent = (window._i18n && window._i18n['form.submit']) || 'Écrire à Zoé'; btn.disabled = false; }
        }
      }).catch(function () {
        alert((window._i18n && window._i18n['form.error_network']) || 'Erreur réseau. Veuillez réessayer.');
        if (btn) { btn.textContent = 'Écrire à Zoé'; btn.disabled = false; }
      });
    });
  }

  /* ── Google Reviews dynamiques ── */
  (function loadReviews() {
    var track = document.getElementById('testimonialsTrack');
    if (!track) return;
    fetch('/.netlify/functions/reviews')
      .then(function(r){ return r.ok ? r.json() : null; })
      .then(function(reviews) {
        if (!reviews || reviews.length < 2) return; // garder le fallback si peu de résultats
        var doubled = reviews.concat(reviews); // double pour le marquee infini
        track.innerHTML = doubled.map(function(t) {
          return '<div class="testimonial-card">'
            + '<div class="testimonial-stars">' + '★'.repeat(t.rating) + '</div>'
            + '<p class="testimonial-text">&ldquo;' + escHtml(t.text) + '&rdquo;</p>'
            + '<div class="testimonial-meta">'
            + '<span class="testimonial-name">' + escHtml(t.name) + '</span>'
            + '<span class="testimonial-date">' + escHtml(t.date) + '</span>'
            + '</div></div>';
        }).join('');
      })
      .catch(function(){});
    function escHtml(s) {
      return String(s).replace(/[&<>"']/g, function(c) {
        return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
      });
    }
  })();

  /* ── Mapbox ── */
  (function initMapbox() {
    var token = typeof mapboxToken !== 'undefined' ? mapboxToken : '';
    var el    = document.getElementById('mapbox-map');
    if (!token || !el) return;

    // Lazy-load Mapbox GL JS depuis le CDN
    var css = document.createElement('link');
    css.rel = 'stylesheet';
    css.href = 'https://api.mapbox.com/mapbox-gl-js/v3.4.0/mapbox-gl.css';
    document.head.appendChild(css);

    var script = document.createElement('script');
    script.src = 'https://api.mapbox.com/mapbox-gl-js/v3.4.0/mapbox-gl.js';
    script.onload = function() {
      el.innerHTML = ''; // retirer le fallback iframe
      mapboxgl.accessToken = token;

      var map = new mapboxgl.Map({
        container   : 'mapbox-map',
        style       : 'mapbox://styles/mapbox/dark-v11',
        center      : [mapLng, mapLat],
        zoom        : 14.5,
        attributionControl: false,
        scrollZoom  : false,
      });

      map.addControl(new mapboxgl.NavigationControl({ showCompass: false }), 'bottom-right');

      map.on('style.load', function() {
        // Fond #0F0F0F
        try { map.setPaintProperty('background', 'background-color', '#0F0F0F'); } catch(_){}
        // Eau #1a0a0d
        ['water', 'water-shadow', 'waterway'].forEach(function(id) {
          try {
            if (map.getLayer(id)) {
              var type = map.getLayer(id).type;
              if (type === 'fill')  map.setPaintProperty(id, 'fill-color',   '#1a0a0d');
              if (type === 'line')  map.setPaintProperty(id, 'line-color',   '#1a0a0d');
            }
          } catch(_){}
        });
        // Terre sombre
        ['land', 'landcover', 'national-park', 'park'].forEach(function(id) {
          try { if (map.getLayer(id)) map.setPaintProperty(id, 'fill-color', '#0a0a0a'); } catch(_){}
        });
        // Routes crème (opacité réduite)
        map.getStyle().layers.forEach(function(layer) {
          if (layer['source-layer'] === 'road' && layer.type === 'line') {
            try { map.setPaintProperty(layer.id, 'line-color', '#F5F0E8'); } catch(_){}
            try { map.setPaintProperty(layer.id, 'line-opacity', 0.18); } catch(_){}
          }
        });
        // Labels plus discrets
        map.getStyle().layers.forEach(function(layer) {
          if (layer.type === 'symbol') {
            try { map.setPaintProperty(layer.id, 'text-color', 'rgba(245,240,232,0.45)'); } catch(_){}
          }
        });

        // Marqueur doré
        var markerEl = document.createElement('div');
        markerEl.style.cssText = [
          'width:14px', 'height:14px', 'border-radius:50%',
          'background:#C9A96E', 'border:2px solid rgba(201,169,110,0.35)',
          'box-shadow:0 0 0 6px rgba(201,169,110,0.12), 0 2px 8px rgba(0,0,0,0.4)',
          'cursor:pointer',
        ].join(';');
        new mapboxgl.Marker({ element: markerEl })
          .setLngLat([mapLng, mapLat])
          .addTo(map);
      });
    };
    document.head.appendChild(script);
  })();

  /* ── FAQ accordion icon ── */
  document.querySelectorAll('.faq-item').forEach(function(d){
    d.addEventListener('toggle', function(){
      var icon = this.querySelector('.faq-icon');
      if(icon) icon.textContent = this.open ? '−' : '+';
    });
  });

  /* ── Boutons partage (Web Share API) ── */
  document.querySelectorAll('[data-share]').forEach(function(btn) {
    var card = btn.closest('[data-share-title]');
    if (!card) return;
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      var title = card.dataset.shareTitle || 'Zowe — Kinésithérapie BELTRA';
      var text  = card.dataset.shareText  || 'Découvrez les protocoles Zowe.';
      var url   = 'https://zowe.netlify.app/#services';
      if (navigator.share) {
        navigator.share({ title: title, text: text + ' — ' + title, url: url });
      } else {
        var wa = 'https://wa.me/?text=' + encodeURIComponent(title + ' — ' + url);
        window.open(wa, '_blank');
      }
    });
  });

  /* ── Sticky CTA : masquer quand on est dans la section contact ── */
  var stickyCta = document.getElementById('stickyCta');
  var contactSection = document.getElementById('contact');
  if (stickyCta && contactSection) {
    var stickyObs = new IntersectionObserver(function(entries) {
      stickyCta.classList.toggle('sticky-cta--hidden', entries[0].isIntersecting);
    }, { threshold: 0.15 });
    stickyObs.observe(contactSection);
  }

})();
</script>
