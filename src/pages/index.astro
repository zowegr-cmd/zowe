        </a>
        <a href={`mailto:${infos.email}`} class="contact-meta__item contact-meta__item--icon" aria-label="Email">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
        </a>
        <a href={igLink} target="_blank" rel="noopener" class="contact-meta__item contact-meta__item--icon" aria-label="Instagram">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
      </div>

      <!-- Layout 2 chemins : KinoQuick + Formulaire -->
      <div class="kq-contact-layout" id="kqContactWrap">

        <!-- CHEMIN 1 — Réservation directe (caché par défaut) -->
        <div class="kq-column" id="kqColumn" style="display:none">
          <span class="kq-badge" id="kqBadge">Disponibilité immédiate</span>
          <h3 class="kq-titre" id="kqTitre">Réserver un Bilan Précision</h3>
          <p class="kq-desc" id="kqDesc">Choisissez directement votre créneau dans l'agenda de Zoé.</p>
          <p class="kq-detail" id="kqDetail">30 min · 60€</p>
          <a href="/reserver?s=contact" id="kqContactBtn" class="kq-btn">Réserver maintenant</a>
        </div>

        <!-- Séparateur (caché par défaut) -->
        <div class="kq-sep" id="kqSep" style="display:none">
          <div class="kq-sep-line"></div>
          <span id="kqSepText">ou</span>
          <div class="kq-sep-line"></div>
        </div>

        <!-- CHEMIN 2 — Formulaire (toujours visible) -->
        <div class="kq-form-col" id="kqFormCol">
          <p class="kq-form-title" id="kqFormTitle" style="display:none">Une question avant de vous lancer&nbsp;?</p>
          <p class="kq-form-desc" id="kqFormDesc" style="display:none">Zoé vous répond personnellement dans la journée.</p>

      <!-- Formulaire direct -->
      <form id="mainForm" class="simple-form" data-anim="up" data-delay="3" novalidate>
        <!-- Honeypot anti-bot : ne doit pas être rempli -->
        <input type="text" name="website" id="website_hp" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;pointer-events:none;height:0;width:0;" value="">
        <div class="ff-row">
          <div class="ff">
            <input type="text" id="prenom" name="prenom" placeholder=" " autocomplete="given-name" required>
            <label for="prenom" data-i18n="form.prenom">Prénom *</label>
          </div>
          <div class="ff">
            <input type="text" id="nom" name="nom" placeholder=" " autocomplete="family-name" required>
            <label for="nom" data-i18n="form.nom">Nom *</label>
          </div>
        </div>
        <div class="ff-row">
          <div class="ff">
            <input type="email" id="email" name="email" placeholder=" " autocomplete="email" required inputmode="email">
            <label for="email" data-i18n="form.email">Email *</label>
          </div>
          <div class="ff">
            <input type="tel" id="telephone" name="telephone" placeholder=" " autocomplete="tel" inputmode="tel" required>
            <label for="telephone" data-i18n="form.tel">Numéro de téléphone *</label>
          </div>
        </div>
        <div class="ff">
          <textarea id="message" name="message" placeholder=" " rows="5" required></textarea>
          <label for="message" data-i18n="form.message">Votre message *</label>
        </div>
        <div class="newsletter-opt">
          <input type="checkbox" id="newsletter" name="newsletter" value="true">
          <label for="newsletter">
            <span data-i18n="form.newsletter">J'accepte de recevoir les conseils et actualités de Zoé par email.</span>
            <span class="newsletter-opt__sub" data-i18n="form.newsletter_sub">Désinscription possible à tout moment.</span>
          </label>
        </div>
        <div class="simple-form__footer">
          <p class="mf-note" data-i18n="form.note">Zoé vous contactera dans la journée pour convenir ensemble d'un moment.</p>
          <button type="submit" class="btn btn-primary" id="submitBtn">
            <svg id="btnSpinner" class="btn-spinner" aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 2a10 10 0 0 1 0 20"/></svg>
            <span id="submitBtnText" data-i18n="form.submit">Écrire à Zoé</span>
          </button>
        </div>
        <div class="form-error" id="formError" hidden>
          <p class="form-error__msg" id="formErrorMsg">Un instant — la connexion semble lente. Réessayez ou contactez Zoé directement au 0471 78 37 46.</p>
          <a class="form-error__wa" id="formErrorWa" href={waLink} target="_blank" rel="noopener">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            Contacter via WhatsApp →
          </a>
        </div>
      </form>
      <!-- Confirmation succès (s'affiche avant la redirection /merci) -->
      <div class="form-success" id="formSuccess" hidden aria-live="polite">
        <div class="form-success__inner">
          <svg class="form-success__circle" viewBox="0 0 52 52" width="52" height="52">
            <circle cx="26" cy="26" r="23" fill="none" stroke="#C9A96E" stroke-width="1.5"/>
            <path class="form-success__tick" fill="none" stroke="#C9A96E" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round" d="M 14,26 L 22,34 L 38,18"/>
          </svg>
          <p data-i18n="form.success_msg">Votre demande est en route. Zoé revient vers vous bientôt.</p>
        </div>
        </div><!-- /form-success -->
        </div><!-- /kq-form-col -->
      </div><!-- /kq-contact-layout -->

      <!-- ── CONTACT MOBILE — 2 options (affiché par JS sur mobile) ── -->
      <div class="cm-wrap" id="cmWrap">

        <!-- Option 1 : accordéon Contacter Zoé -->
        <div class="cm-card">
          <button class="cm-trigger" id="cmTrigger" type="button">
