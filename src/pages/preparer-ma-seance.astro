---
import Layout from '../layouts/Layout.astro';
import session from '../content/session.json';

if (!session.visible) {
  return Astro.redirect('/');
}
---
<Layout
  title="Avant votre première séance — Zowe"
  description="Tout ce qu'il faut savoir avant votre première séance chez Zoé Grêde — comment venir, s'habiller, ce qui se passe pendant le soin.">

  <style>
    .session-page {
      max-width: 720px;
      margin: 0 auto;
      padding: 8rem 2rem 6rem;
    }
    .session-back {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--bordeaux); text-decoration: none; margin-bottom: 3rem;
      transition: opacity 0.2s;
    }
    .session-back:hover { opacity: 0.7; }
    .session-page h1 {
      font-family: var(--serif);
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 300; font-style: italic;
      color: var(--bordeaux); margin-bottom: 0.75rem; line-height: 1.1;
    }
    .session-page .session-sub {
      font-size: 0.82rem; color: var(--light);
      margin-bottom: 3.5rem; padding-bottom: 2rem;
      border-bottom: 1px solid var(--or-border);
    }
    .session-info-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
      margin-bottom: 4rem;
    }
    .session-info-card {
      padding: 1.75rem;
      background: var(--white);
      border: 1px solid var(--border);
    }
    .session-info-card__label {
      font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--bordeaux); margin-bottom: 0.75rem;
    }
    .session-info-card p {
      font-size: 0.88rem; color: var(--mid); line-height: 1.75;
    }
    .session-timeline-title {
      font-family: var(--sans); font-size: 0.65rem; font-weight: 600;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--bordeaux); margin-bottom: 2.5rem;
    }
    .session-timeline {
      position: relative;
      padding-left: 3rem;
      margin-bottom: 4rem;
    }
    .session-timeline::before {
      content: '';
      position: absolute;
      left: 0.75rem; top: 0.5rem; bottom: 0;
      width: 1px;
      background: var(--or-border);
    }
    .timeline-step {
      position: relative;
      padding-bottom: 2.75rem;
    }
    .timeline-step:last-child { padding-bottom: 0; }
    .timeline-step::before {
      content: '';
      position: absolute;
      left: -2.35rem; top: 0.25rem;
      width: 10px; height: 10px;
      border-radius: 50%;
      background: var(--bordeaux);
      box-shadow: 0 0 0 3px var(--off-white), 0 0 0 5px rgba(201,169,110,0.3);
    }
    .timeline-step__label {
      font-size: 0.7rem; font-weight: 600;
      letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--bordeaux); margin-bottom: 0.6rem;
    }
    .timeline-step p {
      font-size: 0.9rem; color: var(--mid); line-height: 1.8;
    }
    .session-cta {
      text-align: center;
      padding-top: 3rem;
      border-top: 1px solid var(--or-border);
    }
    .session-cta p {
      font-family: var(--serif); font-size: 1rem; font-style: italic;
      color: var(--mid); margin-bottom: 1.75rem;
    }
    @media (max-width: 640px) {
      .session-info-grid { grid-template-columns: 1fr; }
    }
  </style>

  <div class="session-page">
    <a href="/" class="session-back" data-i18n="pages.back">← Retour à l'accueil</a>

    <h1 data-lang-fr={session.title_fr} data-lang-nl={session.title_nl || session.title_fr} data-lang-en={session.title_en || session.title_fr}>{session.title_fr}</h1>
    <p class="session-sub" data-i18n="pages.session.sub">Tout ce qu'il faut savoir pour aborder votre séance sereinement.</p>

    <div class="session-info-grid">
      <div class="session-info-card">
        <p class="session-info-card__label" data-i18n="pages.session.how_to_get">Comment venir</p>
        <p data-lang-fr={session.howToGet_fr} data-lang-nl={session.howToGet_nl || session.howToGet_fr} data-lang-en={session.howToGet_en || session.howToGet_fr}>{session.howToGet_fr}</p>
      </div>
      <div class="session-info-card">
        <p class="session-info-card__label" data-i18n="pages.session.dress">Comment s'habiller</p>
        <p data-lang-fr={session.dress_fr} data-lang-nl={session.dress_nl || session.dress_fr} data-lang-en={session.dress_en || session.dress_fr}>{session.dress_fr}</p>
      </div>
      <div class="session-info-card">
        <p class="session-info-card__label" data-i18n="pages.session.duration">Durée selon le protocole</p>
        <p data-lang-fr={session.duration_fr} data-lang-nl={session.duration_nl || session.duration_fr} data-lang-en={session.duration_en || session.duration_fr}>{session.duration_fr}</p>
      </div>
      <div class="session-info-card">
        <p class="session-info-card__label" data-i18n="pages.session.bring">Ce qu'il faut apporter</p>
        <p data-lang-fr={session.bring_fr} data-lang-nl={session.bring_nl || session.bring_fr} data-lang-en={session.bring_en || session.bring_fr}>{session.bring_fr}</p>
      </div>
      <div class="session-info-card" style="grid-column: 1 / -1;">
        <p class="session-info-card__label" data-i18n="pages.session.payment">Paiement</p>
        <p data-lang-fr={session.payment_fr} data-lang-nl={session.payment_nl || session.payment_fr} data-lang-en={session.payment_en || session.payment_fr}>{session.payment_fr}</p>
      </div>
    </div>

    <p class="session-timeline-title" data-i18n="pages.session.timeline_title">Déroulé de la séance</p>
    <div class="session-timeline">
      {session.steps.map((step) => (
        <div class="timeline-step">
          <p class="timeline-step__label"
             data-lang-fr={step.label_fr}
             data-lang-nl={step.label_nl || step.label_fr}
             data-lang-en={step.label_en || step.label_fr}>{step.label_fr}</p>
          <p data-lang-fr={step.text_fr}
             data-lang-nl={step.text_nl || step.text_fr}
             data-lang-en={step.text_en || step.text_fr}>{step.text_fr}</p>
        </div>
      ))}
    </div>

    <div class="session-cta">
      <p data-i18n="pages.session.cta_text">Prêt à vivre l'expérience ?</p>
      <a href="/#contact" class="btn btn-primary" data-i18n="nav.cta">Initier mon accompagnement</a>
    </div>
  </div>
</Layout>

<script is:inline>
(function() {
  function applyDataLang(lang) {
    var attr = 'data-lang-' + (lang || 'fr');
    document.querySelectorAll('[data-lang-nl],[data-lang-en],[data-lang-fr]').forEach(function(el) {
      var val = el.getAttribute(attr) || el.getAttribute('data-lang-fr');
      if (val !== null) el.textContent = val;
    });
  }
  window.addEventListener('zowe:langchange', function(e) { applyDataLang(e.detail.lang); });
  applyDataLang(localStorage.getItem('zowe-lang') || 'fr');
})();
</script>
